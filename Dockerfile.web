# Build stage
FROM node:24 AS builder

WORKDIR /app

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_AMAP_JSAPI_KEY

COPY web/package*.json ./
# lightningcss 的平台二进制在 optionalDependencies 中，构建时必须安装
RUN npm install

COPY web/ .
RUN npm run build

# Production stage
FROM node:24

# 安装 healthcheck 用的 wget（node:24 基于 Debian，默认没有 wget）
RUN apt-get update && apt-get install -y --no-install-recommends wget \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3001
ENV NEXT_TELEMETRY_DISABLED=1

COPY web/package*.json ./
# 生产环境保留 @next/swc-* 平台包，避免 next start 启动时联网下载 SWC 二进制
RUN npm install --omit=dev && \
    npm install --no-save @next/swc-linux-x64-gnu @next/swc-linux-x64-musl || true

# 将构建产物中的 SWC 二进制保留，避免启动时联网下载
# 将构建产物复制到生产镜像
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/next.config.ts ./next.config.ts

EXPOSE 3001

CMD ["npm", "start"]
