meta {
  name: 登录-5次错误后锁定
  type: http
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "schoolId": "2024001",
    "password": "wrong"
  }
}

assert {
  res.status: anyOf [401, 403]
}

docs {
  # 账号锁定策略
  连续 5 次错误密码后，账号锁定 15 分钟（返回 403 AUTH_ACCOUNT_LOCKED）。
  本测试只跑一次错误请求，验证返回 401。
  要完整验证锁定，需手动连续跑 5 次本请求，第 5 次起返回 403。
}
