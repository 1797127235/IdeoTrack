meta {
  name: 登录-管理员
  type: http
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "schoolId": "A001",
    "password": "A001"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.user.role: eq admin
}

tests {
  const data = res.getBody().data;
  if (data && data.token) {
    bru.setVar('adminToken', data.token);
  }
}
