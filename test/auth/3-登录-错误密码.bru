meta {
  name: 登录-错误密码
  type: http
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "schoolId": "2024001",
    "password": "wrong-password"
  }
}

assert {
  res.status: eq 401
  res.body.success: eq false
  res.body.error.code: eq AUTH_INVALID_CREDENTIALS
}
