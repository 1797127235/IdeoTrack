meta {
  name: 创建名言
  type: http
}

post {
  url: {{baseUrl}}/api/quotes
  body: json
  auth: bearer
}

auth:bearer {
  {{adminToken}}
}

body:json {
  {
    "content": "测试名言-Bruno 自动创建",
    "author": "测试作者",
    "source": "Bruno 测试集",
    "isEnabled": true
  }
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.data.content: eq 测试名言-Bruno 自动创建
}

tests {
  // 保存新建名言的 id，供后续更新/删除测试用
  const data = res.body.data;
  if (data && data.id) {
    setVar('quoteId', data.id);
  }
}
