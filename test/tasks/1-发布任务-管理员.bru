meta {
  name: 发布任务-管理员
  type: http
}

post {
  url: {{baseUrl}}/api/tasks
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "title": "Bruno 测试任务",
    "content": "由 Bruno 测试集自动创建的任务内容",
    "scope_type": "school",
    "published_at": "2020-01-01T00:00:00.000Z",
    "deadline_at": "2099-12-31T00:00:00.000Z"
  }
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.data.scope_label: eq 全校
}

tests {
  const data = res.getBody().data;
  if (data && data.id) {
    bru.setVar('taskId', data.id);
  }
}
