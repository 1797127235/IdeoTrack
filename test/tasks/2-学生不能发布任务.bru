meta {
  name: 发布任务-学生无权限
  type: http
}

post {
  url: {{baseUrl}}/api/tasks
  body: json
  auth: bearer
}

auth:bearer {
  token: {{studentToken}}
}

body:json {
  {
    "title": "不应成功的任务",
    "content": "x",
    "scope_type": "school",
    "published_at": "2020-01-01T00:00:00.000Z",
    "deadline_at": "2099-12-31T00:00:00.000Z"
  }
}

assert {
  res.status: eq 403
  res.body.success: eq false
}

docs {
  # RBAC 验证（AD-5）
  学生角色无权发布任务，必须返回 403。
}
