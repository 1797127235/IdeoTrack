meta {
  name: 下架任务-独立delist端点
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/api/tasks/{{taskId}}/delist
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.status: eq delisted
}

docs {
  # CR 修复点 P1：独立下架端点
  Epic 3 代码审查发现 admin 无法下架 counselor 创建的任务（PUT 接口受
  created_by 限制）。修复后改为独立 PATCH /:id/delist 端点：
  - admin 可下架任意任务
  - 发布人可下架自己的
  - 不受截止时间限制（下架是「立即隐藏」）
}
