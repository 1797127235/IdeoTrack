meta {
  name: PUT不能修改任务状态
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/api/tasks/{{taskId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "status": "delisted"
  }
}

assert {
  res.status: eq 400
  res.body.success: eq false
}

docs {
  # CR 修复点 P1：status 不能通过 PUT 修改
  必须走 PATCH /:id/delist 端点。PUT 接口收到 status 字段直接返回 400，
  防止越权修改状态。
}
