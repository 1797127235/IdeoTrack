PORT=3000
NODE_ENV=development

# Client URL for CORS (development default allows all)
CLIENT_URL=*

# PostgreSQL connection string (used by the app, migrations and seed)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ideo_track

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# WeChat Mini Program (only required for wechat login tests; other Bruno tests work without it)
WECHAT_APP_ID=your-wechat-appid
WECHAT_APP_SECRET=your-wechat-app-secret

# WeChat subscribe message template ID for counselor one-click reminder (Epic 8.3)
WECHAT_REMINDER_TEMPLATE_ID=your-reminder-template-id

# Export files (Epic 8.4 counselor data export, AD-7)
# Directory for generated export files; dev/test defaults to ./exports under cwd
# EXPORT_FILE_DIR=/app/exports
# Signed download link TTL in seconds (default 86400 = 24h, AD-7)
# EXPORT_LINK_TTL_SECONDS=86400

# PDF report generation (Epic 8.5)
# Path to Chrome/Edge/Chromium executable. On Windows the app auto-detects Edge/Chrome;
# on Linux/Docker the Dockerfile installs Chromium and sets this automatically.
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
