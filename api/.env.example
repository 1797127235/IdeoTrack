PORT=3000
NODE_ENV=development

# Client URL for CORS (development default allows all)
CLIENT_URL=*

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (used for migrations)
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# WeChat Mini Program (only required for wechat login tests; other Bruno tests work without it)
WECHAT_APP_ID=your-wechat-appid
WECHAT_APP_SECRET=your-wechat-app-secret
