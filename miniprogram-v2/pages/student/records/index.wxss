.records-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f5faf8 42%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(48rpx + env(safe-area-inset-top)) 34rpx 28rpx;
}

.back-button,
.top-placeholder {
  width: 84rpx;
}

.back-button {
  position: relative;
  height: 58rpx;
}

.back-button::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 15rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 800;
}

.content {
  padding: 0 34rpx;
}

.record-list {
  padding-top: 12rpx;
}

.record-item {
  display: flex;
  min-height: 96rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(205, 229, 216, 0.86);
  box-shadow: 0 8rpx 24rpx rgba(16, 45, 29, 0.05);
}

.record-timeline {
  position: relative;
  width: 72rpx;
  flex-shrink: 0;
  display: flex;
  justify-content: center;
}

.record-icon {
  position: relative;
  z-index: 2;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #e7f6ec;
}

.record-icon::before,
.record-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.record-icon.book::before {
  left: 13rpx;
  top: 13rpx;
  width: 26rpx;
  height: 27rpx;
  border: 4rpx solid #239c55;
  border-radius: 4rpx;
}

.record-icon.book::after {
  left: 25rpx;
  top: 14rpx;
  width: 4rpx;
  height: 25rpx;
  background: #239c55;
}

.record-icon.article::before {
  left: 14rpx;
  top: 12rpx;
  width: 25rpx;
  height: 30rpx;
  border: 4rpx solid #239c55;
  border-radius: 4rpx;
}

.record-icon.article::after {
  left: 21rpx;
  top: 21rpx;
  width: 16rpx;
  height: 4rpx;
  background: #239c55;
  box-shadow: 0 9rpx 0 #239c55, 0 18rpx 0 #239c55;
}

.record-icon.flag::before {
  left: 17rpx;
  top: 12rpx;
  width: 4rpx;
  height: 32rpx;
  background: #239c55;
}

.record-icon.flag::after {
  left: 21rpx;
  top: 14rpx;
  width: 20rpx;
  height: 16rpx;
  border-radius: 3rpx 12rpx 12rpx 3rpx;
  background: #239c55;
}

.record-main {
  flex: 1;
  min-width: 0;
  padding: 4rpx 0 8rpx;
}

.record-title {
  color: #101828;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.record-time {
  margin-top: 12rpx;
  color: #667085;
  font-size: 23rpx;
}

.record-points {
  width: 96rpx;
  padding-top: 6rpx;
  text-align: right;
  color: #249d56;
  font-size: 31rpx;
  font-weight: 800;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  text-align: center;
}

.empty-text {
  color: #667085;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-hint {
  margin-top: 16rpx;
  color: #9ca3af;
  font-size: 24rpx;
}
