<view class="mine-page">
  <view class="topbar">
    <view class="top-placeholder"></view>
    <view class="top-title">我的</view>
    <view class="settings-button" bindtap="onSettingsTap">
      <view class="settings-icon"></view>
    </view>
  </view>

  <view class="content">
    <view class="profile-card">
      <view class="campus-art" aria-hidden="true">
        <view class="campus-building">
          <view class="tower">
            <view class="spire"></view>
            <view class="clock-face"></view>
          </view>
          <view class="hall">
            <view class="roof"></view>
            <view class="window-row">
              <view class="school-window"></view>
              <view class="school-window"></view>
              <view class="school-window"></view>
            </view>
          </view>
        </view>
        <view class="tree tree-a"></view>
        <view class="tree tree-b"></view>
        <view class="leaf leaf-a"></view>
        <view class="leaf leaf-b"></view>
      </view>

      <view class="profile-main">
        <view class="avatar">
          <view class="avatar-bg"></view>
          <view class="avatar-head"></view>
          <view class="avatar-hair"></view>
          <view class="avatar-body"></view>
          <view class="avatar-strap left"></view>
          <view class="avatar-strap right"></view>
        </view>
        <view class="profile-text">
          <view class="student-name">{{student.name}}</view>
          <view class="student-meta">{{student.role}}｜{{student.college}} {{student.grade}}</view>
          <view class="level-pill">{{student.level}}</view>
        </view>
      </view>

      <view class="overview-card">
        <view class="overview-item" wx:for="{{overview}}" wx:key="key">
          <view class="overview-icon {{item.icon}}"></view>
          <view class="overview-text">
            <view class="overview-label">{{item.label}}</view>
            <view class="overview-value">{{item.value}}<text>{{item.unit}}</text></view>
          </view>
        </view>
      </view>
    </view>

    <view class="goal-card">
      <view class="goal-art">
        <view class="goal-hill"></view>
        <view class="goal-sprout">
          <view class="goal-stem"></view>
          <view class="goal-leaf one"></view>
          <view class="goal-leaf two"></view>
          <view class="goal-leaf three"></view>
        </view>
      </view>
      <view class="goal-head">
        <view class="goal-title-wrap">
          <view class="target-icon"></view>
          <view class="goal-title">本周学习目标</view>
        </view>
        <view class="goal-status">进行中</view>
      </view>
      <view class="goal-desc">坚持学习，积少成多，向更好的自己前进！</view>
      <view class="goal-progress-row">
        <view class="progress-track">
          <view class="progress-bar" style="width: {{goal.progress}}%;"></view>
        </view>
        <view class="progress-percent">{{goal.progress}}%</view>
      </view>
      <view class="goal-bottom">
        <view>目标：本周完成 <text>{{goal.target}}</text> 次学习任务</view>
        <view>已完成 <text>{{goal.finished}}</text>/{{goal.target}} 次</view>
      </view>
    </view>

    <view class="menu-card">
      <view
        class="menu-item"
        wx:for="{{menuItems}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onMenuTap"
      >
        <view class="menu-icon {{item.icon}} {{item.color}}"></view>
        <view class="menu-label">{{item.label}}</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="logout-row">
      <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>
  </view>

  <view class="student-tabbar">
    <view
      class="tab-item {{item.active ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >
      <view class="tab-icon {{item.icon}}"></view>
      <view class="tab-label">{{item.label}}</view>
    </view>
  </view>
</view>
