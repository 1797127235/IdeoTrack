.mine-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f5faf8 42%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(144rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(48rpx + env(safe-area-inset-top)) 34rpx 28rpx;
}

.top-placeholder,
.settings-button {
  width: 84rpx;
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 800;
}

.settings-button {
  display: flex;
  justify-content: flex-end;
}

.settings-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  border: 5rpx solid #111827;
  border-radius: 50%;
  box-sizing: border-box;
}

.settings-icon::before {
  content: "";
  position: absolute;
  inset: 11rpx;
  border-radius: 50%;
  background: #111827;
}

.settings-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: -12rpx;
  width: 8rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #111827;
  box-shadow: 0 0 0 0 #111827, 18rpx 18rpx 0 -1rpx #111827, -18rpx 18rpx 0 -1rpx #111827;
  transform: translateX(-50%) rotate(45deg);
  z-index: -1;
}

.content {
  padding: 0 34rpx;
}

.profile-card,
.goal-card,
.menu-card {
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(205, 229, 216, 0.86);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.profile-card {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  padding: 34rpx 28rpx 24rpx;
  background: linear-gradient(135deg, #fbfffd, #eef8ef);
}

.campus-art {
  position: absolute;
  right: -22rpx;
  top: 12rpx;
  width: 420rpx;
  height: 210rpx;
  opacity: 0.78;
}

.campus-building {
  position: absolute;
  right: 26rpx;
  bottom: 24rpx;
  width: 260rpx;
  height: 138rpx;
}

.hall {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 190rpx;
  height: 96rpx;
  border: 3rpx solid rgba(121, 171, 171, 0.42);
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(180deg, rgba(253, 237, 218, 0.9), rgba(248, 201, 164, 0.84));
}

.roof {
  position: absolute;
  top: -18rpx;
  left: -6rpx;
  width: 202rpx;
  height: 26rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(90deg, #9fd0b5, #7ab795);
  transform: skewX(-8deg);
}

.tower {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 62rpx;
  height: 136rpx;
  border: 3rpx solid rgba(121, 171, 171, 0.48);
  border-radius: 10rpx 10rpx 0 0;
  background: linear-gradient(180deg, rgba(246, 217, 189, 0.95), rgba(236, 173, 137, 0.88));
  z-index: 2;
}

.spire {
  position: absolute;
  top: -42rpx;
  left: 8rpx;
  width: 46rpx;
  height: 52rpx;
  background: linear-gradient(180deg, #bfe4d6, #6fb091);
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.clock-face {
  position: absolute;
  top: 28rpx;
  left: 17rpx;
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid rgba(120, 164, 169, 0.62);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.64);
}

.window-row {
  position: absolute;
  left: 20rpx;
  top: 34rpx;
  display: flex;
  gap: 14rpx;
}

.school-window {
  width: 28rpx;
  height: 20rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.58);
}

.tree {
  position: absolute;
  bottom: 16rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #bde694, #69bd79);
}

.tree-a {
  right: 0;
  width: 104rpx;
  height: 96rpx;
}

.tree-b {
  right: 96rpx;
  width: 76rpx;
  height: 70rpx;
}

.leaf {
  position: absolute;
  width: 24rpx;
  height: 12rpx;
  border-radius: 24rpx 0;
  background: #8fd589;
}

.leaf-a {
  left: 88rpx;
  top: 42rpx;
  transform: rotate(-34deg);
}

.leaf-b {
  left: 162rpx;
  top: 76rpx;
  width: 17rpx;
  height: 9rpx;
  background: #cfdf61;
  transform: rotate(22deg);
}

.profile-main {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  min-height: 172rpx;
}

.avatar {
  position: relative;
  width: 138rpx;
  height: 138rpx;
  margin-right: 34rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: #d8f0ed;
  box-shadow: 0 8rpx 18rpx rgba(16, 24, 40, 0.12);
}

.avatar-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, #dff7f2 0%, #d1eee5 48%, #a9d795 49%, #85c073 100%);
}

.avatar-head {
  position: absolute;
  left: 39rpx;
  top: 30rpx;
  width: 58rpx;
  height: 66rpx;
  border-radius: 46% 46% 48% 48%;
  background: #ffd9b6;
  z-index: 3;
}

.avatar-hair {
  position: absolute;
  left: 28rpx;
  top: 20rpx;
  width: 78rpx;
  height: 48rpx;
  border-radius: 48rpx 48rpx 26rpx 28rpx;
  background: #2d2019;
  z-index: 4;
}

.avatar-hair::after {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 24rpx;
  width: 18rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #2d2019;
  box-shadow: 22rpx -3rpx 0 #2d2019, 42rpx 2rpx 0 #2d2019;
}

.avatar-body {
  position: absolute;
  left: 25rpx;
  bottom: -18rpx;
  width: 88rpx;
  height: 72rpx;
  border-radius: 34rpx 34rpx 18rpx 18rpx;
  background: #39795e;
  z-index: 2;
}

.avatar-strap {
  position: absolute;
  bottom: 10rpx;
  width: 12rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: #233746;
  z-index: 5;
}

.avatar-strap.left {
  left: 22rpx;
  transform: rotate(12deg);
}

.avatar-strap.right {
  right: 22rpx;
  transform: rotate(-12deg);
}

.profile-text {
  position: relative;
  z-index: 2;
  min-width: 0;
}

.student-name {
  color: #111827;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.student-meta {
  margin-top: 18rpx;
  color: #566074;
  font-size: 24rpx;
  white-space: nowrap;
}

.level-pill {
  display: inline-block;
  min-width: 86rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin-top: 22rpx;
  padding: 0 18rpx;
  border-radius: 17rpx;
  color: #fff;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
  background: linear-gradient(180deg, #35b66a, #1f9952);
}

.overview-card {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 24rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 20rpx rgba(16, 24, 40, 0.05);
}

.overview-item {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.overview-item + .overview-item {
  border-left: 1rpx solid #dce6df;
}

.overview-icon,
.menu-icon {
  position: relative;
  flex-shrink: 0;
  box-sizing: border-box;
}

.overview-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
}

.overview-icon.calendar {
  background: #eef8f1;
}

.overview-icon.calendar::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid #25a85a;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.overview-icon.calendar::after {
  content: "";
  position: absolute;
  left: 21rpx;
  top: 26rpx;
  width: 16rpx;
  height: 9rpx;
  border-left: 5rpx solid #25a85a;
  border-bottom: 5rpx solid #25a85a;
  transform: rotate(-45deg);
}

.overview-icon.medal {
  background: linear-gradient(180deg, #ffd66b, #f59e0b);
  border-radius: 50%;
}

.overview-icon.medal::before {
  content: "★";
  position: absolute;
  left: 0;
  right: 0;
  top: 9rpx;
  color: #fff;
  text-align: center;
  font-size: 28rpx;
  line-height: 1;
}

.overview-icon.medal::after {
  content: "";
  position: absolute;
  left: 14rpx;
  bottom: -16rpx;
  width: 26rpx;
  height: 24rpx;
  background: #f59e0b;
  clip-path: polygon(0 0, 50% 45%, 100% 0, 100% 100%, 50% 72%, 0 100%);
}

.overview-icon.clock {
  background: linear-gradient(135deg, #74b4ff, #3b82f6);
  border-radius: 50%;
}

.overview-icon.clock::before {
  content: "";
  position: absolute;
  left: 25rpx;
  top: 15rpx;
  width: 5rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #fff;
}

.overview-icon.clock::after {
  content: "";
  position: absolute;
  left: 27rpx;
  top: 30rpx;
  width: 14rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #fff;
  transform: rotate(36deg);
}

.overview-label {
  color: #667085;
  font-size: 24rpx;
  white-space: nowrap;
}

.overview-value {
  margin-top: 6rpx;
  color: #101828;
  font-size: 39rpx;
  line-height: 1;
  font-weight: 800;
  white-space: nowrap;
}

.overview-value text {
  margin-left: 6rpx;
  color: #667085;
  font-size: 21rpx;
  font-weight: 500;
}

.goal-card {
  position: relative;
  overflow: hidden;
  margin-top: 24rpx;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
}

.goal-art {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 230rpx;
  height: 140rpx;
  pointer-events: none;
}

.goal-hill {
  position: absolute;
  right: -34rpx;
  bottom: -48rpx;
  width: 230rpx;
  height: 118rpx;
  border-radius: 50% 50% 0 0;
  background: linear-gradient(180deg, #a8dc70, #76c65d);
  transform: rotate(-12deg);
}

.goal-sprout {
  position: absolute;
  right: 74rpx;
  bottom: 44rpx;
  width: 72rpx;
  height: 82rpx;
}

.goal-stem {
  position: absolute;
  left: 34rpx;
  bottom: 0;
  width: 8rpx;
  height: 74rpx;
  border-radius: 999rpx;
  background: #38a656;
}

.goal-leaf {
  position: absolute;
  width: 34rpx;
  height: 20rpx;
  border-radius: 34rpx 0;
  background: #80cc45;
}

.goal-leaf.one {
  left: 2rpx;
  top: 24rpx;
  transform: rotate(38deg);
}

.goal-leaf.two {
  right: 0;
  top: 8rpx;
  transform: rotate(-28deg);
}

.goal-leaf.three {
  right: 3rpx;
  top: 42rpx;
  transform: rotate(-14deg);
}

.goal-head,
.goal-title-wrap,
.goal-progress-row,
.goal-bottom {
  position: relative;
  z-index: 2;
}

.goal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goal-title-wrap {
  display: flex;
  align-items: center;
  min-width: 0;
}

.target-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  margin-right: 18rpx;
  border: 5rpx solid #20a45a;
  border-radius: 50%;
  box-sizing: border-box;
}

.target-icon::before {
  content: "";
  position: absolute;
  inset: 9rpx;
  border: 4rpx solid #20a45a;
  border-radius: 50%;
}

.target-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  top: 8rpx;
  width: 18rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #20a45a;
  transform: rotate(-35deg);
}

.goal-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
}

.goal-status {
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #168145;
  background: #dff3e5;
  font-size: 23rpx;
  font-weight: 700;
}

.goal-desc {
  position: relative;
  z-index: 2;
  margin-top: 24rpx;
  color: #566074;
  font-size: 25rpx;
}

.goal-progress-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
}

.progress-track {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #dceee3;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #1f9d52;
}

.progress-percent {
  color: #20a45a;
  font-size: 27rpx;
  font-weight: 800;
}

.goal-bottom {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 24rpx;
  color: #566074;
  font-size: 23rpx;
}

.goal-bottom text {
  color: #20a45a;
  font-weight: 800;
}

.menu-card {
  margin-top: 24rpx;
  border-radius: 24rpx;
  padding: 0 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 86rpx;
  border-bottom: 1rpx solid #edf1ee;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-icon {
  width: 46rpx;
  height: 46rpx;
  margin-right: 24rpx;
}

.menu-label {
  flex: 1;
  color: #101828;
  font-size: 28rpx;
  font-weight: 600;
}

.menu-arrow {
  color: #98a2b3;
  font-size: 46rpx;
  line-height: 1;
}

.menu-icon.task::before,
.menu-icon.report::before,
.menu-icon.star::before,
.menu-icon.badge::before,
.menu-icon.bell::before,
.menu-icon.help::before,
.menu-icon.settings::before,
.menu-icon.task::after,
.menu-icon.report::after,
.menu-icon.badge::after,
.menu-icon.bell::after,
.menu-icon.settings::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.menu-icon.green { color: #22a35a; }
.menu-icon.blue { color: #5b9dfd; }
.menu-icon.orange { color: #f5a515; }
.menu-icon.purple { color: #8e6ce8; }
.menu-icon.gray { color: #667085; }

.menu-icon.task::before {
  left: 8rpx;
  top: 7rpx;
  width: 30rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 7rpx;
}

.menu-icon.task::after {
  left: 17rpx;
  top: 22rpx;
  width: 16rpx;
  height: 9rpx;
  border-left: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  transform: rotate(-45deg);
}

.menu-icon.report::before {
  left: 8rpx;
  top: 6rpx;
  width: 30rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 7rpx;
}

.menu-icon.report::after {
  left: 18rpx;
  top: 16rpx;
  width: 16rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 20rpx 0 currentColor;
}

.menu-icon.star::before {
  content: "☆";
  position: absolute;
  left: -2rpx;
  top: -12rpx;
  color: currentColor;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 600;
}

.menu-icon.badge::before {
  left: 7rpx;
  top: 7rpx;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.menu-icon.badge::after {
  left: 18rpx;
  top: 18rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: -9rpx 23rpx 0 -1rpx currentColor, 9rpx 23rpx 0 -1rpx currentColor;
}

.menu-icon.bell::before {
  left: 10rpx;
  top: 7rpx;
  width: 26rpx;
  height: 29rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 16rpx 16rpx 0 0;
}

.menu-icon.bell::after {
  left: 7rpx;
  top: 31rpx;
  width: 32rpx;
  height: 10rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 18rpx 18rpx;
}

.menu-icon.help::before {
  content: "?";
  position: absolute;
  inset: 3rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  color: currentColor;
  text-align: center;
  font-size: 31rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.menu-icon.settings::before {
  left: 6rpx;
  top: 6rpx;
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 10rpx;
  transform: rotate(45deg);
}

.menu-icon.settings::after {
  left: 19rpx;
  top: 19rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.student-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  box-sizing: border-box;
  min-height: calc(112rpx + env(safe-area-inset-bottom));
  padding: 12rpx 28rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(213, 224, 219, 0.72);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(16, 24, 40, 0.05);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 22rpx;
}

.tab-item.active {
  color: #1f9d52;
  font-weight: 700;
}

.tab-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.tab-icon.home::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 22rpx;
  width: 28rpx;
  height: 24rpx;
  border-radius: 5rpx;
  background: currentColor;
  z-index: 2;
}

.tab-icon.home::after {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  background: currentColor;
  transform: rotate(45deg);
  z-index: 1;
}

.tab-icon.clipboard::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 10rpx;
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.tab-icon.clipboard::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 20rpx 0 currentColor;
}

.tab-icon.star::before {
  content: "☆";
  position: absolute;
  left: 50%;
  top: 50%;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 600;
  transform: translate(-50%, -54%);
}

.tab-icon.user {
  border: 0;
}

.tab-icon.user::before,
.tab-icon.user::after {
  content: "";
  position: absolute;
  left: 50%;
  box-sizing: border-box;
  transform: translateX(-50%);
}

.tab-icon.user::before {
  top: 6rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  background: currentColor;
}

.tab-icon.user::after {
  top: 31rpx;
  width: 42rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
  background: currentColor;
}

.tab-label {
  height: 26rpx;
  line-height: 26rpx;
  font-size: 22rpx;
  text-align: center;
}

.logout-row {
  margin-top: 24rpx;
  padding: 0 34rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(16, 45, 29, 0.06);
}

.logout-btn::after {
  border: 0;
}

.logout-btn:active {
  opacity: 0.85;
}

@media (max-width: 360px) {
  .profile-main {
    align-items: flex-start;
  }

  .avatar {
    width: 118rpx;
    height: 118rpx;
    margin-right: 22rpx;
  }

  .student-meta {
    white-space: normal;
  }

  .overview-card,
  .goal-bottom {
    flex-direction: column;
    align-items: stretch;
  }

  .overview-item {
    justify-content: flex-start;
  }

  .overview-item + .overview-item {
    border-left: 0;
    border-top: 1rpx solid #dce6df;
    padding-top: 18rpx;
    margin-top: 18rpx;
  }
}
