.home-page {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #eff8f6 0%, #f6faf8 42%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(172rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  min-height: 406rpx;
  padding: calc(34rpx + env(safe-area-inset-top)) 42rpx 0;
  overflow: hidden;
}

.campus-art {
  position: absolute;
  top: 34rpx;
  right: -34rpx;
  width: 448rpx;
  height: 360rpx;
  pointer-events: none;
  opacity: 0.82;
}

.sun,
.cloud,
.leaf,
.building,
.trees {
  position: absolute;
}

.sun {
  top: 52rpx;
  right: 166rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 0 40rpx rgba(255, 255, 255, 0.9);
}

.cloud {
  height: 46rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.cloud::before,
.cloud::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: inherit;
}

.cloud::before {
  width: 56rpx;
  height: 56rpx;
  left: 32rpx;
  bottom: 14rpx;
}

.cloud::after {
  width: 70rpx;
  height: 70rpx;
  left: 78rpx;
  bottom: 4rpx;
}

.cloud-left {
  top: 112rpx;
  left: 2rpx;
  width: 156rpx;
}

.cloud-right {
  top: 66rpx;
  right: 54rpx;
  width: 144rpx;
}

.leaf {
  width: 24rpx;
  height: 12rpx;
  border-radius: 24rpx 0;
  background: #8fd589;
  transform: rotate(-36deg);
}

.leaf-one {
  top: 114rpx;
  left: 74rpx;
}

.leaf-two {
  top: 152rpx;
  left: 160rpx;
  width: 18rpx;
  height: 10rpx;
  background: #cfdf61;
  transform: rotate(22deg);
}

.building {
  right: 46rpx;
  bottom: 52rpx;
  width: 292rpx;
  height: 202rpx;
}

.hall {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 220rpx;
  height: 138rpx;
  border: 4rpx solid rgba(121, 171, 171, 0.42);
  border-radius: 10rpx 10rpx 0 0;
  background: linear-gradient(180deg, rgba(253, 237, 218, 0.9), rgba(248, 201, 164, 0.84));
  box-shadow: inset 0 -16rpx 0 rgba(255, 255, 255, 0.35);
}

.roof {
  position: absolute;
  top: -24rpx;
  left: -8rpx;
  width: 236rpx;
  height: 34rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(90deg, #9fd0b5, #7ab795);
  transform: skewX(-8deg);
}

.tower {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 78rpx;
  height: 198rpx;
  border: 4rpx solid rgba(121, 171, 171, 0.48);
  border-radius: 12rpx 12rpx 0 0;
  background: linear-gradient(180deg, rgba(246, 217, 189, 0.95), rgba(236, 173, 137, 0.88));
  z-index: 2;
}

.spire {
  position: absolute;
  top: -54rpx;
  left: 10rpx;
  width: 58rpx;
  height: 68rpx;
  background: linear-gradient(180deg, #bfe4d6, #6fb091);
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.clock {
  position: absolute;
  top: 34rpx;
  left: 17rpx;
  width: 38rpx;
  height: 38rpx;
  border: 3rpx solid rgba(120, 164, 169, 0.62);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.64);
  color: #85a9ad;
  font-size: 23rpx;
  line-height: 38rpx;
  text-align: center;
}

.tower-window {
  position: absolute;
  bottom: 36rpx;
  left: 23rpx;
  width: 28rpx;
  height: 54rpx;
  border-radius: 14rpx 14rpx 4rpx 4rpx;
  background: rgba(255, 255, 255, 0.58);
}

.window-row {
  display: flex;
  gap: 16rpx;
  position: absolute;
  top: 38rpx;
  left: 24rpx;
}

.window-row.lower {
  top: 86rpx;
}

.school-window {
  width: 34rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 2rpx solid rgba(120, 164, 169, 0.24);
}

.trees {
  right: 0;
  bottom: 14rpx;
  width: 330rpx;
  height: 86rpx;
}

.tree {
  position: absolute;
  bottom: 0;
  border-radius: 50% 50% 42% 44%;
  background: linear-gradient(180deg, #bde694, #69bd79);
}

.tree::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -18rpx;
  width: 10rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: #a98252;
  transform: translateX(-50%);
}

.tree-one {
  left: 12rpx;
  width: 82rpx;
  height: 74rpx;
}

.tree-two {
  left: 78rpx;
  width: 108rpx;
  height: 92rpx;
}

.tree-three {
  right: 8rpx;
  width: 128rpx;
  height: 114rpx;
}

.page-top {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 34rpx;
}

.page-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: 0;
}

.notice-button {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bell {
  position: relative;
  width: 38rpx;
  height: 40rpx;
  border: 5rpx solid #111827;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  border-bottom: 0;
}

.bell::before {
  content: "";
  position: absolute;
  left: -8rpx;
  bottom: -11rpx;
  width: 54rpx;
  height: 17rpx;
  border: 5rpx solid #111827;
  border-top: 0;
  border-radius: 0 0 24rpx 24rpx;
}

.bell::after {
  content: "";
  position: absolute;
  left: 13rpx;
  bottom: -22rpx;
  width: 13rpx;
  height: 7rpx;
  border-radius: 0 0 12rpx 12rpx;
  background: #111827;
}

.bell-dot {
  position: absolute;
  top: -14rpx;
  right: -19rpx;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid #f5faf8;
  border-radius: 50%;
  background: #ff4038;
}

.greeting,
.date-row,
.motto {
  position: relative;
  z-index: 2;
}

.greeting {
  max-width: 500rpx;
  margin-bottom: 24rpx;
  font-size: 50rpx;
  line-height: 1.22;
  font-weight: 800;
  letter-spacing: 0;
}

.date-row {
  margin-bottom: 18rpx;
  color: #566074;
  font-size: 27rpx;
  font-weight: 500;
}

.motto {
  max-width: 560rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
}

.content {
  position: relative;
  z-index: 3;
  padding: 0 42rpx;
}

.quote-card,
.panel,
.reading-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(213, 224, 219, 0.72);
  box-shadow: 0 14rpx 34rpx rgba(21, 43, 35, 0.08);
}

.quote-card {
  display: flex;
  align-items: center;
  min-height: 106rpx;
  margin-bottom: 32rpx;
  padding: 18rpx 28rpx;
  border-radius: 22rpx;
}

.quote-icon {
  width: 82rpx;
  height: 82rpx;
  margin-right: 28rpx;
  border-radius: 50%;
  background: #edf8ef;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sprout {
  position: relative;
  width: 44rpx;
  height: 58rpx;
}

.stem {
  position: absolute;
  left: 20rpx;
  bottom: 0;
  width: 6rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #23a455;
}

.leaf-shape {
  position: absolute;
  width: 28rpx;
  height: 18rpx;
  border-radius: 28rpx 0;
  background: #4cc36f;
}

.leaf-shape.left {
  left: -2rpx;
  top: 18rpx;
  transform: rotate(42deg);
}

.leaf-shape.right {
  right: -4rpx;
  top: 6rpx;
  transform: rotate(-26deg);
}

.quote-text {
  flex: 1;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.quote-author {
  color: #667085;
  font-size: 23rpx;
  white-space: nowrap;
}

.panel {
  border-radius: 24rpx;
}

.task-panel {
  margin-bottom: 24rpx;
  padding: 26rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  min-width: 0;
}

.section-icon {
  flex-shrink: 0;
  margin-right: 18rpx;
}

.clipboard-icon {
  position: relative;
  width: 38rpx;
  height: 44rpx;
  border: 5rpx solid #25a75a;
  border-radius: 8rpx;
}

.clipboard-icon::before {
  content: "";
  position: absolute;
  top: -13rpx;
  left: 7rpx;
  width: 18rpx;
  height: 15rpx;
  border: 5rpx solid #25a75a;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
  background: #fff;
}

.clipboard-icon::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 12rpx;
  width: 17rpx;
  height: 10rpx;
  border-left: 5rpx solid #25a75a;
  border-bottom: 5rpx solid #25a75a;
  transform: rotate(-45deg);
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.more-link {
  color: #1f9d52;
  font-size: 25rpx;
  font-weight: 600;
  white-space: nowrap;
}

.chevron {
  margin-left: 8rpx;
  font-size: 38rpx;
  line-height: 1;
  vertical-align: -2rpx;
}

.section-subtitle {
  margin: 22rpx 0 20rpx;
  color: #667085;
  font-size: 25rpx;
}

.task-card {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid #e9eeee;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, 0.07);
}

.task-body {
  display: flex;
  align-items: stretch;
  margin-bottom: 20rpx;
}

.task-visual {
  position: relative;
  width: 172rpx;
  min-height: 150rpx;
  margin-right: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ff765f 0%, #ffb16e 56%, #fff4d7 100%);
}

.red-banner {
  position: absolute;
  left: -30rpx;
  top: 52rpx;
  width: 150rpx;
  height: 56rpx;
  background: linear-gradient(90deg, rgba(201, 24, 38, 0.86), rgba(246, 117, 76, 0.22));
  transform: rotate(-22deg);
}

.gold-pillar {
  position: absolute;
  top: 20rpx;
  left: 76rpx;
  width: 28rpx;
  height: 90rpx;
  border-radius: 14rpx 14rpx 6rpx 6rpx;
  background: linear-gradient(90deg, #c48629, #f5c765, #a66e20);
  box-shadow: 0 0 0 6rpx rgba(255, 227, 138, 0.18);
}

.open-book {
  position: absolute;
  left: 28rpx;
  right: 22rpx;
  bottom: 16rpx;
  height: 58rpx;
  perspective: 120rpx;
}

.book-page {
  position: absolute;
  bottom: 0;
  width: 62rpx;
  height: 50rpx;
  border-radius: 4rpx 18rpx 5rpx 5rpx;
  background: #fff5df;
  box-shadow: inset 0 -5rpx 0 rgba(246, 193, 97, 0.18);
}

.left-page {
  left: 6rpx;
  transform: skewY(13deg);
}

.right-page {
  right: 6rpx;
  transform: skewY(-13deg);
}

.task-info {
  min-width: 0;
  flex: 1;
}

.task-title-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.task-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.36;
  font-weight: 800;
}

.task-status {
  flex-shrink: 0;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  background: #def7e8;
  color: #1c9b55;
  font-size: 22rpx;
  font-weight: 700;
}

.task-summary {
  display: -webkit-box;
  overflow: hidden;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx 18rpx;
  margin-top: 22rpx;
  color: #667085;
  font-size: 21rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  min-width: 0;
}

.meta-clock {
  position: relative;
  width: 22rpx;
  height: 22rpx;
  margin-right: 8rpx;
  border: 3rpx solid #667085;
  border-radius: 50%;
  flex-shrink: 0;
}

.meta-clock::before,
.meta-clock::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 4rpx;
  width: 3rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #667085;
}

.meta-clock::after {
  top: 10rpx;
  width: 7rpx;
  height: 3rpx;
}

.points {
  color: #f59e0b;
  font-weight: 700;
}

.point-star {
  margin-right: 6rpx;
  font-size: 27rpx;
  line-height: 1;
}

.complete-btn {
  width: 100%;
  height: 74rpx;
  line-height: 74rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f9d52, #249b55);
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(34, 163, 84, 0.22);
}

.complete-btn::after {
  border: 0;
}

.complete-btn:active {
  transform: scale(0.985);
}

.stats-grid {
  display: flex;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  min-width: 0;
  min-height: 174rpx;
  padding: 26rpx 24rpx;
}

.stat-title {
  margin-bottom: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.streak-row {
  display: flex;
  align-items: center;
}

.streak-number {
  font-size: 58rpx;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 0;
}

.streak-unit {
  margin: 18rpx auto 0 12rpx;
  color: #667085;
  font-size: 23rpx;
}

.calendar-badge {
  position: relative;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: #eef8f1;
  flex-shrink: 0;
}

.calendar-top {
  position: absolute;
  left: 18rpx;
  top: 20rpx;
  width: 42rpx;
  height: 38rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #2aa75c 0 32%, #ccefd9 32%);
}

.calendar-top::before,
.calendar-top::after {
  content: "";
  position: absolute;
  top: -8rpx;
  width: 6rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #2aa75c;
}

.calendar-top::before {
  left: 10rpx;
}

.calendar-top::after {
  right: 10rpx;
}

.calendar-check {
  position: absolute;
  right: 16rpx;
  bottom: 17rpx;
  width: 26rpx;
  height: 15rpx;
  border-left: 5rpx solid #2aa75c;
  border-bottom: 5rpx solid #2aa75c;
  transform: rotate(-45deg);
}

.stat-note {
  margin-top: 20rpx;
  color: #667085;
  font-size: 23rpx;
  white-space: nowrap;
}

.stat-note text {
  color: #ff7a1a;
  font-weight: 700;
}

.progress-layout {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.progress-ring {
  position: relative;
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  background: conic-gradient(#24a659 0deg 259deg, #e8f3eb 259deg 360deg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  flex-shrink: 0;
}

.progress-value,
.progress-label {
  position: relative;
  z-index: 1;
  line-height: 1;
}

.progress-ring::after {
  content: "";
  position: absolute;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #fff;
}

.progress-value {
  font-size: 26rpx;
  font-weight: 800;
}

.progress-value text {
  margin-left: 2rpx;
  font-size: 16rpx;
  font-weight: 700;
}

.progress-label {
  margin-top: 5rpx;
  color: #667085;
  font-size: 15rpx;
}

.progress-list {
  flex: 1;
  min-width: 0;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.8;
  white-space: nowrap;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot.green {
  background: #24a659;
}

.dot.orange {
  background: #f5a515;
}

.dot.gray {
  background: #98a2b3;
}

.progress-name {
  flex: 1;
}

.progress-days {
  color: #101828;
  font-weight: 700;
}

.reading-card {
  display: flex;
  align-items: center;
  min-height: 102rpx;
  padding: 18rpx 18rpx 18rpx 22rpx;
  border-radius: 22rpx;
}

.reading-icon,
.reading-cover {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.reading-icon {
  background: #24a659;
}

.reading-icon::before,
.reading-icon::after {
  content: "";
  position: absolute;
  top: 15rpx;
  width: 15rpx;
  height: 26rpx;
  border: 4rpx solid #fff;
  border-radius: 2rpx 8rpx 8rpx 2rpx;
}

.reading-icon::before {
  left: 12rpx;
  transform: skewY(8deg);
}

.reading-icon::after {
  right: 12rpx;
  transform: skewY(-8deg);
}

.reading-label {
  width: 72rpx;
  color: #1f9d52;
  font-size: 25rpx;
  line-height: 1.25;
  font-weight: 800;
}

.divider {
  width: 1rpx;
  height: 58rpx;
  margin: 0 18rpx;
  background: #d9e5df;
  flex-shrink: 0;
}

.reading-info {
  flex: 1;
  min-width: 0;
}

.reading-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #111827;
  font-size: 25rpx;
  font-weight: 700;
}

.reading-subtitle {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 12rpx;
  color: #667085;
  font-size: 21rpx;
}

.reading-book {
  position: relative;
  width: 78rpx;
  height: 46rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.book-cover {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 34rpx;
  border-radius: 2rpx 12rpx 3rpx 3rpx;
  border-bottom: 5rpx solid #0e9f89;
  background: linear-gradient(180deg, #f3fbff, #dff2f0);
}

.book-cover.left {
  left: 4rpx;
  transform: skewY(12deg);
}

.book-cover.right {
  right: 4rpx;
  transform: skewY(-12deg);
}

.reading-arrow {
  margin-left: 12rpx;
  color: #667085;
  font-size: 50rpx;
  line-height: 1;
}

.student-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  box-sizing: border-box;
  min-height: calc(112rpx + env(safe-area-inset-bottom));
  padding: 12rpx 28rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(213, 224, 219, 0.72);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(16, 24, 40, 0.05);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 22rpx;
}

.tab-item.active {
  color: #1f9d52;
  font-weight: 700;
}

.tab-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.tab-icon.home::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 22rpx;
  width: 28rpx;
  height: 24rpx;
  border-radius: 5rpx;
  background: currentColor;
  z-index: 2;
}

.tab-icon.home::after {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  background: currentColor;
  transform: rotate(45deg);
  z-index: 1;
}

.tab-icon.clipboard {
  border: 0;
}

.tab-icon.clipboard::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 10rpx;
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.tab-icon.clipboard::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 20rpx 0 currentColor;
}

.tab-icon.star::before {
  content: "☆";
  position: absolute;
  left: 50%;
  top: 50%;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 600;
  transform: translate(-50%, -54%);
}

.tab-icon.user {
  border: 0;
}

.tab-icon.user::before,
.tab-icon.user::after {
  content: "";
  position: absolute;
  left: 50%;
  box-sizing: border-box;
  transform: translateX(-50%);
}

.tab-icon.user::before {
  top: 6rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.tab-icon.user::after {
  top: 31rpx;
  width: 42rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
}

.tab-label {
  height: 26rpx;
  line-height: 26rpx;
  font-size: 22rpx;
  text-align: center;
}

@media (max-width: 360px) {
  .hero {
    padding-left: 34rpx;
    padding-right: 34rpx;
  }

  .content {
    padding-left: 34rpx;
    padding-right: 34rpx;
  }

  .task-body {
    flex-direction: column;
  }

  .task-visual {
    width: 100%;
    min-height: 170rpx;
    margin-right: 0;
    margin-bottom: 18rpx;
  }

  .stats-grid {
    flex-direction: column;
  }
}
