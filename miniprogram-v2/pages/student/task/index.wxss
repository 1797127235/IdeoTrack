.task-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f6faf8 42%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 34rpx 26rpx;
  border-bottom: 1rpx solid #e8eeeb;
  background: rgba(255, 255, 255, 0.82);
}

.back-button,
.top-actions {
  width: 150rpx;
}

.back-button {
  position: relative;
  height: 58rpx;
}

.back-button::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 15rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 35rpx;
  line-height: 1.2;
  font-weight: 800;
}

.top-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 32rpx;
}

.search-button,
.filter-button {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.search-button::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  width: 30rpx;
  height: 30rpx;
  border: 5rpx solid #111827;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-button::after {
  content: "";
  position: absolute;
  right: 6rpx;
  bottom: 7rpx;
  width: 19rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #111827;
  transform: rotate(45deg);
}

.filter-button::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 6rpx;
  width: 34rpx;
  height: 38rpx;
  border: 5rpx solid #111827;
  border-top-width: 6rpx;
  clip-path: polygon(0 0, 100% 0, 66% 46%, 66% 100%, 34% 82%, 34% 46%);
  box-sizing: border-box;
}

.status-tabs {
  display: flex;
  align-items: center;
  height: 78rpx;
  border-bottom: 1rpx solid #e8eeeb;
  background: rgba(255, 255, 255, 0.92);
}

.status-tab {
  position: relative;
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  color: #566074;
  font-size: 28rpx;
  font-weight: 600;
}

.status-tab.active {
  color: #1f9d52;
  font-weight: 800;
}

.status-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 62rpx;
  height: 6rpx;
  border-radius: 999rpx 999rpx 0 0;
  background: #22a35a;
  transform: translateX(-50%);
}

.content {
  padding: 28rpx 30rpx 0;
}

.task-summary {
  margin: 4rpx 6rpx 24rpx;
  color: #566074;
  font-size: 25rpx;
}

.task-summary text {
  color: #1f9d52;
  font-weight: 800;
}

.task-summary .pending-count {
  color: #f58a22;
}

.task-card {
  display: flex;
  align-items: stretch;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.08);
}

.task-card-hover {
  transform: scale(0.985);
  background: rgba(255, 255, 255, 1);
  box-shadow: 0 8rpx 20rpx rgba(16, 45, 29, 0.06);
}

.task-visual {
  position: relative;
  width: 142rpx;
  min-height: 166rpx;
  margin-right: 26rpx;
  overflow: hidden;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #f3f8f4;
}

.visual-shape {
  position: absolute;
}

.task-visual.book {
  background: linear-gradient(135deg, #ffb36f, #ffe8bd);
}

.task-visual.book .shape-one {
  left: 40rpx;
  top: 26rpx;
  width: 64rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #bd3d22, #e65d36);
  box-shadow: -8rpx 5rpx 0 rgba(150, 55, 27, 0.22);
}

.task-visual.book .shape-one::after {
  content: "习近平";
  position: absolute;
  left: 0;
  right: 0;
  top: 35rpx;
  color: #fff8d9;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
}

.task-visual.book .shape-two {
  left: 18rpx;
  right: 14rpx;
  bottom: 18rpx;
  height: 46rpx;
  border-radius: 4rpx 18rpx 4rpx 4rpx;
  background: #fff5de;
  transform: skewY(-7deg);
}

.task-visual.book .shape-three {
  left: 18rpx;
  bottom: 32rpx;
  width: 56rpx;
  height: 4rpx;
  background: rgba(219, 142, 65, 0.38);
  box-shadow: 12rpx 12rpx 0 rgba(219, 142, 65, 0.28);
}

.task-visual.wall {
  background: linear-gradient(180deg, #dcf2c5, #5eaf5f);
}

.task-visual.wall .shape-one {
  left: -26rpx;
  bottom: -2rpx;
  width: 190rpx;
  height: 78rpx;
  border-radius: 50% 50% 0 0;
  background: #2f8c47;
}

.task-visual.wall .shape-two {
  left: 42rpx;
  top: 34rpx;
  width: 54rpx;
  height: 60rpx;
  border-radius: 8rpx 8rpx 2rpx 2rpx;
  background: #237743;
}

.task-visual.wall .shape-three {
  left: 16rpx;
  top: 88rpx;
  width: 118rpx;
  height: 26rpx;
  border-radius: 20rpx;
  background: #b9df8b;
  transform: rotate(-28deg);
}

.task-visual.video {
  background: linear-gradient(180deg, #c6e8ff, #eaf6ff);
}

.task-visual.video .shape-one {
  left: 20rpx;
  top: 44rpx;
  width: 102rpx;
  height: 78rpx;
  border-radius: 10rpx;
  background: #f8fbff;
  box-shadow: inset 0 -8rpx 0 #c9e2fb;
}

.task-visual.video .shape-two {
  left: 51rpx;
  top: 64rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #5b9dfd;
}

.task-visual.video .shape-two::after {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 12rpx;
  width: 0;
  height: 0;
  border-left: 16rpx solid #fff;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}

.task-visual.video .shape-three {
  left: 14rpx;
  right: 14rpx;
  bottom: 28rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #5b9dfd;
}

.task-visual.service {
  background: linear-gradient(180deg, #cbf0d4, #88d899);
}

.task-visual.service .shape-one,
.task-visual.service .shape-two,
.task-visual.service .shape-three {
  border-radius: 50%;
}

.task-visual.service .shape-one {
  left: 20rpx;
  top: 26rpx;
  width: 58rpx;
  height: 58rpx;
  background: #41b967;
}

.task-visual.service .shape-two {
  right: 18rpx;
  top: 50rpx;
  width: 48rpx;
  height: 48rpx;
  background: #1f8d58;
}

.task-visual.service .shape-three {
  left: -20rpx;
  right: -20rpx;
  bottom: -28rpx;
  height: 96rpx;
  background: #69bd79;
}

.task-visual.flag {
  background: linear-gradient(135deg, #ffa56f, #ffe4bf);
}

.task-visual.flag .shape-one {
  left: 44rpx;
  top: 28rpx;
  width: 6rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: #ba3a24;
}

.task-visual.flag .shape-two {
  left: 50rpx;
  top: 30rpx;
  width: 74rpx;
  height: 48rpx;
  border-radius: 4rpx 28rpx 28rpx 4rpx;
  background: #e74b2c;
}

.task-visual.flag .shape-three {
  left: -20rpx;
  right: -20rpx;
  bottom: -18rpx;
  height: 74rpx;
  border-radius: 50% 50% 0 0;
  background: rgba(232, 95, 56, 0.22);
}

.task-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.task-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.task-title {
  flex: 1;
  min-width: 0;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
}

.task-badges {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.attachment-badge {
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #7c3aed;
  background: #ede9fe;
  font-size: 22rpx;
  font-weight: 700;
}

.status-pill {
  flex-shrink: 0;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.status-pill.pending {
  color: #15904b;
  background: #dff5e6;
}

.status-pill.progress {
  color: #1d78df;
  background: #e4f0ff;
}

.status-pill.done {
  color: #667085;
  background: #eef0f2;
}

.task-desc {
  display: -webkit-box;
  margin-top: 16rpx;
  overflow: hidden;
  color: #566074;
  font-size: 24rpx;
  line-height: 1.55;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 26rpx;
  margin-top: 22rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  color: #566074;
  font-size: 21rpx;
}

.calendar-icon,
.clock-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.calendar-icon {
  border: 3rpx solid #667085;
  border-radius: 5rpx;
}

.calendar-icon::before {
  content: "";
  position: absolute;
  left: -3rpx;
  right: -3rpx;
  top: 5rpx;
  height: 3rpx;
  background: #667085;
}

.clock-icon {
  border: 3rpx solid #667085;
  border-radius: 50%;
}

.clock-icon::before,
.clock-icon::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 4rpx;
  width: 3rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #667085;
}

.clock-icon::after {
  top: 11rpx;
  width: 8rpx;
  height: 3rpx;
}

.task-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: auto;
  padding-top: 20rpx;
}

.points {
  color: #f58a22;
  font-size: 22rpx;
  font-weight: 700;
}

.points text {
  margin-right: 6rpx;
  font-size: 27rpx;
}

.action-button {
  display: inline-block;
  min-width: 132rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
  box-sizing: border-box;
}

.action-button.pending {
  color: #fff;
  background: linear-gradient(90deg, #1f9d52, #249b55);
  box-shadow: 0 8rpx 16rpx rgba(34, 163, 84, 0.22);
}

.action-button.progress {
  color: #1d78df;
  border: 2rpx solid #2b83ee;
  background: #fff;
}

.action-button.done {
  color: #667085;
  background: #eef0f2;
}

.student-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  box-sizing: border-box;
  min-height: calc(112rpx + env(safe-area-inset-bottom));
  padding: 12rpx 28rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(213, 224, 219, 0.72);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(16, 24, 40, 0.05);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 22rpx;
}

.tab-item.active {
  color: #1f9d52;
  font-weight: 700;
}

.tab-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.tab-icon.home::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 22rpx;
  width: 28rpx;
  height: 24rpx;
  border-radius: 5rpx;
  background: currentColor;
  z-index: 2;
}

.tab-icon.home::after {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  background: currentColor;
  transform: rotate(45deg);
  z-index: 1;
}

.tab-icon.clipboard::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 10rpx;
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.tab-icon.clipboard::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 20rpx 0 currentColor;
}

.tab-icon.star::before {
  content: "☆";
  position: absolute;
  left: 50%;
  top: 50%;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 600;
  transform: translate(-50%, -54%);
}

.tab-icon.user {
  border: 0;
}

.tab-icon.user::before,
.tab-icon.user::after {
  content: "";
  position: absolute;
  left: 50%;
  box-sizing: border-box;
  transform: translateX(-50%);
}

.tab-icon.user::before {
  top: 6rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.tab-icon.user::after {
  top: 31rpx;
  width: 42rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
}

.tab-item.active .tab-icon.user::before,
.tab-item.active .tab-icon.user::after {
  background: currentColor;
}

.tab-label {
  height: 26rpx;
  line-height: 26rpx;
  font-size: 22rpx;
  text-align: center;
}

@media (max-width: 360px) {
  .task-card {
    flex-direction: column;
  }

  .task-visual {
    width: 100%;
    min-height: 172rpx;
    margin-right: 0;
    margin-bottom: 18rpx;
  }

  .task-foot {
    align-items: flex-start;
    flex-direction: column;
  }

  .action-button {
    width: 100%;
  }
}
