.learning-resource-detail-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 32rpx 26rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-button {
  position: relative;
  width: 64rpx;
  height: 58rpx;
}

.back-button::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 15rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 35rpx;
  font-weight: 800;
  color: #101828;
}

.top-placeholder {
  width: 64rpx;
}

.content {
  padding: 28rpx 30rpx;
}

.cover-section {
  margin-bottom: 22rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.cover-image,
.cover-placeholder {
  width: 100%;
  height: 360rpx;
}

.cover-placeholder {
  background: linear-gradient(135deg, #22a35a, #4ade80);
}

.info-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.resource-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #101828;
  line-height: 1.4;
  margin-bottom: 18rpx;
}

.resource-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meta-tag {
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #22a35a;
  background: #dcfce7;
  font-weight: 700;
}

.meta-tag.type {
  color: #3b82f6;
  background: #dbeafe;
}

.view-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.resource-desc {
  font-size: 27rpx;
  color: #4b5563;
  line-height: 1.7;
}

.content-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.content-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 18rpx;
}

.content-body {
  font-size: 27rpx;
  color: #4b5563;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
  z-index: 20;
}

.open-url-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(90deg, #1f9d52, #249b55);
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(34, 163, 90, 0.28);
}

.open-url-btn::after {
  border: none;
}

.loading-state {
  padding: 120rpx 48rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.error-state {
  padding: 100rpx 48rpx;
  text-align: center;
}

.error-text {
  font-size: 28rpx;
  color: #ef4444;
  margin-bottom: 28rpx;
}

.retry-btn {
  display: inline-block;
  background: #fff;
  color: #15904b;
  font-size: 28rpx;
  font-weight: 800;
  padding: 16rpx 48rpx;
  border-radius: 100rpx;
  border: 1rpx solid #22a35a;
}

.retry-btn::after {
  border: none;
}
