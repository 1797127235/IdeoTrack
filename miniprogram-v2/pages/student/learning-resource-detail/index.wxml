<view class="learning-resource-detail-page">
  <view class="topbar">
    <view class="back-button" bindtap="onBackTap"></view>
    <view class="top-title">推荐阅读</view>
    <view class="top-placeholder"></view>
  </view>

  <view class="content" wx:if="{{resource && !loading}}">
    <view class="cover-section">
      <image class="cover-image" wx:if="{{coverUrl}}" src="{{coverUrl}}" mode="aspectFill" />
      <view class="cover-placeholder" wx:else></view>
    </view>

    <view class="info-card">
      <view class="resource-title">{{resource.title}}</view>
      <view class="resource-meta">
        <view class="meta-tag" wx:if="{{resource.category}}">{{resource.category}}</view>
        <view class="meta-tag type">{{resource.type === 'article' ? '文章' : resource.type === 'video' ? '视频' : resource.type === 'document' ? '文档' : '链接'}}</view>
        <view class="view-count">{{resource.view_count}} 次阅读</view>
      </view>
      <view class="resource-desc" wx:if="{{resource.description}}">{{resource.description}}</view>
    </view>

    <view class="content-card" wx:if="{{resource.content}}">
      <view class="content-title">内容</view>
      <view class="content-body">{{resource.content}}</view>
    </view>

    <view class="bottom-bar" wx:if="{{resource.url}}">
      <button class="open-url-btn" bindtap="onOpenUrl">查看原文</button>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-text">加载中…</view>
  </view>

  <view class="error-state" wx:if="{{error}}">
    <view class="error-text">{{error}}</view>
    <button class="retry-btn" bindtap="onRetry">重新加载</button>
  </view>
</view>
