.teacher-mine-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f6faf8 44%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 34rpx 28rpx;
}

.top-placeholder,
.notice-button {
  width: 84rpx;
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.notice-button {
  position: relative;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  height: 56rpx;
}

.bell-icon {
  position: relative;
  width: 34rpx;
  height: 36rpx;
  border: 5rpx solid #111827;
  border-top-left-radius: 22rpx;
  border-top-right-radius: 22rpx;
  border-bottom: 0;
  box-sizing: border-box;
}

.bell-icon::before {
  content: "";
  position: absolute;
  left: -8rpx;
  bottom: -11rpx;
  width: 50rpx;
  height: 16rpx;
  border: 5rpx solid #111827;
  border-top: 0;
  border-radius: 0 0 22rpx 22rpx;
  box-sizing: border-box;
}

.bell-icon::after {
  content: "";
  position: absolute;
  left: 10rpx;
  bottom: -19rpx;
  width: 12rpx;
  height: 7rpx;
  border-radius: 0 0 12rpx 12rpx;
  background: #111827;
}

.notice-dot {
  position: absolute;
  right: 10rpx;
  top: 0;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #fbfdfc;
  border-radius: 50%;
  background: #ef4444;
}

.content {
  padding: 0 30rpx;
}

.profile-card {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  padding: 34rpx 28rpx;
  background: linear-gradient(135deg, #fbfffd, #eef8ef);
  border: 1rpx solid rgba(205, 229, 216, 0.86);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.profile-art {
  position: absolute;
  right: 0;
  top: 0;
  width: 220rpx;
  height: 100%;
  pointer-events: none;
}

.art-leaf {
  position: absolute;
  border-radius: 50% 0;
  background: rgba(34, 197, 94, 0.12);
}

.art-leaf.leaf-a {
  right: -30rpx;
  top: -20rpx;
  width: 140rpx;
  height: 140rpx;
  transform: rotate(30deg);
}

.art-leaf.leaf-b {
  right: 40rpx;
  top: 60rpx;
  width: 90rpx;
  height: 90rpx;
  background: rgba(34, 197, 94, 0.08);
  transform: rotate(-20deg);
}

.art-leaf.leaf-c {
  right: -10rpx;
  bottom: 20rpx;
  width: 70rpx;
  height: 70rpx;
  background: rgba(34, 197, 94, 0.1);
  transform: rotate(45deg);
}

.profile-main {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
}

.avatar {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  margin-right: 28rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: #d8f0ed;
  box-shadow: 0 8rpx 18rpx rgba(16, 24, 40, 0.1);
}

.avatar-face {
  position: absolute;
  left: 30rpx;
  top: 28rpx;
  width: 72rpx;
  height: 78rpx;
  border-radius: 46% 46% 48% 48%;
  background: #ffe4c9;
  z-index: 3;
}

.avatar-hair {
  position: absolute;
  left: 22rpx;
  top: 14rpx;
  width: 88rpx;
  height: 56rpx;
  border-radius: 44rpx 44rpx 24rpx 24rpx;
  background: #2d2019;
  z-index: 4;
}

.avatar-hair::after {
  content: "";
  position: absolute;
  right: 8rpx;
  top: 26rpx;
  width: 22rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #2d2019;
}

.avatar-glasses {
  position: absolute;
  left: 34rpx;
  top: 52rpx;
  width: 64rpx;
  height: 20rpx;
  z-index: 5;
}

.avatar-glasses::before,
.avatar-glasses::after {
  content: "";
  position: absolute;
  top: 0;
  width: 24rpx;
  height: 20rpx;
  border: 4rpx solid #4b5563;
  border-radius: 50%;
  box-sizing: border-box;
}

.avatar-glasses::before {
  left: 0;
}

.avatar-glasses::after {
  right: 0;
}

.avatar-body {
  position: absolute;
  left: 18rpx;
  bottom: -18rpx;
  width: 96rpx;
  height: 74rpx;
  border-radius: 38rpx 38rpx 16rpx 16rpx;
  background: #39795e;
  z-index: 2;
}

.profile-text {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.profile-name {
  color: #111827;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
}

.role-badge {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  color: #15904b;
  background: #e3f6ea;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-meta {
  color: #566074;
  font-size: 26rpx;
  line-height: 1.5;
}

.stats-card {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 30rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.stats-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.stats-divider {
  width: 1rpx;
  height: 80rpx;
  background: #e5e7eb;
}

.stats-label {
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 600;
}

.stats-value {
  margin-top: 14rpx;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.stats-value text {
  margin-left: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.stats-value.green {
  color: #16a65a;
}

.stats-value.orange {
  color: #f59e0b;
}

.menu-card {
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid #edf1ee;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-item:active {
  opacity: 0.7;
}

.menu-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  margin-right: 22rpx;
  color: #22a35a;
  flex-shrink: 0;
  box-sizing: border-box;
}

.menu-label {
  flex: 1;
  color: #101828;
  font-size: 30rpx;
  font-weight: 600;
}

.menu-arrow {
  color: #98a2b3;
  font-size: 46rpx;
  line-height: 1;
}

.menu-icon.group::before,
.menu-icon.group::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: currentColor;
}

.menu-icon.group::before {
  left: 14rpx;
  top: 4rpx;
  width: 16rpx;
  height: 16rpx;
}

.menu-icon.group::after {
  left: 3rpx;
  top: 24rpx;
  width: 38rpx;
  height: 16rpx;
  border-radius: 16rpx 16rpx 5rpx 5rpx;
  box-shadow: -14rpx -4rpx 0 -2rpx currentColor, 14rpx -4rpx 0 -2rpx currentColor;
}

.menu-icon.clipboard::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 6rpx;
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.menu-icon.clipboard::after {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 20rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor;
}

.menu-icon.reviews::before,
.menu-icon.reviews::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

/* 第一人 */
.menu-icon.reviews::before {
  left: 16rpx;
  top: 4rpx;
  width: 13rpx;
  height: 13rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 0 16rpx 0 -2rpx currentColor;
}

/* 第二人 + 对勾圆圈 */
.menu-icon.reviews::after {
  left: 0;
  top: 22rpx;
  width: 32rpx;
  height: 13rpx;
  border-radius: 13rpx 13rpx 4rpx 4rpx;
  background: currentColor;
}

.menu-icon.bell::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 28rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 16rpx 16rpx 0 0;
  box-sizing: border-box;
}

.menu-icon.bell::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 31rpx;
  width: 34rpx;
  height: 10rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 16rpx 16rpx;
  box-sizing: border-box;
}

.menu-icon.lock::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 16rpx;
  width: 32rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.menu-icon.lock::after {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 4rpx;
  width: 16rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
  box-sizing: border-box;
}

.menu-icon.help::before {
  content: "?";
  position: absolute;
  inset: 2rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  color: currentColor;
  text-align: center;
  font-size: 30rpx;
  line-height: 36rpx;
  font-weight: 800;
}

.menu-icon.settings::before {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 5rpx;
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 10rpx;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.menu-icon.settings::after {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.logout-row {
  margin-top: 24rpx;
  padding-bottom: 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 24rpx;
  color: #ef4444;
  background: rgba(255, 255, 255, 0.97);
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.logout-btn::after {
  border: 0;
}

.teacher-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  box-sizing: border-box;
  min-height: calc(112rpx + env(safe-area-inset-bottom));
  padding: 12rpx 28rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(213, 224, 219, 0.72);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(16, 24, 40, 0.05);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7a8280;
  font-size: 22rpx;
}

.tab-item.active {
  color: #18a85a;
  font-weight: 800;
}

.tab-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.tab-icon.group::before,
.tab-icon.group::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: currentColor;
}

.tab-icon.group::before {
  left: 17rpx;
  top: 8rpx;
  width: 18rpx;
  height: 18rpx;
}

.tab-icon.group::after {
  left: 7rpx;
  top: 30rpx;
  width: 38rpx;
  height: 16rpx;
  border-radius: 18rpx 18rpx 6rpx 6rpx;
  box-shadow: -18rpx -5rpx 0 -2rpx currentColor, 18rpx -5rpx 0 -2rpx currentColor;
}

.tab-icon.grid::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 7rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  background: currentColor;
  box-shadow: 22rpx 0 0 currentColor, 0 22rpx 0 currentColor, 22rpx 22rpx 0 currentColor;
}

.tab-icon.clipboard::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 10rpx;
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.tab-icon.clipboard::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 20rpx 0 currentColor;
}

.tab-icon.user::before,
.tab-icon.user::after {
  content: "";
  position: absolute;
  left: 50%;
  box-sizing: border-box;
  transform: translateX(-50%);
}

.tab-icon.user::before {
  top: 6rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.tab-icon.user::after {
  top: 31rpx;
  width: 42rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
}

.tab-label {
  height: 26rpx;
  line-height: 26rpx;
  font-size: 22rpx;
  text-align: center;
}

@media (max-width: 360px) {
  .profile-name {
    font-size: 34rpx;
  }

  .stats-value {
    font-size: 40rpx;
  }
}
