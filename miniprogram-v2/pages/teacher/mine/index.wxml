<view class="teacher-mine-page">
  <view class="topbar">
    <view class="top-placeholder"></view>
    <view class="top-title">我的</view>
    <view class="notice-button" bindtap="onNotificationTap">
      <view class="bell-icon"></view>
      <view class="notice-dot" wx:if="{{stats.pendingReviewCount > 0}}"></view>
    </view>
  </view>

  <view class="content">
    <view class="profile-card">
      <view class="profile-art" aria-hidden="true">
        <view class="art-leaf leaf-a"></view>
        <view class="art-leaf leaf-b"></view>
        <view class="art-leaf leaf-c"></view>
      </view>

      <view class="profile-main">
        <view class="avatar">
          <view class="avatar-face"></view>
          <view class="avatar-hair"></view>
          <view class="avatar-glasses"></view>
          <view class="avatar-body"></view>
        </view>
        <view class="profile-text">
          <view class="profile-name-row">
            <view class="profile-name">{{profile.name}}</view>
            <view class="role-badge">{{profile.roleLabel}}</view>
          </view>
          <view class="profile-meta" wx:if="{{profile.college}}">{{profile.college}}</view>
          <view class="profile-meta">工号：{{profile.staffId}}</view>
        </view>
      </view>
    </view>

    <view class="stats-card">
      <view class="stats-item">
        <view class="stats-label">管理班级</view>
        <view class="stats-value green">{{stats.classCount}}<text>个</text></view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <view class="stats-label">学生总数</view>
        <view class="stats-value green">{{stats.studentCount}}<text>人</text></view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <view class="stats-label">待人工复核</view>
        <view class="stats-value orange">{{stats.pendingReviewCount}}<text>条</text></view>
      </view>
    </view>

    <view class="menu-card">
      <view
        class="menu-item"
        wx:for="{{menuItems}}"
        wx:key="key"
        data-key="{{item.key}}"
        data-label="{{item.label}}"
        bindtap="onMenuTap"
      >
        <view class="menu-icon {{item.icon}}"></view>
        <view class="menu-label">{{item.label}}</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="logout-row">
      <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>
  </view>

  <view class="teacher-tabbar">
    <view
      class="tab-item {{item.active ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >
      <view class="tab-icon {{item.icon}}"></view>
      <view class="tab-label">{{item.label}}</view>
    </view>
  </view>
</view>
