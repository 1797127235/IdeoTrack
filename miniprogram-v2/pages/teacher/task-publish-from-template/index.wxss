.teacher-task-publish-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f6faf8 44%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 24rpx 24rpx;
}

.back-button,
.top-placeholder {
  width: 84rpx;
}

.back-button {
  display: flex;
  align-items: center;
  height: 56rpx;
}

.back-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.content {
  padding: 0 30rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #667085;
  font-size: 28rpx;
}

.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 18rpx;
  border: 5rpx solid #e5e7eb;
  border-top-color: #16a65a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.section-title {
  margin: 28rpx 4rpx 18rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
}

.template-list {
  margin-bottom: 18rpx;
}

.template-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 8rpx 20rpx rgba(16, 45, 29, 0.05);
}

.template-card.active {
  border-color: #16a65a;
  background: #f0fdf4;
}

.template-card:active {
  opacity: 0.96;
}

.template-title {
  margin-bottom: 10rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
}

.template-desc {
  margin-bottom: 14rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.template-meta {
  display: flex;
  gap: 14rpx;
}

.template-category,
.template-checkin {
  padding: 5rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.template-category {
  color: #16a65a;
  background: #e3f6ea;
}

.template-checkin {
  color: #2f7ee6;
  background: #e3f0ff;
}

.template-location {
  padding: 5rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #6b7280;
  background: #f3f4f6;
}

.template-location.required {
  color: #dc2626;
  background: #fee2e2;
}

.class-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.class-tag {
  padding: 14rpx 26rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 999rpx;
  color: #4b5563;
  background: #f9fafb;
  font-size: 26rpx;
  font-weight: 600;
}

.class-tag.active {
  color: #fff;
  background: linear-gradient(135deg, #24c66a 0%, #16a65a 100%);
  border-color: transparent;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #9ca3af;
  font-size: 26rpx;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 14rpx;
  border: 5rpx solid #e5e7eb;
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
}

.empty-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 28rpx;
  width: 20rpx;
  height: 14rpx;
  border: 4rpx solid #d1d5db;
  border-top: 0;
  border-radius: 0 0 10rpx 10rpx;
  transform: translateX(-50%);
  box-sizing: border-box;
}

.form-card {
  margin-bottom: 32rpx;
  padding: 8rpx 26rpx;
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.form-item {
  padding: 26rpx 0;
  border-bottom: 1rpx solid #edf1ee;
}

.form-item:last-child {
  border-bottom: 0;
}

.form-label {
  margin-bottom: 18rpx;
  color: #374151;
  font-size: 29rpx;
  font-weight: 700;
}

.datetime-row {
  display: flex;
  gap: 18rpx;
}

.datetime-row picker {
  flex: 1;
}

.picker-value {
  padding: 18rpx 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  background: #f9fafb;
  color: #101828;
  font-size: 28rpx;
  text-align: center;
}

.attachment-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 8rpx 20rpx rgba(16, 45, 29, 0.05);
}

.attachment-name {
  flex: 1;
  color: #101828;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-tag {
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #16a65a;
  background: #e3f6ea;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.locate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 14rpx 0;
  border: 1rpx solid #4f46e5;
  border-radius: 12rpx;
  color: #4f46e5;
  background: #eef2ff;
  font-size: 26rpx;
  font-weight: 700;
}

.locate-icon {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #4f46e5;
  border-radius: 50%;
  position: relative;
}

.locate-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  background: #4f46e5;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.map-search {
  position: relative;
  margin-bottom: 16rpx;
}

.search-icon {
  position: absolute;
  left: 22rpx;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid #9ca3af;
  border-radius: 50%;
  transform: translateY(-50%);
  box-sizing: border-box;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: -10rpx;
  bottom: -4rpx;
  width: 14rpx;
  height: 4rpx;
  background: #9ca3af;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.map-search-input {
  width: 100%;
  padding: 18rpx 20rpx 18rpx 56rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 14rpx;
  background: #ffffff;
  color: #101828;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #9ca3af;
}

.search-results {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(100% + 8rpx);
  max-height: 320rpx;
  overflow-y: auto;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  background: #fff;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 10;
}

.search-result-item {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.search-result-item:last-child {
  border-bottom: 0;
}

.result-name {
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.result-address {
  margin-top: 4rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.location-map {
  width: 100%;
  height: 420rpx;
  border-radius: 14rpx;
  margin-bottom: 16rpx;
}

.selected-location {
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  background: #f9fafb;
}

.selected-location .location-name {
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.selected-location .location-address {
  margin-top: 4rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.location-box {
  padding: 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  background: #f9fafb;
}

.location-placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

.location-name {
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
}

.location-address {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.radius-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.radius-row .form-label.small {
  margin-bottom: 0;
  font-size: 26rpx;
}

.radius-input {
  flex: 1;
  margin-left: 24rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 12rpx;
  background: #ffffff;
  color: #101828;
  font-size: 30rpx;
  line-height: 1.5;
  text-align: right;
  box-sizing: border-box;
  min-height: 88rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 18rpx;
  color: #fff;
  background: linear-gradient(135deg, #24c66a 0%, #16a65a 100%);
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(22, 166, 90, 0.22);
}

.submit-btn::after {
  border: 0;
}

.submit-btn[disabled],
.submit-btn.disabled {
  background: #d1d5db;
  color: #9ca3af;
  box-shadow: none;
}
