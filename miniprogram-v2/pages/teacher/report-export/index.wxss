.teacher-report-export-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 32rpx 26rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-button {
  position: relative;
  width: 64rpx;
  height: 58rpx;
}

.back-button::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 15rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 35rpx;
  font-weight: 800;
  color: #101828;
}

.top-placeholder {
  width: 64rpx;
}

.form {
  padding: 24rpx 30rpx;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  font-size: 30rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 20rpx;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-pill {
  padding: 14rpx 28rpx;
  border-radius: 100rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.15s;
}

.option-pill.active {
  background: #16a65a;
  color: #fff;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.date-picker {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  border: 1rpx solid #f3f4f6;
  color: #374151;
  font-size: 28rpx;
}

.date-icon {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.date-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid #16a65a;
  border-radius: 4rpx;
}

.date-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 12rpx;
  transform: translateX(-50%);
  width: 14rpx;
  height: 3rpx;
  background: #16a65a;
  box-shadow: 0 6rpx 0 #16a65a;
}

.date-sep {
  color: #9ca3af;
  font-size: 28rpx;
}

.range-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  background: #f9fafb;
}

.range-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  flex-shrink: 0;
}

.range-icon.class::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 10rpx;
  transform: translateX(-50%);
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid #16a65a;
  border-radius: 50%;
}

.range-icon.class::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 30rpx;
  transform: translateX(-50%);
  width: 28rpx;
  height: 10rpx;
  border: 4rpx solid #16a65a;
  border-radius: 8rpx 8rpx 0 0;
  border-bottom: 0;
}

.range-main {
  flex: 1;
}

.range-strong {
  font-size: 30rpx;
  font-weight: 700;
  color: #101828;
}

.range-text {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.range-arrow {
  color: #9ca3af;
  font-size: 24rpx;
}

.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 22rpx 26rpx;
  border-radius: 16rpx;
  background: #f0fdf4;
  margin-top: 10rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  position: relative;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid #16a65a;
  border-radius: 50%;
}

.tip-icon::after {
  content: "i";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 18rpx;
  font-weight: 800;
  color: #16a65a;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #15803d;
  line-height: 1.5;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 100rpx;
  background: linear-gradient(90deg, #1f9d52, #16a65a);
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.7;
}
