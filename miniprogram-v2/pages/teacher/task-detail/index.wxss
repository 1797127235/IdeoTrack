.teacher-task-detail-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 32rpx 26rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-button {
  position: relative;
  width: 64rpx;
  height: 58rpx;
}

.back-button::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 15rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 35rpx;
  font-weight: 800;
  color: #101828;
}

.top-placeholder {
  width: 64rpx;
}

.content {
  padding: 28rpx 30rpx;
}

.task-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.task-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #101828;
  line-height: 1.35;
  margin-bottom: 16rpx;
}

.task-desc {
  font-size: 27rpx;
  color: #4b5563;
  line-height: 1.6;
  margin-bottom: 22rpx;
}

.task-meta-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  border-top: 1rpx solid #f3f4f6;
  padding-top: 20rpx;
}

.task-meta-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 25rpx;
  color: #6b7280;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.meta-icon.deadline {
  background: #fee2e2;
}

.meta-icon.checkin {
  background: #dbeafe;
}

.meta-icon.location {
  background: #dcfce7;
}

.meta-icon.face {
  background: #ede9fe;
}

.stat-card {
  display: flex;
  margin-bottom: 22rpx;
  padding: 26rpx 16rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #101828;
}

.stat-value.green {
  color: #16a65a;
}

.stat-value.orange {
  color: #f47c12;
}

.stat-label {
  font-size: 23rpx;
  color: #6b7280;
}

.section-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 22rpx;
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.class-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.class-info {
  width: 160rpx;
  flex-shrink: 0;
}

.class-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #101828;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.class-count {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.class-bar-wrap {
  flex: 1;
  height: 14rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  overflow: hidden;
}

.class-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f9d52, #4ade80);
}

.class-rate {
  width: 90rpx;
  text-align: right;
  font-size: 26rpx;
  font-weight: 800;
  color: #16a65a;
  flex-shrink: 0;
}

.list-card {
  padding-bottom: 20rpx;
}

.tab-bar {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.tab-item {
  padding-bottom: 16rpx;
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 600;
  position: relative;
}

.tab-item.active {
  color: #16a65a;
  font-weight: 800;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  background: #16a65a;
  border-radius: 2rpx;
}

.student-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.student-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
  background: #f9fafb;
  border-radius: 14rpx;
}

.student-info {
  flex: 1;
  min-width: 0;
}

.student-name {
  font-size: 27rpx;
  font-weight: 700;
  color: #101828;
  margin-bottom: 4rpx;
}

.student-class {
  font-size: 23rpx;
  color: #9ca3af;
}

.student-id {
  font-size: 24rpx;
  color: #6b7280;
  font-family: monospace;
}

.student-status {
  padding: 6rpx 14rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.student-status.approved,
.student-status.ai_approved {
  color: #047857;
  background: #d1fae5;
}

.student-status.pending_manual_review {
  color: #b45309;
  background: #fef3c7;
}

.student-status.submitted,
.student-status.ai_reviewing {
  color: #1d78df;
  background: #dbeafe;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #9ca3af;
  font-size: 27rpx;
}

.loading-state {
  padding: 120rpx 48rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.error-state {
  padding: 100rpx 48rpx;
  text-align: center;
}

.error-text {
  font-size: 28rpx;
  color: #ef4444;
  margin-bottom: 28rpx;
}

.retry-btn {
  display: inline-block;
  background: #fff;
  color: #15904b;
  font-size: 28rpx;
  font-weight: 800;
  padding: 16rpx 48rpx;
  border-radius: 100rpx;
  border: 1rpx solid #22a35a;
}

.retry-btn::after {
  border: none;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
  z-index: 20;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  border: none;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.action-btn.secondary {
  color: #16a65a;
  background: #fff;
  border: 2rpx solid #16a65a;
}

.action-btn.primary {
  color: #fff;
  background: linear-gradient(90deg, #1f9d52, #249b55);
  box-shadow: 0 8rpx 20rpx rgba(34, 163, 90, 0.28);
}
