.teacher-classes-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f6faf8 44%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 34rpx 28rpx;
}

.top-placeholder,
.notice-button {
  width: 84rpx;
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.notice-button {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  height: 56rpx;
}

.bell-icon {
  position: relative;
  width: 34rpx;
  height: 36rpx;
  border: 5rpx solid #111827;
  border-top-left-radius: 22rpx;
  border-top-right-radius: 22rpx;
  border-bottom: 0;
  box-sizing: border-box;
}

.bell-icon::before {
  content: "";
  position: absolute;
  left: -8rpx;
  bottom: -11rpx;
  width: 50rpx;
  height: 16rpx;
  border: 5rpx solid #111827;
  border-top: 0;
  border-radius: 0 0 22rpx 22rpx;
  box-sizing: border-box;
}

.bell-icon::after {
  content: "";
  position: absolute;
  left: 10rpx;
  bottom: -19rpx;
  width: 12rpx;
  height: 7rpx;
  border-radius: 0 0 12rpx 12rpx;
  background: #111827;
}

.content {
  padding: 0 34rpx;
}

.summary-card {
  overflow: hidden;
  border-radius: 24rpx;
  padding: 34rpx 24rpx 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #24c66a 0%, #16a65a 56%, #0f934d 100%);
  box-shadow: 0 16rpx 30rpx rgba(21, 160, 84, 0.22);
}

.summary-row {
  display: flex;
  align-items: center;
}

.summary-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.summary-label {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.94;
}

.summary-value {
  margin-top: 18rpx;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 0;
}

.summary-value text {
  margin-left: 6rpx;
  font-size: 25rpx;
  font-weight: 700;
}

.summary-divider {
  width: 1rpx;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.36);
}

.summary-note {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.14);
  font-size: 23rpx;
  font-weight: 600;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  margin-right: 14rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.section-title {
  margin: 34rpx 4rpx 22rpx;
  color: #101828;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 800;
}

.class-card {
  overflow: hidden;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.08);
}

.class-main {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 22rpx;
}

.class-icon-wrap {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  margin-right: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.class-icon-wrap.green {
  background: #ddf5e6;
}

.class-icon-wrap.blue {
  background: #e3f0ff;
}

.class-icon-wrap.purple {
  background: #efe5ff;
}

.class-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 58rpx;
  height: 58rpx;
  transform: translate(-50%, -50%);
}

.class-icon::before,
.class-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.class-card.green .class-icon::before {
  left: 4rpx;
  top: 6rpx;
  width: 50rpx;
  height: 38rpx;
  border: 5rpx solid #19a75a;
  border-radius: 5rpx;
}

.class-card.green .class-icon::after {
  content: "</>";
  left: 11rpx;
  top: 15rpx;
  color: #19a75a;
  font-size: 21rpx;
  line-height: 1;
  font-weight: 800;
}

.class-card.blue .class-icon::before {
  left: 4rpx;
  top: 8rpx;
  width: 50rpx;
  height: 34rpx;
  border: 5rpx solid #2f7ee6;
  border-radius: 5rpx;
}

.class-card.blue .class-icon::after {
  left: 0;
  bottom: 4rpx;
  width: 58rpx;
  height: 14rpx;
  border-radius: 6rpx 6rpx 3rpx 3rpx;
  background: #2f7ee6;
}

.class-card.purple .class-icon::before {
  left: 3rpx;
  top: 8rpx;
  width: 52rpx;
  height: 38rpx;
  border: 5rpx solid #8a4de8;
  border-radius: 5rpx;
}

.class-card.purple .class-icon::after {
  content: "</>";
  left: 11rpx;
  top: 18rpx;
  color: #8a4de8;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 800;
}

.class-info {
  flex: 1;
  min-width: 0;
}

.class-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.class-name {
  color: #101828;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 800;
}

.class-arrow {
  color: #667085;
  font-size: 54rpx;
  line-height: 1;
}

.class-metrics {
  display: flex;
  align-items: center;
}

.metric {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.metric-label {
  color: #667085;
  font-size: 22rpx;
  white-space: nowrap;
}

.metric-value {
  margin-top: 8rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 800;
}

.metric-divider {
  width: 1rpx;
  height: 58rpx;
  margin: 0 18rpx;
  background: #d7dfdc;
}

.class-footer {
  display: grid;
  grid-template-columns: 136rpx 1fr 148rpx;
  align-items: end;
  gap: 18rpx;
  padding: 22rpx 24rpx 24rpx;
  border-top: 1rpx solid #edf1ee;
}

.completion-label {
  color: #101828;
  font-size: 20rpx;
  font-weight: 700;
  white-space: nowrap;
}

.completion-label text {
  color: #667085;
  font-weight: 500;
}

.completion-value {
  margin-top: 10rpx;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 800;
}

.completion-value.green {
  color: #17a85a;
}

.completion-value.blue {
  color: #2f7ee6;
}

.completion-value.purple {
  color: #8a4de8;
}

.progress-track {
  height: 13rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e6e7e8;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
}

.progress-bar.green {
  background: #19a75a;
}

.progress-bar.blue {
  background: #2f7ee6;
}

.progress-bar.purple {
  background: #8a4de8;
}

.view-button {
  width: 148rpx;
  height: 58rpx;
  line-height: 56rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  background: #fff;
}

.view-button::after {
  border: 0;
}

.view-button.green {
  color: #17a85a;
  border: 2rpx solid #17a85a;
}

.view-button.blue {
  color: #2f7ee6;
  border: 2rpx solid #2f7ee6;
}

.view-button.purple {
  color: #8a4de8;
  border: 2rpx solid #8a4de8;
}

.teacher-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  box-sizing: border-box;
  min-height: calc(112rpx + env(safe-area-inset-bottom));
  padding: 12rpx 28rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(213, 224, 219, 0.72);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(16, 24, 40, 0.05);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7a8280;
  font-size: 22rpx;
}

.tab-item.active {
  color: #18a85a;
  font-weight: 800;
}

.tab-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.tab-icon.group::before,
.tab-icon.group::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: currentColor;
}

.tab-icon.group::before {
  left: 17rpx;
  top: 8rpx;
  width: 18rpx;
  height: 18rpx;
}

.tab-icon.group::after {
  left: 7rpx;
  top: 30rpx;
  width: 38rpx;
  height: 16rpx;
  border-radius: 18rpx 18rpx 6rpx 6rpx;
  box-shadow: -18rpx -5rpx 0 -2rpx currentColor, 18rpx -5rpx 0 -2rpx currentColor;
}

.tab-icon.grid::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 7rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  background: currentColor;
  box-shadow: 22rpx 0 0 currentColor, 0 22rpx 0 currentColor, 22rpx 22rpx 0 currentColor;
}

.tab-icon.clipboard::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 10rpx;
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.tab-icon.clipboard::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 20rpx 0 currentColor;
}

.tab-icon.user::before,
.tab-icon.user::after {
  content: "";
  position: absolute;
  left: 50%;
  box-sizing: border-box;
  transform: translateX(-50%);
}

.tab-icon.user::before {
  top: 6rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.tab-icon.user::after {
  top: 31rpx;
  width: 42rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
}

.tab-label {
  height: 26rpx;
  line-height: 26rpx;
  font-size: 22rpx;
  text-align: center;
}

@media (max-width: 360px) {
  .summary-card {
    padding-left: 16rpx;
    padding-right: 16rpx;
  }

  .summary-label {
    font-size: 21rpx;
  }

  .summary-value {
    font-size: 46rpx;
  }

  .class-footer {
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .view-button {
    width: 100%;
  }
}
