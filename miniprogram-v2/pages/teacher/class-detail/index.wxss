.teacher-class-detail-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 32rpx 26rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-button {
  position: relative;
  width: 64rpx;
  height: 58rpx;
}

.back-button::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 15rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 35rpx;
  font-weight: 800;
  color: #101828;
}

.top-placeholder {
  width: 64rpx;
}

.content {
  padding: 28rpx 30rpx;
}

.header-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.header-main {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.class-icon {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #e3f6ea;
  flex-shrink: 0;
}

.class-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 44%;
  transform: translate(-50%, -50%);
  width: 44rpx;
  height: 34rpx;
  border: 5rpx solid #16a65a;
  border-radius: 6rpx;
}

.class-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 24rpx;
  transform: translateX(-50%);
  width: 20rpx;
  height: 6rpx;
  background: #16a65a;
  border-radius: 3rpx;
}

.header-info {
  flex: 1;
}

.class-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 8rpx;
}

.class-sub {
  font-size: 26rpx;
  color: #6b7280;
}

.overview-card {
  display: flex;
  margin-bottom: 22rpx;
  padding: 26rpx 12rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.overview-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 2rpx;
}

/* 当前任务：文档 */
.overview-icon.overview-task::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 30rpx;
  height: 36rpx;
  border: 4rpx solid #16a65a;
  border-radius: 5rpx;
}

.overview-icon.overview-task::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 54%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 4rpx;
  background: #16a65a;
  border-radius: 2rpx;
  box-shadow: 0 -10rpx 0 #16a65a;
}

/* 平均完成率：圆环 */
.overview-icon.overview-chart::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid #16a65a;
  border-radius: 50%;
}

.overview-icon.overview-chart::after {
  content: "";
  position: absolute;
  right: 6rpx;
  top: 6rpx;
  width: 14rpx;
  height: 14rpx;
  background: #16a65a;
  border-radius: 0 100% 0 0;
}

/* 待复核：感叹号 */
.overview-icon.overview-warning::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #f47c12;
  border-radius: 50%;
}

.overview-icon.overview-warning::after {
  content: "!";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 24rpx;
  font-weight: 800;
  color: #f47c12;
}

/* 未完成学生：时钟 */
.overview-icon.overview-pending::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid #ef4444;
  border-radius: 50%;
}

.overview-icon.overview-pending::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 12rpx;
  background: #ef4444;
  transform: translate(-50%, -90%);
  transform-origin: 50% 100%;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #101828;
}

.overview-value.green {
  color: #16a65a;
}

.overview-value.orange {
  color: #f47c12;
}

.overview-value.red {
  color: #ef4444;
}

.overview-label {
  font-size: 23rpx;
  color: #6b7280;
}

.section-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #101828;
}

.section-link {
  font-size: 25rpx;
  color: #16a65a;
  font-weight: 700;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.task-icon {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e3f6ea;
  flex-shrink: 0;
}

/* 默认/学习：文档 */
.task-icon.default::before,
.task-icon.study::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 26rpx;
  height: 30rpx;
  border: 4rpx solid #16a65a;
  border-radius: 4rpx;
}

.task-icon.default::after,
.task-icon.study::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 54%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 3rpx;
  background: #16a65a;
  box-shadow: 0 -8rpx 0 #16a65a;
}

/* 实践活动：旗帜 */
.task-icon.activity {
  background: #e3f0ff;
}

.task-icon.activity::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 14rpx;
  width: 4rpx;
  height: 34rpx;
  background: #2f7ee6;
  border-radius: 2rpx;
}

.task-icon.activity::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 14rpx;
  width: 22rpx;
  height: 16rpx;
  background: #2f7ee6;
  border-radius: 0 4rpx 4rpx 0;
}

/* 志愿服务/心得：心形简化 */
.task-icon.volunteer,
.task-icon.reflection {
  background: #fef3c7;
}

.task-icon.volunteer::before,
.task-icon.reflection::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 56%;
  width: 14rpx;
  height: 14rpx;
  background: #f59e0b;
  transform: translate(-50%, -50%) rotate(45deg);
}

.task-icon.volunteer::after,
.task-icon.reflection::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 56%;
  width: 14rpx;
  height: 14rpx;
  background: #f59e0b;
  border-radius: 50%;
  transform: translate(-100%, -85%);
  box-shadow: 14rpx 0 0 #f59e0b;
}

/* 打卡：对勾 */
.task-icon.checkin {
  background: #e3f6ea;
}

.task-icon.checkin::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 20rpx;
  border-right: 5rpx solid #16a65a;
  border-bottom: 5rpx solid #16a65a;
  transform: translate(-70%, -60%) rotate(45deg);
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #101828;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.task-meta {
  font-size: 23rpx;
  color: #9ca3af;
}

.task-rate-wrap {
  width: 140rpx;
  flex-shrink: 0;
  text-align: right;
}

.task-rate {
  font-size: 26rpx;
  font-weight: 800;
  color: #16a65a;
  margin-bottom: 8rpx;
}

.task-bar-wrap {
  height: 10rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  overflow: hidden;
}

.task-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f9d52, #4ade80);
}

.task-review {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 100rpx;
  background: #fef3c7;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 700;
}

.task-arrow {
  flex-shrink: 0;
  color: #9ca3af;
  font-size: 32rpx;
  margin-left: 8rpx;
}

.empty-section {
  margin-bottom: 22rpx;
  padding: 60rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 27rpx;
  background: #fff;
  border-radius: 22rpx;
}

.member-card {
  padding-bottom: 20rpx;
}

.member-tab-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.member-tab {
  padding: 10rpx 22rpx;
  border-radius: 100rpx;
  font-size: 25rpx;
  color: #6b7280;
  background: #f3f4f6;
  font-weight: 600;
}

.member-tab.active {
  color: #fff;
  background: #16a65a;
  font-weight: 800;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: #f9fafb;
  border-radius: 14rpx;
}

.member-info {
  width: 180rpx;
  flex-shrink: 0;
}

.member-name {
  font-size: 27rpx;
  font-weight: 700;
  color: #101828;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-id {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.member-progress {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-bar-wrap {
  flex: 1;
  height: 10rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  overflow: hidden;
}

.member-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f9d52, #4ade80);
}

.member-rate {
  width: 80rpx;
  text-align: right;
  font-size: 24rpx;
  color: #6b7280;
}

.member-status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.member-status.done {
  color: #047857;
  background: #d1fae5;
}

.member-status.review {
  color: #b45309;
  background: #fef3c7;
}

.member-status.incomplete {
  color: #dc2626;
  background: #fee2e2;
}

.member-arrow {
  flex-shrink: 0;
  color: #9ca3af;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  padding: 50rpx 0;
  color: #9ca3af;
  font-size: 27rpx;
}

.loading-state {
  padding: 120rpx 48rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.error-state {
  padding: 100rpx 48rpx;
  text-align: center;
}

.error-text {
  font-size: 28rpx;
  color: #ef4444;
  margin-bottom: 28rpx;
}

.retry-btn {
  display: inline-block;
  background: #fff;
  color: #15904b;
  font-size: 28rpx;
  font-weight: 800;
  padding: 16rpx 48rpx;
  border-radius: 100rpx;
  border: 1rpx solid #22a35a;
}

.retry-btn::after {
  border: none;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
  z-index: 20;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  border: none;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.action-btn.secondary {
  color: #16a65a;
  background: #fff;
  border: 2rpx solid #16a65a;
}

.action-btn.primary {
  color: #fff;
  background: linear-gradient(90deg, #1f9d52, #249b55);
  box-shadow: 0 8rpx 20rpx rgba(34, 163, 90, 0.28);
}

.action-btn.full {
  flex: 1;
  width: 100%;
}
