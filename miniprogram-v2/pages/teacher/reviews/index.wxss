.teacher-reviews-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f6faf8 44%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 24rpx 24rpx;
}

.back-button,
.top-placeholder {
  width: 84rpx;
}

.back-button {
  display: flex;
  align-items: center;
  height: 56rpx;
}

.back-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.content {
  padding: 0 30rpx;
}

.header {
  margin-bottom: 28rpx;
}

.header-title {
  color: #16a65a;
  font-size: 40rpx;
  font-weight: 800;
}

.header-subtitle {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
}

.error-tip {
  margin-bottom: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
  font-size: 27rpx;
}

.filter-hint {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  background: #e3f6ea;
  font-size: 25rpx;
}

.filter-label {
  color: #6b7280;
  flex-shrink: 0;
}

.filter-name {
  flex: 1;
  min-width: 0;
  color: #101828;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-clear {
  margin-left: 16rpx;
  color: #16a65a;
  font-weight: 700;
  flex-shrink: 0;
}

.review-list {
  padding-bottom: 24rpx;
}

.review-card {
  margin-bottom: 22rpx;
  padding: 26rpx 26rpx 24rpx;
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.review-card:active {
  opacity: 0.96;
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.student-name {
  flex: 1;
  padding-right: 16rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.class-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #16a65a;
  background: #e3f6ea;
  font-size: 22rpx;
  font-weight: 700;
}

.task-title {
  margin-bottom: 14rpx;
  color: #374151;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.reflection {
  margin-bottom: 20rpx;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.review-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reason-tag {
  display: flex;
  align-items: center;
  color: #f59e0b;
  font-size: 24rpx;
  font-weight: 700;
}

.reason-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #f59e0b;
}

.submit-time {
  color: #9ca3af;
  font-size: 22rpx;
}

.load-more {
  padding: 30rpx 0;
  color: #9ca3af;
  text-align: center;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #667085;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  border: 6rpx solid #e5e7eb;
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
}

.empty-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 38rpx;
  width: 34rpx;
  height: 24rpx;
  border: 5rpx solid #d1d5db;
  border-top: 0;
  border-radius: 0 0 16rpx 16rpx;
  transform: translateX(-50%);
  box-sizing: border-box;
}

.empty-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 70rpx;
  width: 6rpx;
  height: 22rpx;
  background: #d1d5db;
  transform: translateX(-50%);
}

.empty-title {
  margin-bottom: 12rpx;
  color: #374151;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-subtitle {
  color: #9ca3af;
  font-size: 26rpx;
}
