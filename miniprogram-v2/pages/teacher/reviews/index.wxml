<view class="teacher-reviews-page">
  <view class="topbar">
    <view class="back-button" bindtap="onBackTap">
      <view class="back-icon"></view>
    </view>
    <view class="top-title">人工复核</view>
    <view class="top-placeholder"></view>
  </view>

  <view class="content">
    <view class="header">
      <view class="header-title">待复核心得</view>
      <view class="header-subtitle">仅展示您所带班级的待复核打卡</view>
    </view>

    <view class="filter-hint" wx:if="{{filterTaskId && filterTaskTitle}}">
      <text class="filter-label">任务筛选：</text>
      <text class="filter-name">{{filterTaskTitle}}</text>
      <text class="filter-clear" bindtap="onClearTaskFilter">清除</text>
    </view>

    <view class="error-tip" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <view class="review-list" wx:if="{{items.length > 0}}">
      <view
        class="review-card"
        wx:for="{{items}}"
        wx:key="check_in_id"
        data-id="{{item.check_in_id}}"
        bindtap="onItemTap"
      >
        <view class="review-header">
          <view class="student-name">{{displayStudent(item)}}</view>
          <view class="class-tag">{{item.class_name}}</view>
        </view>
        <view class="task-title">{{item.task_title}}</view>
        <view class="reflection">{{item.reflection_content || '（未填写心得）'}}</view>
        <view class="review-footer">
          <view class="reason-tag">
            <view class="reason-dot"></view>
            <text>{{formatReason(item)}}</text>
          </view>
          <view class="submit-time">{{formatTime(item.submitted_at)}}</view>
        </view>
      </view>

      <view class="load-more" wx:if="{{loading}}">加载中…</view>
      <view class="load-more" wx:if="{{!loading && !hasMore && items.length > 0}}">没有更多了</view>
    </view>

    <view class="empty-state" wx:if="{{!loading && items.length === 0}}">
      <view class="empty-icon"></view>
      <view class="empty-title">暂无待复核心得</view>
      <view class="empty-subtitle">当前没有 AI 初审未通过的学生打卡</view>
    </view>
  </view>
</view>
