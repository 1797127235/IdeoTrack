<view class="teacher-review-detail-page">
  <view class="topbar">
    <view class="back-button" bindtap="onBackTap">
      <view class="back-icon"></view>
    </view>
    <view class="top-title">复核详情</view>
    <view class="top-placeholder"></view>
  </view>

  <view class="content">
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中…</text>
    </view>

    <view class="error-tip" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <block wx:if="{{item && !loading}}">
      <view class="card info-card">
        <view class="info-row">
          <view class="info-label">学生</view>
          <view class="info-value">{{displayStudent(item)}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">班级</view>
          <view class="info-value">{{item.class_name}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">任务</view>
          <view class="info-value">{{item.task_title}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">提交时间</view>
          <view class="info-value text-secondary">{{formatTime(item.submitted_at)}}</view>
        </view>
      </view>

      <view class="card" wx:if="{{item.task_content}}">
        <view class="section-title">任务内容</view>
        <view class="task-content">{{item.task_content}}</view>
      </view>

      <view class="card">
        <view class="section-title">心得内容</view>
        <view class="reflection-content">{{item.reflection_content || '（未填写心得）'}}</view>
      </view>

      <view class="card reason-card">
        <view class="section-title">AI 初审结果</view>
        <view class="reason-text">{{formatReason()}}</view>
      </view>

      <view class="card action-card">
        <view class="section-title">复核决策</view>
        <view class="decision-options">
          <view
            class="option {{decision === 'approve' ? 'active approve' : ''}}"
            data-decision="approve"
            bindtap="chooseDecision"
          >通过</view>
          <view
            class="option {{decision === 'reject' ? 'active reject' : ''}}"
            data-decision="reject"
            bindtap="chooseDecision"
          >不通过</view>
          <view
            class="option {{decision === 'require_modification' ? 'active modify' : ''}}"
            data-decision="require_modification"
            bindtap="chooseDecision"
          >要求修改</view>
        </view>

        <view class="feedback-section" wx:if="{{showFeedback}}">
          <view class="feedback-label">
            {{decision === 'require_modification' ? '修改说明（必填）' : '不通过原因（选填）'}}
          </view>
          <textarea
            class="feedback-input"
            placeholder="{{decision === 'require_modification' ? '请说明需要学生补充或修改的内容' : '可填写不通过原因，学生将在结果中查看'}}"
            maxlength="500"
            bindinput="onFeedbackInput"
            value="{{feedback}}"
          />
        </view>

        <button
          class="submit-btn {{submitting || !decision ? 'disabled' : ''}}"
          disabled="{{submitting || !decision}}"
          bindtap="submit"
        >{{submitting ? '提交中…' : '确认复核'}}</button>
      </view>
    </block>
  </view>
</view>
