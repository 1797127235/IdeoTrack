.teacher-review-detail-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f6faf8 44%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 24rpx 24rpx;
}

.back-button,
.top-placeholder {
  width: 84rpx;
}

.back-button {
  display: flex;
  align-items: center;
  height: 56rpx;
}

.back-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.content {
  padding: 0 30rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #667085;
  font-size: 28rpx;
}

.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 18rpx;
  border: 5rpx solid #e5e7eb;
  border-top-color: #16a65a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.error-tip {
  margin-bottom: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
  font-size: 27rpx;
}

.card {
  margin-bottom: 22rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.07);
}

.info-card {
  padding-bottom: 18rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf1ee;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  color: #667085;
  font-size: 27rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  margin-left: 24rpx;
  color: #101828;
  font-size: 27rpx;
  font-weight: 600;
  text-align: right;
  word-break: break-all;
}

.info-value.text-secondary {
  color: #6b7280;
  font-weight: 500;
}

.section-title {
  margin-bottom: 20rpx;
  color: #16a65a;
  font-size: 30rpx;
  font-weight: 800;
}

.task-content,
.reflection-content {
  color: #374151;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

.reason-card {
  border-left: 8rpx solid #f59e0b;
}

.reason-text {
  color: #f59e0b;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.5;
}

.action-card {
  margin-top: 8rpx;
}

.decision-options {
  display: flex;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
  color: #6b7280;
  background: #f9fafb;
  font-size: 27rpx;
  font-weight: 700;
}

.option.active {
  color: #fff;
  border-color: transparent;
}

.option.active.approve {
  background: linear-gradient(135deg, #24c66a 0%, #16a65a 100%);
}

.option.active.reject {
  background: #ef4444;
}

.option.active.modify {
  background: #f59e0b;
}

.feedback-section {
  margin-bottom: 28rpx;
}

.feedback-label {
  margin-bottom: 14rpx;
  color: #374151;
  font-size: 27rpx;
  font-weight: 700;
}

.feedback-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  background: #f9fafb;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 18rpx;
  color: #fff;
  background: linear-gradient(135deg, #24c66a 0%, #16a65a 100%);
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(22, 166, 90, 0.22);
}

.submit-btn::after {
  border: 0;
}

.submit-btn[disabled],
.submit-btn.disabled {
  background: #d1d5db;
  color: #9ca3af;
  box-shadow: none;
}
