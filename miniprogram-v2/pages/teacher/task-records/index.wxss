.task-records-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fbfdfc 0%, #f6faf8 45%, #ffffff 100%);
  color: #101828;
  padding-bottom: calc(34rpx + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(44rpx + env(safe-area-inset-top)) 32rpx 28rpx;
}

.back-button,
.top-action {
  width: 92rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
}

.back-button {
  justify-content: flex-start;
}

.top-action {
  justify-content: flex-end;
  color: #16a65a;
  font-size: 28rpx;
  font-weight: 800;
}

.back-icon {
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  transform: rotate(45deg);
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.content {
  padding: 0 30rpx;
}

.summary-card {
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #20b965 0%, #13964d 100%);
  box-shadow: 0 14rpx 30rpx rgba(19, 150, 77, 0.2);
  color: #fff;
}

.summary-title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.summary-grid {
  display: flex;
  align-items: stretch;
  min-height: 104rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.13);
}

.summary-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.summary-value {
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 900;
}

.summary-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 22rpx;
  font-weight: 600;
}

.summary-divider {
  width: 1rpx;
  margin: 22rpx 0;
  background: rgba(255, 255, 255, 0.35);
}

.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.filter-item {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 14rpx;
  color: #4b5563;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(214, 226, 220, 0.78);
  font-size: 25rpx;
  font-weight: 700;
}

.filter-item.active {
  color: #16a65a;
  background: #e3f6ea;
  border-color: #b9e8cd;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #667085;
  font-size: 26rpx;
}

.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 18rpx;
  border: 5rpx solid #e5e7eb;
  border-top-color: #16a65a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 34rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(16, 45, 29, 0.06);
}

.empty-icon {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background: #e3f6ea;
}

.empty-icon::before {
  content: "";
  position: absolute;
  left: 29rpx;
  top: 24rpx;
  width: 38rpx;
  height: 48rpx;
  border: 5rpx solid #16a65a;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.empty-icon::after {
  content: "";
  position: absolute;
  left: 42rpx;
  top: 42rpx;
  width: 14rpx;
  height: 5rpx;
  background: #16a65a;
  box-shadow: 0 13rpx 0 #16a65a;
}

.empty-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
}

.empty-button {
  margin-top: 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 34rpx;
  border-radius: 14rpx;
  color: #fff;
  background: #16a65a;
  font-size: 26rpx;
  font-weight: 800;
}

.record-list {
  padding-bottom: 20rpx;
}

.record-card {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(214, 226, 220, 0.86);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12rpx 30rpx rgba(16, 45, 29, 0.08);
}

.record-head {
  display: flex;
  align-items: flex-start;
}

.record-icon-wrap {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  margin-right: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.record-icon-wrap.study {
  background: #ddf5e6;
}

.record-icon-wrap.checkin {
  background: #e3f0ff;
}

.record-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.record-icon.study {
  width: 44rpx;
  height: 36rpx;
  border: 5rpx solid #19a75a;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.record-icon.study::before {
  content: "";
  position: absolute;
  left: -8rpx;
  top: -8rpx;
  width: 18rpx;
  height: 15rpx;
  border: 4rpx solid #19a75a;
  border-bottom: 0;
  border-radius: 8rpx 8rpx 0 0;
  box-sizing: border-box;
}

.record-icon.checkin {
  width: 42rpx;
  height: 48rpx;
  border: 5rpx solid #2f7ee6;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.record-icon.checkin::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 16rpx;
  width: 18rpx;
  height: 9rpx;
  border-left: 4rpx solid #2f7ee6;
  border-bottom: 4rpx solid #2f7ee6;
  transform: rotate(-45deg);
  box-sizing: border-box;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.record-title {
  flex: 1;
  min-width: 0;
  color: #101828;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
}

.status-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-tag.ongoing {
  color: #15904b;
  background: #e3f6ea;
}

.status-tag.ended {
  color: #667085;
  background: #f3f4f6;
}

.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.category-tag,
.review-tag {
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.category-tag.study {
  color: #15904b;
  background: #e3f6ea;
}

.category-tag.checkin {
  color: #2f7ee6;
  background: #e3f0ff;
}

.review-tag {
  color: #c56a09;
  background: #fff2d6;
}

.record-info {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f8faf9;
}

.info-row {
  display: flex;
  align-items: flex-start;
  color: #4b5563;
  font-size: 25rpx;
  line-height: 1.4;
}

.info-row + .info-row {
  margin-top: 12rpx;
}

.people-icon,
.calendar-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  margin: 3rpx 12rpx 0 0;
  flex-shrink: 0;
  color: #667085;
}

.people-icon::before,
.people-icon::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: currentColor;
}

.people-icon::before {
  left: 9rpx;
  top: 2rpx;
  width: 10rpx;
  height: 10rpx;
}

.people-icon::after {
  left: 3rpx;
  bottom: 2rpx;
  width: 22rpx;
  height: 11rpx;
  border-radius: 11rpx 11rpx 3rpx 3rpx;
}

.calendar-icon {
  border: 3rpx solid currentColor;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.calendar-icon::before {
  content: "";
  position: absolute;
  left: -3rpx;
  right: -3rpx;
  top: 6rpx;
  height: 3rpx;
  background: currentColor;
}

.progress-block {
  margin-top: 22rpx;
}

.progress-head,
.progress-foot,
.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.progress-title {
  color: #101828;
  font-size: 26rpx;
  font-weight: 800;
}

.progress-number {
  color: #16a65a;
  font-size: 30rpx;
  font-weight: 900;
}

.progress-track {
  overflow: hidden;
  height: 14rpx;
  margin: 16rpx 0 12rpx;
  border-radius: 999rpx;
  background: #e6e7e8;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #18a85a 0%, #24c66a 100%);
}

.progress-foot {
  color: #667085;
  font-size: 23rpx;
}

.record-footer {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #edf1ee;
}

.published-text {
  color: #667085;
  font-size: 23rpx;
}

.review-button {
  flex-shrink: 0;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  color: #fff;
  background: #f59e0b;
  font-size: 24rpx;
  font-weight: 800;
}

@media (max-width: 360px) {
  .summary-grid {
    flex-wrap: wrap;
  }

  .summary-item {
    flex-basis: 48%;
    min-height: 92rpx;
  }

  .summary-divider {
    display: none;
  }

  .record-title-row,
  .record-footer,
  .progress-foot {
    align-items: flex-start;
    flex-direction: column;
  }
}
