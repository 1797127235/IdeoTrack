<view class="login-page">
  <image class="login-bg" src="/assets/images/login-bg.jpg" mode="aspectFill" />

  <view class="login-card">
    <view class="login-input-group">
      <image class="input-icon" src="data:image/svg+xml;base64," mode="aspectFit" />
      <input
        class="login-input"
        type="text"
        placeholder="请输入账号"
        value="{{account}}"
        bindinput="onAccountInput"
      />
    </view>

    <view class="login-input-group">
      <image class="input-icon" src="data:image/svg+xml;base64," mode="aspectFit" />
      <input
        class="login-input"
        type="text"
        password="{{!showPassword}}"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <view
        class="eye-icon {{showPassword ? 'open' : 'close'}}"
        bindtap="onTogglePassword"
      ></view>
    </view>

    <button class="login-btn" bindtap="onLogin">登录</button>

    <view class="login-options">
      <text class="forgot-link" bindtap="onForgot">忘记密码？</text>
    </view>

    <view class="agreement-row" bindtap="onToggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <view class="checkbox-inner" wx:if="{{agreed}}"></view>
      </view>
      <view class="agreement-content">
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" catchtap="onUserAgreement">《用户协议》</text>
        <text class="agreement-text">与</text>
        <text class="agreement-link" catchtap="onPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>
  </view>
</view>
