<view class="container">
  <view class="header">
    <text class="title">派发任务</text>
    <text class="subtitle">从任务池选择任务派发给班级</text>
  </view>

  <!-- 任务池列表 -->
  <view class="section">
    <text class="section-title">选择任务</text>
    <view class="task-list" wx:if="{{taskPool.length > 0}}">
      <view
        class="task-item {{selectedTask.id === item.id ? 'selected' : ''}}"
        wx:for="{{taskPool}}"
        wx:key="id"
        bindtap="selectTask"
        data-id="{{item.id}}"
      >
        <view class="task-info">
          <text class="task-title">{{item.title}}</text>
          <text class="task-date">截止 {{item.deadlineText}}</text>
        </view>
        <view class="task-check" wx:if="{{selectedTask.id === item.id}}">
          <text class="check-icon">✓</text>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text class="empty-text">暂无可派发的任务</text>
    </view>
  </view>

  <!-- 选中任务详情 -->
  <view class="section" wx:if="{{selectedTask}}">
    <text class="section-title">任务详情</text>
    <view class="task-detail">
      <text class="detail-title">{{selectedTask.title}}</text>
      <text class="detail-content">{{selectedTask.content}}</text>

      <view class="detail-row">
        <text class="detail-label">截止时间：</text>
        <text class="detail-value">{{selectedTask.deadlineText}}</text>
      </view>

      <!-- 思考题 -->
      <view class="detail-questions" wx:if="{{selectedTask.guiding_questions && selectedTask.guiding_questions.length > 0}}">
        <text class="questions-title">思考题：</text>
        <text class="question-item" wx:for="{{selectedTask.guiding_questions}}" wx:key="*this">
          {{index + 1}}. {{item}}
        </text>
      </view>

      <!-- 链接 -->
      <view class="detail-links" wx:if="{{selectedTask.source_url || selectedTask.video_url}}">
        <text class="link-item" wx:if="{{selectedTask.source_url}}">
          外部链接: {{selectedTask.source_url}}
        </text>
        <text class="link-item" wx:if="{{selectedTask.video_url}}">
          视频链接: {{selectedTask.video_url}}
        </text>
      </view>
    </view>
  </view>

  <!-- 班级选择 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">选择班级</text>
      <text class="select-all" bindtap="toggleSelectAll">{{allSelected ? '取消全选' : '全选'}}</text>
    </view>
    <view class="class-list" wx:if="{{classes.length > 0}}">
      <view
        class="class-item {{item.selected ? 'selected' : ''}}"
        wx:for="{{classes}}"
        wx:key="class_id"
        bindtap="toggleClass"
        data-idx="{{index}}"
      >
        <view class="class-info">
          <text class="class-name">{{item.class_name}}</text>
          <text class="class-meta">{{item.college_name}}</text>
        </view>
        <view class="class-check" wx:if="{{item.selected}}">
          <text class="check-icon">✓</text>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text class="empty-text">暂无所辖班级</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="submit-btn"
      bindtap="submitDispatch"
      disabled="{{submitting || !selectedTask || selectedCount === 0}}"
    >
      {{submitting ? '派发中...' : '确认派发'}}
    </button>
  </view>
</view>
