<view class="container">
  <view class="header">
    <text class="title">发布任务</text>
    <text class="subtitle">从模板库选择并发布到班级</text>
  </view>

  <!-- 模板库列表 -->
  <view class="section">
    <text class="section-title">选择模板</text>
    <view class="task-list" wx:if="{{templates.length > 0}}">
      <view
        class="task-item {{selectedTemplate.id === item.id ? 'selected' : ''}}"
        wx:for="{{templates}}"
        wx:key="id"
        bindtap="selectTemplate"
        data-id="{{item.id}}"
      >
        <view class="task-info">
          <text class="task-title">{{item.title}}</text>
          <text class="task-date">更新于 {{item.deadlineText}}</text>
        </view>
        <view class="task-check" wx:if="{{selectedTemplate.id === item.id}}">
          <text class="check-icon">✓</text>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text class="empty-text">暂无可发布的模板</text>
    </view>
  </view>

  <!-- 班级选择 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">选择班级</text>
      <text class="select-all" bindtap="toggleSelectAll">{{allSelected ? '取消全选' : '全选'}}</text>
    </view>
    <view class="class-list" wx:if="{{classes.length > 0}}">
      <view
        class="class-item {{item.selected ? 'selected' : ''}}"
        wx:for="{{classes}}"
        wx:key="class_id"
        bindtap="toggleClass"
        data-idx="{{index}}"
      >
        <view class="class-info">
          <text class="class-name">{{item.class_name}}</text>
          <text class="class-meta">{{item.college_name}}</text>
        </view>
        <view class="class-check" wx:if="{{item.selected}}">
          <text class="check-icon">✓</text>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text class="empty-text">暂无所辖班级</text>
    </view>
  </view>

  <!-- 发布时间 -->
  <view class="section">
    <text class="section-title">发布时间</text>
    <view class="form-row">
      <text class="form-label">开始时间</text>
      <input type="datetime-local" value="{{publishedAt}}" bindinput="onPublishedAtChange" class="date-input" />
    </view>
    <view class="form-row">
      <text class="form-label">截止时间</text>
      <input type="datetime-local" value="{{deadlineAt}}" bindinput="onDeadlineAtChange" class="date-input" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="submit-btn"
      bindtap="submitDispatch"
      disabled="{{submitting || !selectedTemplate || selectedCount === 0}}"
    >
      {{submitting ? '发布中...' : '确认发布'}}
    </button>
  </view>
</view>
