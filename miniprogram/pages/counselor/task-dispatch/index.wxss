.container {
  min-height: 100vh;
  background-color: #ECFEFF;
  padding: 24rpx;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #164E63;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #64748B;
  margin-top: 8rpx;
  display: block;
}

.section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #164E63;
}

.select-all {
  font-size: 26rpx;
  color: #0891B2;
}

.task-list,
.class-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.task-item,
.class-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
}

.task-item.selected,
.class-item.selected {
  border-color: #0891B2;
  background-color: #F0FDFF;
}

.task-info,
.class-info {
  flex: 1;
  min-width: 0;
}

.task-title,
.class-name {
  font-size: 28rpx;
  color: #164E63;
  display: block;
}

.task-date,
.class-meta {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 4rpx;
  display: block;
}

.task-check,
.class-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #0891B2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
}

.empty {
  padding: 32rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
}

.submit-section {
  margin-top: 32rpx;
  padding-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background-color: #22C55E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn[disabled] {
  background-color: #94A3B8;
  color: #FFFFFF;
}

.submit-btn:not([disabled]):active {
  background-color: #16A34A;
}
