.container {
  min-height: 100vh;
  background-color: #ECFEFF;
  padding: 24rpx;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #164E63;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #64748B;
  margin-top: 8rpx;
  display: block;
}

.section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #164E63;
  margin-bottom: 16rpx;
  display: block;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
}

.task-item.selected {
  border-color: #0891B2;
  background-color: #F0FDFF;
}

.task-info {
  flex: 1;
}

.task-title {
  font-size: 28rpx;
  color: #164E63;
  display: block;
}

.task-date {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 4rpx;
  display: block;
}

.task-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #0891B2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
}

.empty {
  padding: 32rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
}

.task-detail {
  padding: 16rpx;
  background-color: #F0FDFF;
  border-radius: 12rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #164E63;
  display: block;
  margin-bottom: 12rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #164E63;
  display: block;
  margin-bottom: 16rpx;
}

.detail-questions {
  margin-top: 16rpx;
}

.questions-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #164E63;
  display: block;
  margin-bottom: 8rpx;
}

.question-item {
  font-size: 26rpx;
  color: #64748B;
  display: block;
  margin-bottom: 4rpx;
}

.detail-links {
  margin-top: 16rpx;
}

.link-item {
  font-size: 24rpx;
  color: #0891B2;
  display: block;
  margin-bottom: 4rpx;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #164E63;
}

.picker-arrow {
  font-size: 24rpx;
  color: #64748B;
}

.deadline-row {
  display: flex;
  gap: 16rpx;
}

.deadline-row .picker {
  flex: 1;
}

.submit-section {
  margin-top: 32rpx;
  padding-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background-color: #22C55E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn[disabled] {
  background-color: #94A3B8;
  color: #FFFFFF;
}

.submit-btn:not([disabled]):active {
  background-color: #16A34A;
}
