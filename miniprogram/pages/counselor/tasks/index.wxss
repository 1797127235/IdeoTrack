.page {
  min-height: 100vh;
  background: var(--color-background, #ECFEFF);
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.container {
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #164E63);
}

.section-count {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
}

.task-list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.06);
}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid var(--color-divider, #F1F5F9);
}

.task-card:last-child {
  border-bottom: none;
}

.task-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary, #164E63);
}

.task-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
  margin-top: 6rpx;
}

.dispatch-btn {
  background: var(--color-cta, #22C55E);
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

.task-status {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}

.task-status.published {
  background: rgba(34, 197, 94, 0.12);
  color: var(--color-cta, #22C55E);
}

.task-status.delisted {
  background: rgba(148, 163, 184, 0.12);
  color: var(--color-text-disabled, #94A3B8);
}

.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  color: var(--color-text-secondary, #64748B);
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
}
