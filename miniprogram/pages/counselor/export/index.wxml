<view class="page">
  <!-- 错误提示 -->
  <view class="error-tip" wx:if="{{errorMsg}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{errorMsg}}</text>
  </view>

  <!-- 班级选择 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">选择班级</text>
      <text class="select-all" bindtap="onSelectAll">{{allSelected ? '取消全选' : '全选'}}</text>
    </view>
    <view class="class-list">
      <view
        class="class-item {{item.selected ? 'selected' : ''}}"
        wx:for="{{classes}}"
        wx:key="class_id"
        data-idx="{{index}}"
        bindtap="onToggleClass"
      >
        <view class="checkbox {{item.selected ? 'checked' : ''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
        <text class="class-name">{{item.class_name}}</text>
        <text class="college-name">{{item.college_name}}</text>
      </view>
      <view class="empty" wx:if="{{classes.length === 0 && !errorMsg}}">
        <text>暂无可导出的班级</text>
      </view>
    </view>
  </view>

  <!-- 日期范围 -->
  <view class="section">
    <text class="section-title">日期范围</text>
    <view class="date-row">
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="date-picker">
          <text class="date-label">开始</text>
          <text class="date-value">{{startDate}}</text>
        </view>
      </picker>
      <text class="date-sep">至</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="date-picker">
          <text class="date-label">结束</text>
          <text class="date-value">{{endDate}}</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 导出按钮 -->
  <view class="action-bar">
    <button
      class="btn-export {{loading ? 'disabled' : ''}}"
      bindtap="onExport"
      disabled="{{loading}}"
    >
      {{loading ? '导出中...' : '导出 Excel'}}
    </button>
  </view>

  <!-- 导出结果 -->
  <view class="result-card" wx:if="{{result}}">
    <view class="result-header">
      <text class="result-icon">✅</text>
      <text class="result-title">导出成功</text>
    </view>
    <view class="result-info">
      <text class="result-label">链接有效期至：</text>
      <text class="result-value">{{result.expires_at}}</text>
    </view>
    <button class="btn-copy" bindtap="onCopyLink">复制下载链接</button>
    <text class="result-hint">复制链接后在浏览器中打开下载</text>
  </view>
</view>
