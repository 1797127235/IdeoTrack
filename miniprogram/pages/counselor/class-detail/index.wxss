.detail-container {
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: var(--space-4);
}

.class-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-1);
}

.date-picker {
  display: inline-flex;
  align-items: center;
  padding: var(--space-1) var(--space-2);
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
}

.date-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: var(--space-1);
}

.date-icon {
  font-size: 22rpx;
  color: var(--color-primary);
}

.filter-bar {
  display: flex;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-1);
  margin-bottom: var(--space-3);
}

.filter-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: var(--space-2) 0;
  border-radius: var(--radius-md);
  transition: all 0.15s ease;
}

.filter-tab.active {
  background-color: rgba(8, 145, 178, 0.1);
  color: var(--color-primary);
  font-weight: 600;
}

.mini-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: var(--space-4);
}

.mini-stat {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.error-tip {
  background-color: rgba(239, 68, 68, 0.08);
  color: var(--color-error);
  font-size: 26rpx;
  padding: var(--space-3);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-3);
}

.student-card {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: 0 2rpx 12rpx rgba(8, 145, 178, 0.06);
  border-left: 8rpx solid var(--color-error);
}

.student-card.checked-in {
  border-left-color: var(--color-success);
}

.student-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.student-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.student-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.student-school-id {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.student-id {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.status-badge.success {
  color: var(--color-success);
  background-color: rgba(34, 197, 94, 0.1);
}

.status-badge.error {
  color: var(--color-error);
  background-color: rgba(239, 68, 68, 0.1);
}

.student-card.high-risk {
  border-left-color: #dc2626;
  background-color: rgba(220, 38, 38, 0.04);
}

.warning-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background-color: #dc2626;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  margin-top: var(--space-2);
}

.student-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-2);
}

.reflection {
  font-size: 26rpx;
  color: var(--color-text);
  background-color: var(--color-surface-raised);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  line-height: 1.6;
}

.empty-state {
  padding: var(--space-8) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.skeleton-list {
  margin-bottom: var(--space-4);
}

.student-skeleton {
  height: 160rpx;
  margin-bottom: var(--space-3);
}

.skeleton {
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-lg);
  animation: shimmer 1.2s infinite;
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.selection-toolbar {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
  font-size: 26rpx;
}

.selection-text {
  color: var(--color-primary);
  padding: var(--space-2);
}

.selection-divider {
  color: var(--color-divider);
  margin: 0 var(--space-1);
}

.selection-count {
  margin-left: auto;
  color: var(--color-text-secondary);
}

.student-checkbox {
  margin-right: var(--space-2);
  margin-left: calc(-1 * var(--space-2));
  min-width: 96rpx;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-badge.reminded {
  color: var(--color-primary);
  background-color: rgba(8, 145, 178, 0.1);
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-3) var(--space-4);
  padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  transform: translateY(100%);
  transition: transform 0.2s ease;
  z-index: 100;
}

.action-bar.active {
  transform: translateY(0);
}

.action-info {
  font-size: 28rpx;
  color: var(--color-text);
}

.action-count {
  color: var(--color-primary);
  font-weight: 700;
}

.action-btn {
  margin: 0;
  padding: var(--space-2) var(--space-5);
  font-size: 28rpx;
  line-height: 1.6;
  color: #fff;
  background-color: var(--color-primary);
  border-radius: var(--radius-full);
}

.action-btn[disabled] {
  background-color: var(--color-divider);
  color: var(--color-text-secondary);
}

.detail-container {
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom) + 120rpx);
}
