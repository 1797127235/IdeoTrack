.page {
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
}

.summary-bar {
  display: flex;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4) 0;
  margin-bottom: var(--space-4);
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.summary-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: var(--space-1);
}

.student-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.student-card {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: 0 2rpx 12rpx rgba(8, 145, 178, 0.06);
}

.student-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.student-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.student-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.student-school-id,
.student-class {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-badge {
  text-align: right;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-error);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.rate-bar-bg {
  height: 8rpx;
  background-color: var(--color-border);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.rate-bar-fill {
  height: 100%;
  background-color: var(--color-error);
  border-radius: var(--radius-full);
}

.empty-state {
  padding: var(--space-10) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-sub {
  font-size: 24rpx;
  margin-top: var(--space-2);
}

.error-tip {
  margin-top: var(--space-4);
  background-color: rgba(239, 68, 68, 0.08);
  color: var(--color-error);
  font-size: 26rpx;
  padding: var(--space-3);
  border-radius: var(--radius-md);
}

.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.student-skeleton {
  height: 180rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
