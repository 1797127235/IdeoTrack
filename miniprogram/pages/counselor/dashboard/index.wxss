.dashboard-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 32rpx 60rpx;
  color: #fff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting {
  font-size: 40rpx;
  font-weight: 600;
}

.date-text {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 12rpx;
}

.export-btn {
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 30rpx;
  padding: 12rpx 26rpx;
  font-size: 26rpx;
}

.error-tip {
  margin: 20rpx 32rpx;
  padding: 20rpx;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
  color: #cf1322;
  font-size: 28rpx;
}

.task-card {
  background: #fff;
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.task-deadline {
  font-size: 24rpx;
  color: #8c8c8c;
}

.class-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.class-row:last-child {
  border-bottom: none;
}

.class-info {
  flex: 1;
  min-width: 0;
}

.class-name {
  font-size: 30rpx;
  color: #262626;
}

.class-meta {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.class-stats {
  display: flex;
  align-items: center;
  width: 220rpx;
  margin-left: 20rpx;
}

.rate-bar-bg {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.rate-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #389e0d);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.rate-value {
  font-size: 26rpx;
  color: #262626;
  margin-left: 12rpx;
  min-width: 64rpx;
  text-align: right;
}

.card-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #8c8c8c;
  font-size: 30rpx;
}

.text-secondary {
  font-size: 26rpx;
  color: #bfbfbf;
  margin-top: 12rpx;
}

.skeleton-list {
  padding: 20rpx 32rpx;
}

.skeleton {
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 50%, #f2f2f2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 12rpx;
}

.class-skeleton {
  height: 180rpx;
  margin-bottom: 20rpx;
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
