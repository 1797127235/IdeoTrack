<view class="page">
  <view class="container">
    <view class="task-title">{{taskName}}</view>

    <view wx:if="{{errorMsg}}" class="error-tip">{{errorMsg}}</view>

    <view wx:if="{{loading && classes.length === 0}}" class="skeleton-list">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton class-skeleton"></view>
    </view>

    <view class="class-list" wx:if="{{classes.length > 0}}">
      <view
        wx:for="{{classes}}"
        wx:key="class_id"
        class="class-card"
        data-id="{{item.class_id}}"
        data-name="{{item.class_name}}"
        bindtap="goToClassDetail"
      >
        <view class="class-info">
          <view class="class-name">{{item.class_name}}</view>
          <view class="class-meta">{{item.college_name}}</view>
          <view class="class-count">{{item.checked_in_count}}/{{item.total_students}} 人已打卡</view>
        </view>
        <view class="class-rate">
          <view class="rate-value">{{item.check_in_rate}}%</view>
          <view class="rate-label">打卡率</view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:elif="{{!loading}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">暂无班级数据</view>
    </view>
  </view>
</view>
