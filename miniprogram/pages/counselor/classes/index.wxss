.page {
  min-height: 100vh;
  background: var(--color-background, #ECFEFF);
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.container {
  padding: 24rpx;
}

.task-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #164E63);
  margin-bottom: 24rpx;
}

.error-tip {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: rgba(239, 68, 68, 0.08);
  color: var(--color-error, #EF4444);
  border-radius: 16rpx;
  font-size: 28rpx;
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.class-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.06);
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #164E63);
}

.class-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
  margin-top: 4rpx;
}

.class-count {
  font-size: 24rpx;
  color: var(--color-text-secondary, #64748B);
  margin-top: 12rpx;
}

.class-rate {
  text-align: center;
}

.rate-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-cta, #22C55E);
  font-family: var(--font-numeric, 'Inter', sans-serif);
}

.rate-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--color-text-secondary, #64748B);
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
}

.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton {
  background: linear-gradient(90deg, var(--color-divider, #E5E7EB) 25%, #e8f4f8 50%, var(--color-divider, #E5E7EB) 75%);
  background-size: 200% 100%;
  border-radius: 24rpx;
  animation: shimmer 1.2s infinite;
}

.class-skeleton {
  height: 160rpx;
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
