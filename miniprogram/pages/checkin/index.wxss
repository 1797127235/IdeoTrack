page {
  height: 100%;
  background-color: #ECFEFF;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.location-card,
.tips-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.08);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 24rpx;
}

.location-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E2E8F0;
  border-top-color: #0891B2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #64748B;
}

.location-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: #EF4444;
  margin-bottom: 32rpx;
  text-align: center;
}

.error-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #0891B2;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  padding: 0 32rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.secondary {
  background-color: #F0FDFF;
  color: #0891B2;
}

.location-info {
  padding: 16rpx 0;
}

.location-address {
  display: block;
  font-size: 30rpx;
  color: #164E63;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.location-coords {
  display: block;
  font-size: 24rpx;
  color: #64748B;
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.8;
}

.footer {
  margin-top: auto;
  padding: 24rpx 0 24rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #22C55E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background-color: #E2E8F0;
  color: #94A3B8;
}

.submit-btn:not(.disabled):active {
  transform: scale(0.98);
}
