page {
  height: 100%;
  background-color: #ECFEFF;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.loading-wrap,
.error-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading {
  color: #64748B;
  font-size: 28rpx;
}

.error-text {
  color: #EF4444;
  font-size: 28rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.retry-btn {
  background-color: #0891B2;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
}

.task-bar {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.08);
}

.task-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.task-deadline {
  display: block;
  font-size: 24rpx;
  color: #64748B;
}

.location-card,
.tips-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.08);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 24rpx;
}

.location-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E2E8F0;
  border-top-color: #0891B2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #64748B;
}

.location-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #0891B2;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  padding: 0 32rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.secondary {
  background-color: #F0FDFF;
  color: #0891B2;
}

.location-info {
  padding: 16rpx 0;
}

.location-address {
  display: block;
  font-size: 30rpx;
  color: #164E63;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.location-coords {
  display: block;
  font-size: 24rpx;
  color: #64748B;
}

.location-coords {
  display: block;
  font-size: 24rpx;
  color: #64748B;
}

.geofence-hint {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  background-color: #F0FDFF;
  border: 2rpx solid #0891B2;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.geofence-hint.danger {
  background-color: #FEF2F2;
  border-color: #EF4444;
}

.hint-icon {
  font-size: 32rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #164E63;
  flex: 1;
}

.geofence-hint.danger .hint-text {
  color: #991B1B;
}

.hint-status {
  font-size: 24rpx;
  color: #EF4444;
}

.hint-status.success {
  color: #16A34A;
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.8;
}

.footer {
  margin-top: auto;
  padding: 24rpx 0 24rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #22C55E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background-color: #E2E8F0;
  color: #94A3B8;
}

.submit-btn:not(.disabled):active {
  transform: scale(0.98);
}

.photo-preview-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-preview {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  background-color: #F1F5F9;
}

.photo-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 16rpx;
  background-color: #0891B2;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.photo-btn::after {
  border: none;
}

.photo-btn:active {
  opacity: 0.85;
}
