<view class="container">
  <block wx:if="{{taskLoading}}">
    <view class="loading-wrap">
      <view class="loading">加载任务中...</view>
    </view>
  </block>

  <block wx:elif="{{taskError}}">
    <view class="error-wrap">
      <text class="error-text">{{taskError}}</text>
      <button class="retry-btn" bindtap="onRetryTask">重试</button>
    </view>
  </block>

  <block wx:else>
    <view class="task-bar" wx:if="{{task}}">
      <text class="task-title">{{task.title}}</text>
      <text class="task-deadline">{{deadlineText}}</text>
    </view>

    <view class="location-card">
      <text class="card-title">{{requireLocation ? '当前位置' : '签到方式'}}</text>

      <block wx:if="{{geofenceHint}}">
        <view class="geofence-hint {{requireLocation && outOfRange ? 'danger' : ''}}">
          <text class="hint-icon">{{requireLocation ? '📍' : '✅'}}</text>
          <text class="hint-text">{{geofenceHint}}</text>
          <text wx:if="{{requireLocation && outOfRange}}" class="hint-status">（当前不在范围内）</text>
          <text wx:elif="{{requireLocation && locationReady}}" class="hint-status success">（已在范围内）</text>
        </view>
      </block>

      <block wx:if="{{requireLocation && locationLoading}}">
        <view class="location-loading">
          <view class="spinner"></view>
          <text class="loading-text">正在获取定位...</text>
        </view>
      </block>

      <block wx:elif="{{requireLocation && locationError}}">
        <view class="location-error">
          <text class="error-icon">📍</text>
          <text class="error-text">{{locationError}}</text>
          <view class="error-actions">
            <button class="action-btn secondary" bindtap="onRetryLocation">重试定位</button>
            <button class="action-btn" open-type="openSetting" bindopensetting="onOpenSetting">去设置</button>
          </view>
        </view>
      </block>

      <block wx:elif="{{requireLocation}}">
        <view class="location-info">
          <text class="location-address">{{address}}</text>
          <text class="location-coords">纬度 {{latitude.toFixed(6)}} · 经度 {{longitude.toFixed(6)}}</text>
        </view>
      </block>
    </view>

    <view class="tips-card">
      <text class="tips-title">签到说明</text>
      <text class="tips-item" wx:if="{{requireLocation}}">1. 请确保在真实位置完成签到</text>
      <text class="tips-item" wx:else>1. 该任务无需定位，直接确认打卡即可</text>
      <text class="tips-item">2. 签到后请继续提交学习心得</text>
      <text class="tips-item">3. 同一任务多次签到以最后一次为准</text>
    </view>

    <view class="footer">
      <button
        class="submit-btn {{submitting || (requireLocation && (locationLoading || locationError || outOfRange)) || taskLoading ? 'disabled' : ''}}"
        disabled="{{submitting || (requireLocation && (locationLoading || locationError || outOfRange)) || taskLoading}}"
        bindtap="onSubmitCheckIn"
      >
        {{submitting ? '签到中...' : '确认签到'}}
      </button>
    </view>
  </block>
</view>
