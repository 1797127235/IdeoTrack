<view class="page">
  <view class="content">
    <block wx:if="{{role === 'student'}}">
      <view class="profile-card">
        <view class="profile-main">
          <view class="profile-avatar">
            <text class="avatar-text">{{profile.name ? profile.name[0] : '学'}}</text>
            <view class="level-badge">Lv.{{stats.level.level}}</view>
          </view>
          <view class="profile-info">
            <view class="profile-name">{{profile.name || '同学'}}</view>
            <view class="profile-meta">学号：{{profile.schoolId || '-'}}</view>
            <view class="profile-slogan">每一次努力，都是成长的足迹。</view>
          </view>
          <view class="profile-arrow">›</view>
        </view>
      </view>

      <view class="streak-card">
        <view class="streak-header">
          <view class="streak-main">
            <text class="streak-icon">打卡</text>
            <view class="streak-text">
              <view class="streak-title">连续打卡 <text class="streak-days">{{stats.currentStreak}}</text> 天</view>
              <view class="streak-desc">继续加油，养成学习好习惯！</view>
            </view>
          </view>
          <view class="streak-best">最佳 {{stats.maxStreak}} 天</view>
        </view>

        <view class="week-days">
          <view wx:for="{{stats.recent7Days}}" wx:key="date" class="week-day {{item.checkedIn ? 'checked' : ''}}">
            <view class="day-dot">
              <text wx:if="{{item.checkedIn}}" class="day-check">✓</text>
            </view>
            <text class="day-label">{{item.date.slice(8)}}</text>
          </view>
        </view>
      </view>

      <view class="badges-card">
        <view class="section-title">我的勋章</view>
        <view class="badges-list" wx:if="{{stats.badges.length > 0}}">
          <view wx:for="{{stats.badges}}" wx:key="id" class="badge-item {{item.earned ? '' : 'locked'}}">
            <text class="badge-icon">{{item.name[0]}}</text>
            <text class="badge-name">{{item.name}}</text>
          </view>
        </view>
        <view wx:else class="badges-empty">暂无勋章，快去打卡获得吧~</view>
      </view>
    </block>

    <block wx:elif="{{role === 'counselor' || role === 'admin'}}">
      <view class="profile-card counselor">
        <view class="profile-main">
          <view class="profile-avatar">
            <text class="avatar-text">{{profile.name ? profile.name[0] : '导'}}</text>
          </view>
          <view class="profile-info">
            <view class="profile-name">{{profile.name || '辅导员'}}</view>
            <view class="profile-meta">工号：{{profile.schoolId || '-'}}</view>
            <view class="profile-meta" wx:if="{{profile.collegeName}}">{{profile.collegeName}}</view>
          </view>
        </view>
        <view class="counselor-stat">
          <view class="stat-value-lg">{{profile.managedClassesCount}}</view>
          <view class="stat-label">管辖班级</view>
        </view>
      </view>

      <view class="menu-list">
        <view wx:if="{{showReviewEntry}}" class="menu-card" bindtap="goToReviews">
          <text class="menu-icon-text menu-icon-review">复</text>
          <view class="menu-content">
            <view class="menu-title">心得复核</view>
            <view class="menu-desc">查看待复核的学生心得并处理</view>
          </view>
          <view class="menu-arrow">›</view>
        </view>

        <view class="menu-card" bindtap="goToExport">
          <text class="menu-icon-text menu-icon-export">导</text>
          <view class="menu-content">
            <view class="menu-title">数据导出</view>
            <view class="menu-desc">导出 Excel 打卡报表</view>
          </view>
          <view class="menu-arrow">›</view>
        </view>
      </view>
    </block>

    <view class="menu-list">
      <view class="menu-card" bindtap="goToHelp">
        <view class="menu-icon-text menu-icon-help"></view>
        <view class="menu-content">
          <view class="menu-title">帮助与反馈</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-card" bindtap="goToAbout">
        <view class="menu-icon-text menu-icon-about"></view>
        <view class="menu-content">
          <view class="menu-title">关于我们</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-card" bindtap="goToSettings">
        <view class="menu-icon-text menu-icon-setting"></view>
        <view class="menu-content">
          <view class="menu-title">设置</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="logout-wrap">
      <button class="btn-logout" bindtap="handleLogout">
        退出登录
      </button>
    </view>
  </view>
</view>
