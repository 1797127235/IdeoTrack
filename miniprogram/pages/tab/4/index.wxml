<view class="page-placeholder">
  <!-- Student: keep placeholder -->
  <block wx:if="{{role === 'student'}}">
    <view class="card">
      <view class="title">我的</view>
      <view class="desc">积分 / 等级 / 勋章 / 个人信息将在这里展示</view>
      <view class="tag">待 Epic 6</view>
    </view>
  </block>

  <!-- Counselor / Admin: profile card + menu -->
  <block wx:elif="{{role === 'counselor' || role === 'admin'}}">
    <view class="counselor-card">
      <view class="counselor-main">
        <view class="counselor-avatar">{{profile.name ? profile.name[0] : '导'}}</view>
        <view class="counselor-info">
          <view class="counselor-name">{{profile.name || '辅导员'}}</view>
          <view class="counselor-meta" wx:if="{{profile.schoolId}}">工号 {{profile.schoolId}}</view>
          <view class="counselor-meta" wx:if="{{profile.collegeName}}">{{profile.collegeName}}</view>
        </view>
      </view>
      <view class="counselor-stat">
        <view class="stat-value">{{profile.managedClassesCount}}</view>
        <view class="stat-label">管辖班级</view>
      </view>
    </view>

    <view class="menu-list">
      <view wx:if="{{showReviewEntry}}" class="menu-card" bindtap="goToReviews">
        <view class="menu-icon menu-icon-review"></view>
        <view class="menu-content">
          <view class="menu-title">心得复核</view>
          <view class="menu-desc">查看待复核的学生心得并处理</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-card" bindtap="goToExport">
        <view class="menu-icon menu-icon-export"></view>
        <view class="menu-content">
          <view class="menu-title">数据导出</view>
          <view class="menu-desc">导出 Excel 打卡报表</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </block>

  <button class="btn-logout" bindtap="handleLogout">退出登录</button>
</view>
