.page {
  min-height: 100vh;
  background-color: #F8FAFC;
}

.content {
  padding: 32rpx 32rpx 48rpx;
}

/*  */
.profile-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.profile-card.counselor {
  background: linear-gradient(135deg, #0891B2 0%, #0E7490 100%);
  color: #FFFFFF;
}

.profile-main {
  display: flex;
  align-items: center;
}

.profile-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #22D3EE 0%, #0891B2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.profile-card.counselor .profile-avatar {
  background: rgba(255, 255, 255, 0.2);
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.level-badge {
  position: absolute;
  right: -8rpx;
  bottom: -4rpx;
  background-color: #F59E0B;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 2rpx solid #FFFFFF;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 8rpx;
}

.profile-card.counselor .profile-name {
  color: #FFFFFF;
}

.profile-meta {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 8rpx;
}

.profile-card.counselor .profile-meta {
  color: rgba(255, 255, 255, 0.9);
}

.profile-slogan {
  font-size: 24rpx;
  color: #94A3B8;
}

.profile-arrow {
  font-size: 48rpx;
  color: #CBD5E1;
  margin-left: 16rpx;
}

.counselor-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 32rpx;
  border-left: 1rpx solid rgba(255, 255, 255, 0.25);
  margin-left: 24rpx;
}

.stat-value-lg {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

/*  */
.streak-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.streak-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.streak-main {
  display: flex;
  align-items: center;
}

.streak-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.streak-title {
  font-size: 30rpx;
  color: #164E63;
  font-weight: 600;
}

.streak-days {
  font-size: 44rpx;
  font-weight: 700;
  color: #F59E0B;
}

.streak-desc {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.streak-best {
  font-size: 24rpx;
  color: #F59E0B;
  background-color: #FFFBEB;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.week-days {
  display: flex;
  justify-content: space-between;
  padding: 0 8rpx;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.day-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
}

.week-day.checked .day-dot {
  background-color: #0891B2;
  border-color: #0891B2;
}

.day-check {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.day-label {
  font-size: 22rpx;
  color: #94A3B8;
}

.week-day.checked .day-label {
  color: #0891B2;
  font-weight: 500;
}

/*  */
.badges-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 24rpx;
}

.badges-list {
  display: flex;
  justify-content: space-between;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.badge-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-item.locked .badge-icon {
  background: #E2E8F0;
  color: #94A3B8;
}

.badge-name {
  font-size: 22rpx;
  color: #475569;
}

.badge-item.locked .badge-name {
  color: #94A3B8;
}

.badges-empty {
  font-size: 26rpx;
  color: #94A3B8;
  text-align: center;
  padding: 24rpx 0;
}

/*  */
.menu-list {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.menu-card {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.menu-card:last-child {
  border-bottom: none;
}

.menu-icon-text {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-review {
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
}

.menu-icon-export {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
}

.menu-icon-calendar {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
}

.menu-icon-rank {
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
}

.menu-icon-setting {
  background: linear-gradient(135deg, #64748B 0%, #94A3B8 100%);
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #164E63;
}

.menu-desc {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CBD5E1;
  margin-left: 16rpx;
}

/*  */
.logout-wrap {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: transparent;
  color: #EF4444;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-logout::after {
  border: none;
}

.logout-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}
