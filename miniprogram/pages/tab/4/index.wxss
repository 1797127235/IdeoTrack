.page-placeholder {
  padding: var(--space-4);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary-dark);
  margin-bottom: var(--space-2);
}

.desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-3);
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(8, 145, 178, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
}

.menu-icon {
  font-size: 44rpx;
  margin-right: var(--space-3);
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary-dark);
  margin-bottom: var(--space-1);
}

.menu-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.menu-arrow {
  font-size: 40rpx;
  color: var(--color-text-disabled);
}

.btn-logout {
  margin-top: var(--space-6);
  background-color: var(--color-surface);
  color: var(--color-error);
  border: 2rpx solid var(--color-error);
  border-radius: var(--radius-md);
  font-size: 28rpx;
}

/* Counselor profile card */
.counselor-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(8, 145, 178, 0.2);
}

.counselor-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.counselor-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  margin-right: var(--space-4);
  flex-shrink: 0;
}

.counselor-info {
  min-width: 0;
}

.counselor-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: var(--space-1);
}

.counselor-meta {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 4rpx;
}

.counselor-stat {
  text-align: center;
  padding-left: var(--space-4);
  border-left: 1rpx solid rgba(255, 255, 255, 0.25);
  min-width: 120rpx;
}

.counselor-stat .stat-value {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.counselor-stat .stat-label {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

/* Menu list */
.menu-list {
  margin-bottom: var(--space-3);
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: var(--space-3);
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  flex-shrink: 0;
}

.menu-icon-review {
  background-image: url("data:image/svg+xml;base64,");
}

.menu-icon-export {
  background-image: url("data:image/svg+xml;base64,");
}
