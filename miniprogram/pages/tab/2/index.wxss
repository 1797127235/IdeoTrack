.page {
  min-height: 100vh;
  background-color: #F8FAFC;
}

.content {
  padding: 32rpx 32rpx 48rpx;
}

/* 本月成长概览 */
.overview-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F0FDFF 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.overview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
}

.overview-arrow {
  font-size: 24rpx;
  color: #0891B2;
  font-weight: 500;
}

.overview-main {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.medal {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
}

.medal-icon {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.overview-text {
  flex: 1;
}

.overview-percent {
  font-size: 28rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.highlight {
  font-size: 40rpx;
  font-weight: 700;
  color: #F59E0B;
}

.overview-desc {
  font-size: 24rpx;
  color: #94A3B8;
}

.overview-grid {
  display: flex;
  justify-content: space-between;
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.overview-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.task-icon {
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
}

.streak-icon {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
}

.reflection-icon {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
}

.points-icon {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
}

.overview-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 4rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 4rpx;
}

.overview-sub {
  font-size: 20rpx;
  color: #94A3B8;
}

/* 等级进度 */
.level-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.level-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.level-badge-lg {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.level-info {
  flex: 1;
}

.level-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 8rpx;
}

.level-desc {
  font-size: 24rpx;
  color: #64748B;
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: #E2E8F0;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0891B2 0%, #06B6D4 100%);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #0891B2;
  font-weight: 600;
  min-width: 56rpx;
  text-align: right;
}

/* 近7天 */
.weekly-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 24rpx;
}

.weekly-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 200rpx;
  padding: 0 8rpx;
}

.weekly-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.weekly-bar-wrap {
  position: relative;
  width: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 160rpx;
}

.weekly-bar {
  width: 32rpx;
  background: linear-gradient(180deg, #06B6D4 0%, #0891B2 100%);
  border-radius: 16rpx 16rpx 4rpx 4rpx;
  min-height: 8rpx;
  transition: height 0.3s ease;
}

.weekly-count {
  position: absolute;
  top: -28rpx;
  font-size: 20rpx;
  color: #0891B2;
  font-weight: 600;
}

.weekly-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}

.chart-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  gap: 8rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #0891B2;
}

.legend-text {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 排行榜 */
.leaderboard-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.leaderboard-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.leaderboard-tabs {
  display: flex;
  align-items: center;
  background-color: #F1F5F9;
  border-radius: 999rpx;
  padding: 6rpx;
  gap: 6rpx;
}

.leaderboard-tab {
  font-size: 26rpx;
  color: #64748B;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  transition: all 0.2s ease;
}

.leaderboard-tab.active {
  background-color: #FFFFFF;
  color: #0891B2;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.leaderboard-self {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #F0FDFF 0%, #FFFFFF 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #E0F2FE;
}

.self-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 8rpx;
}

.self-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #164E63;
}

.self-beat {
  font-size: 24rpx;
  color: #475569;
}

.beat-rate {
  color: #F59E0B;
  font-weight: 700;
}

.leaderboard-scroll {
  max-height: 480rpx;
}

.leaderboard-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.leaderboard-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.leaderboard-item.me {
  background-color: #F0FDFF;
  border-radius: 16rpx;
  padding: 16rpx;
  margin: 0 -16rpx;
}

.rank {
  width: 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #164E63;
  text-align: center;
}

.rank.top {
  color: #F59E0B;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #22D3EE 0%, #0891B2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 16rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.name {
  flex: 1;
  font-size: 28rpx;
  color: #475569;
}

.me-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #0891B2;
  background-color: #E0F2FE;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  margin-left: 8rpx;
}

.score {
  font-size: 28rpx;
  font-weight: 600;
  color: #164E63;
}

.leaderboard-empty {
  font-size: 26rpx;
  color: #94A3B8;
  text-align: center;
  padding: 32rpx 0;
}

/* 学习记录入口 */
.menu-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
  margin-bottom: 24rpx;
}

.menu-icon-text {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-calendar {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #164E63;
}

.menu-desc {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CBD5E1;
  margin-left: 16rpx;
}

/* Counselor task management */
.counselor-container {
  min-height: 100vh;
  background: var(--color-background, #ECFEFF);
  padding: 24rpx 24rpx calc(112rpx + env(safe-area-inset-bottom));
}

.counselor-container .section {
  margin-bottom: 32rpx;
}

.counselor-container .section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.counselor-container .section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #164E63);
  margin-bottom: 0;
}

.counselor-container .section-count {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
}

.counselor-container .task-list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.06);
}

.counselor-container .task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid var(--color-divider, #F1F5F9);
}

.counselor-container .task-card:last-child {
  border-bottom: none;
}

.counselor-container .task-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary, #164E63);
}

.counselor-container .task-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
  margin-top: 6rpx;
}

.counselor-container .dispatch-btn {
  background: var(--color-cta, #22C55E);
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

.counselor-container .task-status {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}

.counselor-container .task-status.published {
  background: rgba(34, 197, 94, 0.12);
  color: var(--color-cta, #22C55E);
}

.counselor-container .task-status.delisted {
  background: rgba(148, 163, 184, 0.12);
  color: var(--color-text-disabled, #94A3B8);
}

.counselor-container .empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  color: var(--color-text-secondary, #64748B);
}

.counselor-container .empty-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.counselor-container .empty-text {
  font-size: 26rpx;
}

.counselor-container .empty-icon-pool,
.counselor-container .empty-icon-dispatched {
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 12rpx;
}

.counselor-container .empty-icon-pool {
  background-image: url("data:image/svg+xml;base64,");
}

.counselor-container .empty-icon-dispatched {
  background-image: url("data:image/svg+xml;base64,");
}

.skeleton-list {
  padding: 24rpx;
}

.skeleton {
  background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
  background-size: 200% 100%;
  border-radius: 16rpx;
  animation: shimmer 1.5s infinite;
}

.section-skeleton {
  height: 240rpx;
  margin-bottom: 24rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
