.page {
  min-height: 100vh;
  background-color: #F8FAFC;
}

.content {
  padding: 32rpx 32rpx 48rpx;
}

/* 本月成长概览 */
.overview-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F0FDFF 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.overview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
}

.overview-month {
  font-size: 24rpx;
  color: #0891B2;
  font-weight: 500;
}

.overview-main {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.medal {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
}

.medal-icon {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.overview-text {
  flex: 1;
}

.overview-percent {
  font-size: 28rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.highlight {
  font-size: 40rpx;
  font-weight: 700;
  color: #F59E0B;
}

.overview-desc {
  font-size: 24rpx;
  color: #94A3B8;
}

.overview-grid {
  display: flex;
  justify-content: space-between;
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.overview-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.task-icon {
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
}

.streak-icon {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
}

.reflection-icon {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
}

.points-icon {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
}

.overview-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 4rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 4rpx;
}

.overview-sub {
  font-size: 20rpx;
  color: #94A3B8;
}

/* 等级进度 */
.level-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.level-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.level-badge-lg {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.level-info {
  flex: 1;
}

.level-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 8rpx;
}

.level-desc {
  font-size: 24rpx;
  color: #64748B;
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: #E2E8F0;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0891B2 0%, #06B6D4 100%);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #0891B2;
  font-weight: 600;
  min-width: 56rpx;
  text-align: right;
}

/* 近7天 */
.weekly-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 24rpx;
}

.weekly-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 200rpx;
  padding: 0 8rpx;
}

.weekly-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.weekly-bar-wrap {
  position: relative;
  width: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 160rpx;
}

.weekly-bar {
  width: 32rpx;
  background: linear-gradient(180deg, #06B6D4 0%, #0891B2 100%);
  border-radius: 16rpx 16rpx 4rpx 4rpx;
  min-height: 8rpx;
  transition: height 0.3s ease;
}

.weekly-count {
  position: absolute;
  top: -28rpx;
  font-size: 20rpx;
  color: #0891B2;
  font-weight: 600;
}

.weekly-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}

.chart-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  gap: 8rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #0891B2;
}

.legend-text {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 排行榜 */
.leaderboard-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.leaderboard-self {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #F0FDFF 0%, #FFFFFF 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #E0F2FE;
}

.self-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 8rpx;
}

.self-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #164E63;
}

.self-beat {
  font-size: 24rpx;
  color: #475569;
}

.beat-rate {
  color: #F59E0B;
  font-weight: 700;
}

.leaderboard-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.leaderboard-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.leaderboard-item.placeholder {
  justify-content: center;
  color: #94A3B8;
}

.rank {
  width: 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #164E63;
  text-align: center;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 16rpx;
  font-size: 24rpx;
  color: #64748B;
}

.name {
  flex: 1;
  font-size: 28rpx;
  color: #475569;
}

.score {
  font-size: 28rpx;
  font-weight: 600;
  color: #164E63;
}

/* 学习记录入口 */
.menu-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.12);
}

.menu-icon-text {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-calendar {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #164E63;
}

.menu-desc {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CBD5E1;
  margin-left: 16rpx;
}
