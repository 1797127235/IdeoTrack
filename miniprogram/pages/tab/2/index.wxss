.calendar-container {
  padding: var(--space-4);
}

/* Header */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
}

.nav-icon {
  font-size: 40rpx;
  color: var(--color-primary);
  font-weight: 700;
}

.month-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

/* Weekdays */
.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
  margin-bottom: var(--space-2);
}

.weekday {
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Grid */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  transition: transform 0.1s ease;
}

.day-cell:active {
  transform: scale(0.95);
}

.day-cell.out-month {
  opacity: 0.4;
}

.day-cell.checked-in {
  background-color: var(--color-success);
}

.day-cell.checked-in .day-number {
  color: #ffffff;
  font-weight: 700;
}

.day-number {
  font-size: 28rpx;
  color: var(--color-text);
}

/* Loading / Error */
.loading-state,
.error-state {
  margin-top: var(--space-5);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto var(--space-2);
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* Detail modal */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(22, 78, 99, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.detail-card {
  width: 80%;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.detail-date {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.detail-close {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  padding: var(--space-1);
}

.detail-row {
  margin-bottom: var(--space-2);
}

.detail-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-1);
  display: block;
}

.detail-value {
  font-size: 30rpx;
  color: var(--color-text);
}

.detail-value.status {
  color: var(--color-success);
}

.detail-reflection {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
  white-space: pre-wrap;
}


.page {
  min-height: 100vh;
  background: var(--color-background, #ECFEFF);
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.container {
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #164E63);
}

.section-count {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
}

.task-list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.06);
}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid var(--color-divider, #F1F5F9);
}

.task-card:last-child {
  border-bottom: none;
}

.task-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary, #164E63);
}

.task-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748B);
  margin-top: 6rpx;
}

.dispatch-btn {
  background: var(--color-cta, #22C55E);
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

.task-status {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}

.task-status.published {
  background: rgba(34, 197, 94, 0.12);
  color: var(--color-cta, #22C55E);
}

.task-status.delisted {
  background: rgba(148, 163, 184, 0.12);
  color: var(--color-text-disabled, #94A3B8);
}

.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  color: var(--color-text-secondary, #64748B);
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
}

/* Empty state icons (replace emoji with neutral SVG stroke icons) */
.empty-icon-pool,
.empty-icon-dispatched {
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 12rpx;
}

.empty-icon-pool {
  background-image: url("data:image/svg+xml;base64,");
}

.empty-icon-dispatched {
  background-image: url("data:image/svg+xml;base64,");
}
