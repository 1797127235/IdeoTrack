<view class="page">
  <view class="header-bg"></view>

  <view class="content">
    <!-- 本月成长概览 -->
    <view class="overview-card">
      <view class="overview-header">
        <view class="overview-title">本月成长概览</view>
        <view class="overview-month">本月 ›</view>
      </view>

      <view class="overview-main">
        <view class="medal">
          <text class="medal-icon">勋章</text>
        </view>
        <view class="overview-text">
          <view class="overview-percent"><text class="highlight">0%</text> 完成率</view>
          <view class="overview-desc">继续保持，遇见更好的自己！</view>
        </view>
      </view>

      <view class="overview-grid">
        <view class="overview-item">
          <text class="overview-icon task-icon">任务</text>
          <view class="overview-value">{{loading ? '-' : stats.monthly.completedTasks}}/{{loading ? '-' : stats.monthly.totalTasks}}</view>
          <view class="overview-label">完成任务</view>
          <view class="overview-sub">完成率 {{loading ? '-' : stats.monthly.completionRate}}%</view>
        </view>

        <view class="overview-item">
          <text class="overview-icon streak-icon">打卡</text>
          <view class="overview-value">{{loading ? '-' : stats.monthly.maxStreak}}</view>
          <view class="overview-label">连续打卡</view>
          <view class="overview-sub">最长 {{loading ? '-' : stats.monthly.maxStreak}} 天</view>
        </view>

        <view class="overview-item">
          <text class="overview-icon reflection-icon">心得</text>
          <view class="overview-value">{{loading ? '-' : stats.monthly.reflections}}</view>
          <view class="overview-label">提交心得</view>
          <view class="overview-sub">本月提交</view>
        </view>

        <view class="overview-item">
          <text class="overview-icon points-icon">积分</text>
          <view class="overview-value">{{loading ? '-' : stats.monthly.points}}</view>
          <view class="overview-label">累计积分</view>
          <view class="overview-sub">+{{loading ? '-' : stats.monthly.points}} 本月</view>
        </view>
      </view>
    </view>

    <!-- 等级进度 -->
    <view class="level-card">
      <view class="level-main">
        <view class="level-badge-lg">Lv.{{stats.level.level}}</view>
        <view class="level-info">
          <view class="level-title">Lv.{{stats.level.level}} {{stats.level.title}}</view>
          <view class="level-desc" wx:if="{{stats.level.maxPoints}}">距离 Lv.{{stats.level.level + 1}} 还差 {{stats.level.maxPoints - stats.points}} 积分</view>
          <view class="level-desc" wx:else>已达到最高等级</view>
        </view>
      </view>

      <view class="progress-wrap">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{loading ? 0 : levelProgress}}%"></view>
        </view>
        <view class="progress-text">{{loading ? '-' : levelProgress}}%</view>
      </view>
    </view>

    <!-- 近7天完成情况 -->
    <view class="weekly-card">
      <view class="section-title">近7天完成情况</view>

      <view class="weekly-chart">
        <view wx:for="{{stats.weekly}}" wx:key="day" class="weekly-item">
          <view class="weekly-bar-wrap">
            <view class="weekly-bar" style="height: {{maxWeekly > 0 ? (item.completed / maxWeekly * 120) : 0}}rpx"></view>
            <view class="weekly-count" wx:if="{{item.completed > 0}}">{{item.completed}}</view>
          </view>
          <view class="weekly-label">{{item.label}}</view>
        </view>
      </view>

      <view class="chart-legend">
        <view class="legend-dot"></view>
        <view class="legend-text">完成任务数（个）</view>
      </view>
    </view>

    <!-- 班级排行榜 -->
    <view class="leaderboard-card" bindtap="goToLeaderboard">
      <view class="section-title">班级排行榜</view>

      <view class="leaderboard-self">
        <view class="self-rank">
          <view class="self-label">我的排名</view>
          <view class="self-value">第 - 名</view>
        </view>
        <view class="self-beat">
          超过了 <text class="beat-rate">- %</text> 的同学
        </view>
      </view>

      <view class="leaderboard-list">
        <view class="leaderboard-item placeholder">
          <view class="rank">1</view>
          <view class="avatar">-</view>
          <view class="name">排行榜开发中</view>
          <view class="score">-</view>
        </view>
      </view>
    </view>

    <!-- 学习记录入口 -->
    <view class="menu-card" bindtap="goToCalendar">
      <text class="menu-icon-text menu-icon-calendar">历</text>
      <view class="menu-content">
        <view class="menu-title">学习记录</view>
        <view class="menu-desc">查看历史打卡、任务完成和心得记录</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>
</view>
