<view class="tab-page">
  <!-- Student Home -->
  <block wx:if="{{role === 'student'}}">
    <view class="container home-container">
      <view class="header">
        <view class="greeting-row">
          <text class="greeting">{{greeting}}，{{roleLabel}}</text>
          <view class="role-tag">{{roleLabel}}</view>
        </view>
        <text class="date-text">{{homeDateText}}</text>
      </view>

      <view class="quote-card">
        <view class="quote-content-wrap">
          <block wx:if="{{quoteLoading}}">
            <view class="skeleton quote-skeleton"></view>
          </block>
          <block wx:elif="{{quote}}">
            <text class="quote-content">{{quote.content}}</text>
            <text class="quote-source" wx:if="{{quote.author || quote.source}}">
              —— {{quote.author}}<text wx:if="{{quote.source}}"> {{quote.source}}</text>
            </text>
          </block>
          <block wx:else>
            <text class="empty-hint">暂无今日名言</text>
          </block>
        </view>
      </view>

      <view class="streak-card">
        <view class="streak-main">
          <view class="streak-label">连续打卡</view>
          <view class="streak-value">{{streakDays}}<text class="streak-unit">天</text></view>
          <view class="streak-sub">累计积分 {{totalPoints}} 分</view>
        </view>
        <view class="streak-week">
          <view class="week-day {{item.checked ? 'checked' : ''}}" wx:for="{{weekDays}}" wx:key="day">
            <text class="week-day-label">{{item.label}}</text>
            <view class="week-day-dot"></view>
          </view>
        </view>
      </view>

      <view class="tasks-section">
        <view class="section-header">
          <text class="section-title">今日任务</text>
          <text class="section-meta" wx:if="{{tasks.length > 0}}">共 {{tasks.length}} 个</text>
        </view>

        <view class="loading-state" wx:if="{{tasksLoading}}">
          <view class="skeleton task-skeleton" wx:for="{{3}}" wx:key="*this"></view>
        </view>

        <block wx:elif="{{tasks.length > 0}}">
          <view class="task-card" wx:for="{{tasks}}" wx:key="id" data-id="{{item.id}}" bindtap="goToTask">
            <view class="task-main">
              <view class="task-title-row">
                <text class="task-title">{{item.title}}</text>
                <view class="status-badge" style="color: {{item.statusMeta.color}}; background-color: {{item.statusMeta.bgColor}};">
                  {{item.statusMeta.label}}
                </view>
              </view>
              <text class="task-deadline">{{item.deadlineText}}</text>
              <text class="task-summary" wx:if="{{item.content}}">{{item.content}}</text>
            </view>
            <view class="task-action" wx:if="{{item.status === 'in_progress'}}" catchtap="goToCheckIn" data-id="{{item.id}}">
              <button class="btn-mini">去打卡</button>
            </view>
          </view>
        </block>

        <view class="empty-state" wx:else>
          <view class="empty-icon">🎉</view>
          <view>今日暂无任务，好好休息吧</view>
        </view>
      </view>

      <view class="error-toast" wx:if="{{homeError}}">{{homeError}}</view>
    </view>
  </block>

  <!-- Counselor Dashboard: task-centric -->
  <block wx:elif="{{role === 'counselor'}}">
    <view class="dashboard-container">
      <view class="header">
        <view class="header-top">
          <view>
            <view class="greeting">任务看板</view>
            <view class="date-text">所辖班级任务完成情况</view>
          </view>
          <view class="export-btn" bindtap="goToExport">导出数据</view>
        </view>
      </view>

      <view wx:if="{{dashErrorMsg}}" class="error-tip">{{dashErrorMsg}}</view>

      <view wx:if="{{dashLoading && dashTasks.length === 0}}" class="skeleton-list">
        <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton class-skeleton"></view>
      </view>

      <block wx:if="{{dashTasks.length > 0}}">
        <view
          wx:for="{{dashTasks}}"
          wx:key="task_id"
          class="task-card"
          data-id="{{item.task_id}}"
          data-title="{{item.title}}"
          bindtap="goToTaskClasses"
        >
          <view class="task-header">
            <view class="task-title">{{item.title}}</view>
            <view class="task-deadline">{{item.deadlineText}}</view>
          </view>

          <view wx:for="{{item.classes}}" wx:key="class_id" wx:for-item="cls" class="class-row">
            <view class="class-info">
              <view class="class-name">{{cls.class_name}}</view>
              <view class="class-meta">{{cls.college_name}}</view>
            </view>
            <view class="class-stats">
              <view class="rate-bar-bg">
                <view class="rate-bar-fill" style="width: {{cls.check_in_rate}}%;"></view>
              </view>
              <view class="rate-value">{{cls.check_in_rate}}%</view>
            </view>
          </view>

          <view class="card-hint">点击查看班级明细</view>
        </view>
      </block>

      <view wx:if="{{!dashLoading && dashTasks.length === 0 && !dashErrorMsg}}" class="empty-state">
        <view>暂无负责的任务</view>
        <view class="text-secondary">管理员发布任务后即可查看</view>
      </view>
    </view>
  </block>

  <!-- Unknown role -->
  <block wx:else>
    <view class="empty-state">
      <view class="empty-icon">🔒</view>
      <view>请先登录</view>
    </view>
  </block>
</view>
