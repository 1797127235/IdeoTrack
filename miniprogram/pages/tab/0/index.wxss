.home-container {
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
}

/* Header */
.header {
  margin-bottom: var(--space-4);
}

.greeting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.role-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(8, 145, 178, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full, 999rpx);
}

.date-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Quote card */
.quote-card {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  position: relative;
  overflow: hidden;
}

.quote-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.quote-content-wrap {
  position: relative;
  z-index: 1;
}

.quote-content {
  display: block;
  font-size: 34rpx;
  line-height: 1.7;
  color: #ffffff;
  font-weight: 500;
  margin-bottom: var(--space-3);
}

.quote-source {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  padding: var(--space-4) 0;
}

/* Streak card */
.streak-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
}

.streak-main {
  flex: 1;
}

.streak-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-1);
}

.streak-value {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1;
  margin-bottom: var(--space-1);
}

.streak-unit {
  font-size: 28rpx;
  font-weight: 500;
  margin-left: 8rpx;
}

.streak-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.streak-week {
  display: flex;
  gap: var(--space-2);
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.week-day-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.week-day-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: var(--color-border);
}

.week-day.checked .week-day-dot {
  background-color: var(--color-cta);
}

/* Tasks section */
.tasks-section {
  margin-top: var(--space-2);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  transition: transform 0.1s ease;
}

.task-card:active {
  transform: scale(0.99);
}

.task-main {
  flex: 1;
  min-width: 0;
  margin-right: var(--space-3);
}

.task-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: var(--space-2);
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full, 999rpx);
  white-space: nowrap;
}

.task-deadline {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-1);
}

.task-summary {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-action {
  flex-shrink: 0;
}

.btn-mini {
  font-size: 24rpx;
  color: #ffffff;
  background-color: var(--color-cta);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-md);
  line-height: 1.4;
  margin: 0;
  border: none;
}

.btn-mini::after {
  border: none;
}

/* Skeleton */
.skeleton {
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-md);
  animation: shimmer 1.2s infinite;
}

.quote-skeleton {
  height: 120rpx;
  margin-bottom: var(--space-2);
}

.task-skeleton {
  height: 160rpx;
  margin-bottom: var(--space-3);
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* Empty state */
.empty-state {
  padding: var(--space-8) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: var(--space-2);
}

/* Error */
.error-toast {
  margin-top: var(--space-3);
  padding: var(--space-3);
  background-color: rgba(239, 68, 68, 0.1);
  color: var(--color-error);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  text-align: center;
}


.dashboard-container {
  padding: var(--space-4);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: var(--space-4);
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-1);
}

.date-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.export-btn {
  display: inline-block;
  font-size: 26rpx;
  color: var(--color-primary);
  background: rgba(8, 145, 178, 0.1);
  border-radius: var(--radius-md);
  padding: 12rpx 24rpx;
}

/* KPI Section */
.kpi-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  margin-bottom: var(--space-4);
}

.kpi-main {
  flex: 1;
}

.kpi-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: var(--space-2);
}

.kpi-value {
  font-size: 80rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  margin-bottom: var(--space-2);
}

.kpi-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.kpi-chart {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  margin-left: var(--space-4);
}

.donut-chart {
  position: relative;
  width: 100%;
  height: 100%;
}

.donut-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}

.donut-center {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.donut-rate {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.donut-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* Summary grid */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}

.summary-card {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  text-align: center;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-1);
}

.summary-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* Section header */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* Focus students */
.focus-section {
  margin-bottom: var(--space-5);
}

.focus-skeleton {
  height: 200rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
}

.focus-student {
  display: flex;
  align-items: center;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-2);
}

.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.student-info {
  flex: 1;
  min-width: 0;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.student-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.remind-btn {
  font-size: 24rpx;
  color: #ffffff;
  background-color: var(--color-primary);
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  line-height: 1.5;
  margin: 0;
  border: none;
}

.remind-btn::after {
  border: none;
}

.remind-btn[disabled] {
  background-color: var(--color-border);
  color: var(--color-text-disabled);
}

.empty-hint {
  text-align: center;
  padding: var(--space-6) 0;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

/* Error */
.error-tip {
  background-color: rgba(239, 68, 68, 0.08);
  color: var(--color-error);
  font-size: 26rpx;
  padding: var(--space-3);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-3);
}

/* Class card */
.class-card {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  transition: transform 0.1s ease;
}

.class-card:active {
  transform: scale(0.99);
}

.class-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.class-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.college-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(8, 145, 178, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: var(--space-3);
}

.stat {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-1);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.rate-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
}

.rate-bar-bg {
  flex: 1;
  height: 16rpx;
  background-color: var(--color-divider);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.rate-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-cta));
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.rate-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-left: var(--space-2);
  width: 80rpx;
  text-align: right;
}

.card-hint {
  font-size: 22rpx;
  color: var(--color-text-disabled);
  text-align: right;
}

.text-primary {
  color: var(--color-primary);
}

.text-success {
  color: var(--color-success);
}

.text-error {
  color: var(--color-error);
}

.empty-state {
  padding: var(--space-8) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.skeleton-list {
  margin-bottom: var(--space-4);
}

.class-skeleton {
  height: 280rpx;
  margin-bottom: var(--space-3);
}

.skeleton {
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-lg);
  animation: shimmer 1.2s infinite;
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
