.home-container {
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
}

/* Header */
.header {
  margin-bottom: var(--space-4);
}

.greeting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.role-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(8, 145, 178, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full, 999rpx);
}

.date-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Quote card */
.quote-card {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  position: relative;
  overflow: hidden;
}

.quote-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.quote-content-wrap {
  position: relative;
  z-index: 1;
}

.quote-content {
  display: block;
  font-size: 34rpx;
  line-height: 1.7;
  color: #ffffff;
  font-weight: 500;
  margin-bottom: var(--space-3);
}

.quote-source {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  padding: var(--space-4) 0;
}

/* Streak card */
.streak-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
}

.streak-main {
  flex: 1;
}

.streak-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-1);
}

.streak-value {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1;
  margin-bottom: var(--space-1);
}

.streak-unit {
  font-size: 28rpx;
  font-weight: 500;
  margin-left: 8rpx;
}

.streak-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.streak-week {
  display: flex;
  gap: var(--space-2);
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.week-day-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.week-day-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: var(--color-border);
}

.week-day.checked .week-day-dot {
  background-color: var(--color-cta);
}

/* Tasks section */
.tasks-section {
  margin-top: var(--space-2);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.sort-control {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background-color: #FFFFFF;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid #CBD5E1;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  height: 52rpx;
  box-sizing: border-box;
}

.sort-text {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
  white-space: nowrap;
  line-height: 1;
}

.sort-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 10rpx solid #64748B;
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.sort-arrow.desc {
  transform: rotate(180deg);
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 999rpx;
  padding: 0 20rpx;
  margin-bottom: var(--space-3);
  border: 2rpx solid #CBD5E1;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  height: 76rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-placeholder {
  color: #94A3B8;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #CBD5E1;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  transition: transform 0.1s ease;
}

.task-card:active {
  transform: scale(0.99);
}

.task-main {
  flex: 1;
  min-width: 0;
  margin-right: var(--space-3);
}

.task-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: var(--space-2);
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full, 999rpx);
  white-space: nowrap;
}

.task-deadline {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-1);
}

.task-summary {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-action {
  flex-shrink: 0;
}

.btn-mini {
  font-size: 24rpx;
  color: #ffffff;
  background-color: var(--color-cta);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-md);
  line-height: 1.4;
  margin: 0;
  border: none;
}

.btn-mini::after {
  border: none;
}

/* Skeleton */
.skeleton {
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-md);
  animation: shimmer 1.2s infinite;
}

.quote-skeleton {
  height: 120rpx;
  margin-bottom: var(--space-2);
}

.task-skeleton {
  height: 160rpx;
  margin-bottom: var(--space-3);
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* Empty state */
.empty-state {
  padding: var(--space-8) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: var(--space-2);
}

/* Error */
.error-toast {
  margin-top: var(--space-3);
  padding: var(--space-3);
  background-color: rgba(239, 68, 68, 0.1);
  color: var(--color-error);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  text-align: center;
}

/* Counselor task dashboard */
.dashboard-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.dashboard-container .header {
  background: #ffffff;
  padding: 24rpx 32rpx;
  margin-bottom: 0;
}

.dashboard-container .header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dashboard-container .date-text {
  font-size: 28rpx;
  color: #262626;
  opacity: 1;
  margin-top: 0;
}

.export-btn {
  font-size: 26rpx;
  color: #1890ff;
  background: #ffffff;
  border: 1rpx solid #1890ff;
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
}

.error-tip {
  margin: 20rpx 32rpx;
  padding: 20rpx;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
  color: #cf1322;
  font-size: 28rpx;
}

.dashboard-container .task-card {
  display: block;
  background: #fff;
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.dashboard-container .task-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.dashboard-container .task-deadline {
  font-size: 24rpx;
  color: #8c8c8c;
}

.class-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.class-row:last-child {
  border-bottom: none;
}

.class-info {
  flex: 1;
  min-width: 0;
}

.class-name {
  font-size: 30rpx;
  color: #262626;
}

.class-meta {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.class-stats {
  display: flex;
  align-items: center;
  width: 220rpx;
  margin-left: 20rpx;
}

.rate-bar-bg {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.rate-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #389e0d);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.rate-value {
  font-size: 26rpx;
  color: #262626;
  margin-left: 12rpx;
  min-width: 64rpx;
  text-align: right;
}

.card-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  text-align: center;
}

.text-secondary {
  font-size: 26rpx;
  color: #bfbfbf;
  margin-top: 12rpx;
}

.skeleton-list {
  padding: 20rpx 32rpx;
}

.class-skeleton {
  height: 180rpx;
  margin-bottom: 20rpx;
}

/* High risk students card */
.high-risk-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.high-risk-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.high-risk-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.high-risk-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #cf1322;
}

.high-risk-loading {
  font-size: 26rpx;
  color: #8c8c8c;
}

.high-risk-desc {
  font-size: 24rpx;
  color: #8c8c8c;
}

.high-risk-arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #bfbfbf;
}

.high-risk-card .high-risk-main,
.high-risk-card .high-risk-desc {
  padding-right: 40rpx;
}
