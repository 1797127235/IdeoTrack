    <view class="desc">积分 / 等级 / 勋章 / 个人信息将在这里展示</view>
    <view class="tag">待 Epic 6</view>
  </view>

  <view wx:if="{{showReviewEntry}}" class="menu-card" bindtap="goToReviews">
    <view class="menu-icon">📝</view>
