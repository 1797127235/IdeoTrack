      <view class="menu-title">心得复核</view>
      <view class="menu-desc">查看待复核的学生心得并处理</view>
    </view>
    <view class="menu-arrow">›</view>
  </view>

  <button class="btn-logout" bindtap="handleLogout">退出登录</button>
</view>
