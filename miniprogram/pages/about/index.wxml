<view class="page">
  <view class="brand-card">
    <view class="brand-icon"></view>
    <view class="brand-title">思政打卡</view>
    <view class="brand-desc">面向学生与辅导员的思政学习任务、打卡验证、心得复核和成长记录工具。</view>
  </view>

  <view class="section">
    <view class="section-title">我们提供</view>
    <view class="feature-item">
      <view class="feature-dot"></view>
      <view class="feature-text">学生任务打卡、定位拍照和人脸验证</view>
    </view>
    <view class="feature-item">
      <view class="feature-dot"></view>
      <view class="feature-text">辅导员任务管理、心得复核和数据导出</view>
    </view>
    <view class="feature-item">
      <view class="feature-dot"></view>
      <view class="feature-text">成长积分、连续打卡和学习记录沉淀</view>
    </view>
  </view>

  <view class="section meta-section">
    <view class="meta-row">
      <text class="meta-label">当前版本</text>
      <text class="meta-value">v{{version}}</text>
    </view>
    <view class="meta-row">
      <text class="meta-label">服务对象</text>
      <text class="meta-value">学生 / 辅导员 / 管理员</text>
    </view>
  </view>
</view>
