.home-container {
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
}

/* Header */
.header {
  margin-bottom: var(--space-4);
}

.greeting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.role-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(8, 145, 178, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full, 999rpx);
}

.date-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Quote card */
.quote-card {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  position: relative;
  overflow: hidden;
}

.quote-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.quote-content-wrap {
  position: relative;
  z-index: 1;
}

.quote-content {
  display: block;
  font-size: 34rpx;
  line-height: 1.7;
  color: #ffffff;
  font-weight: 500;
  margin-bottom: var(--space-3);
}

.quote-source {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  padding: var(--space-4) 0;
}

/* Streak card */
.streak-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
}

.streak-main {
  flex: 1;
}

.streak-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-1);
}

.streak-value {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1;
  margin-bottom: var(--space-1);
}

.streak-unit {
  font-size: 28rpx;
  font-weight: 500;
  margin-left: 8rpx;
}

.streak-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.streak-week {
  display: flex;
  gap: var(--space-2);
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.week-day-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.week-day-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: var(--color-border);
}

.week-day.checked .week-day-dot {
  background-color: var(--color-cta);
}

/* Tasks section */
.tasks-section {
  margin-top: var(--space-2);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  transition: transform 0.1s ease;
}

.task-card:active {
  transform: scale(0.99);
}

.task-main {
  flex: 1;
  min-width: 0;
  margin-right: var(--space-3);
}

.task-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: var(--space-2);
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full, 999rpx);
  white-space: nowrap;
}

.task-deadline {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-1);
}

.task-summary {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-action {
  flex-shrink: 0;
}

.btn-mini {
  font-size: 24rpx;
  color: #ffffff;
  background-color: var(--color-cta);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-md);
  line-height: 1.4;
  margin: 0;
  border: none;
}

.btn-mini::after {
  border: none;
}

/* Skeleton */
.skeleton {
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-md);
  animation: shimmer 1.2s infinite;
}

.quote-skeleton {
  height: 120rpx;
  margin-bottom: var(--space-2);
}

.task-skeleton {
  height: 160rpx;
  margin-bottom: var(--space-3);
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* Empty state */
.empty-state {
  padding: var(--space-8) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: var(--space-2);
}

/* Error */
.error-toast {
  margin-top: var(--space-3);
  padding: var(--space-3);
  background-color: rgba(239, 68, 68, 0.1);
  color: var(--color-error);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  text-align: center;
}
