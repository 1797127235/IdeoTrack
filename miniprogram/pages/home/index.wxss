.home-container {
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
}

/* Header */
.header {
  margin-bottom: var(--space-4);
}

.greeting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.role-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(8, 145, 178, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full, 999rpx);
}

.date-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Section */
.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-3);
}

.section-icon {
  margin-right: var(--space-1);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.count-badge {
  margin-left: var(--space-1);
  font-size: 22rpx;
  color: #ffffff;
  background-color: var(--color-primary);
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: var(--radius-full, 999rpx);
  padding: 0 8rpx;
}

/* Quote card */
.quote-card {
  background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-surface-raised) 100%);
  border-left: 8rpx solid var(--color-primary);
}

.quote-content {
  font-size: 32rpx;
  line-height: 1.6;
  color: var(--color-text);
  margin-bottom: var(--space-2);
}

.quote-source {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: right;
}

.empty-hint {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
  padding: var(--space-4) 0;
}

/* Tasks */
.tasks-section {
  margin-top: var(--space-2);
}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
  transition: transform 0.1s ease;
}

.task-card:active {
  transform: scale(0.99);
}

.task-main {
  flex: 1;
  min-width: 0;
  margin-right: var(--space-3);
}

.task-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: var(--space-2);
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full, 999rpx);
  white-space: nowrap;
}

.task-deadline {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.task-action {
  flex-shrink: 0;
}

.btn-mini {
  font-size: 24rpx;
  color: #ffffff;
  background-color: var(--color-cta);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-md);
  line-height: 1.4;
  margin: 0;
  border: none;
}

.btn-mini::after {
  border: none;
}

/* Skeleton */
.skeleton {
  background: linear-gradient(90deg, var(--color-divider) 25%, #e8f4f8 50%, var(--color-divider) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-md);
  animation: shimmer 1.2s infinite;
}

.quote-skeleton {
  height: 120rpx;
  margin-bottom: var(--space-2);
}

.task-skeleton {
  height: 140rpx;
  margin-bottom: var(--space-3);
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* Empty state */
.empty-state {
  padding: var(--space-8) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: var(--space-2);
}

/* Error */
.error-toast {
  margin-top: var(--space-3);
  padding: var(--space-3);
  background-color: rgba(239, 68, 68, 0.1);
  color: var(--color-error);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  text-align: center;
}
