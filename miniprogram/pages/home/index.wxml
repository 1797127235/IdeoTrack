<view class="container home-container">
  <!-- 顶部问候 -->
  <view class="header">
    <view class="greeting-row">
      <text class="greeting">{{greeting}}，{{roleLabel}}</text>
      <view class="role-tag">{{roleLabel}}</view>
    </view>
    <text class="date-text">{{dateText}}</text>
  </view>

  <!-- 每日名言 -->
  <view class="quote-card">
    <view class="quote-content-wrap">
      <block wx:if="{{quoteLoading}}">
        <view class="skeleton quote-skeleton"></view>
      </block>
      <block wx:elif="{{quote}}">
        <text class="quote-content">{{quote.content}}</text>
        <text class="quote-source" wx:if="{{quote.author || quote.source}}">
          —— {{quote.author}}<text wx:if="{{quote.source}}"> {{quote.source}}</text>
        </text>
      </block>
      <block wx:else>
        <text class="empty-hint">暂无今日名言</text>
      </block>
    </view>
  </view>

  <!-- 连续打卡激励 -->
  <view class="streak-card">
    <view class="streak-main">
      <view class="streak-label">连续打卡</view>
      <view class="streak-value">{{streakDays}}<text class="streak-unit">天</text></view>
      <view class="streak-sub">累计积分 {{totalPoints}} 分</view>
    </view>
    <view class="streak-week">
      <view class="week-day {{item.checked ? 'checked' : ''}}" wx:for="{{weekDays}}" wx:key="day">
        <text class="week-day-label">{{item.label}}</text>
        <view class="week-day-dot"></view>
      </view>
    </view>
  </view>

  <!-- 今日任务 -->
  <view class="tasks-section">
    <view class="section-header">
      <text class="section-title">今日任务</text>
      <text class="section-meta" wx:if="{{tasks.length > 0}}">共 {{tasks.length}} 个</text>
    </view>

    <view class="loading-state" wx:if="{{tasksLoading}}">
      <view class="skeleton task-skeleton" wx:for="{{3}}" wx:key="*this"></view>
    </view>

    <block wx:elif="{{tasks.length > 0}}">
      <view class="task-card" wx:for="{{tasks}}" wx:key="id" data-id="{{item.id}}" bindtap="goToTask">
        <view class="task-main">
          <view class="task-title-row">
            <text class="task-title">{{item.title}}</text>
            <view class="status-badge" style="color: {{item.statusMeta.color}}; background-color: {{item.statusMeta.bgColor}};">
              {{item.statusMeta.label}}
            </view>
          </view>
          <text class="task-deadline">{{item.deadlineText}}</text>
          <text class="task-summary" wx:if="{{item.content}}">{{item.content}}</text>
        </view>
        <view class="task-action" wx:if="{{item.status === 'in_progress'}}" catchtap="goToCheckIn" data-id="{{item.id}}">
          <button class="btn-mini">去打卡</button>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:else>
      <view class="empty-icon">🎉</view>
      <view>今日暂无任务，好好休息吧</view>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="error-toast" wx:if="{{error}}">
    {{error}}
  </view>
</view>
