<view class="login-page">
  <view class="logo-area">
    <view class="logo-icon">📚</view>
    <view class="app-name">思政打卡</view>
    <view class="app-slogan">每日积累，轻松成长</view>
  </view>

  <view class="login-card">
    <!-- 登录方式切换 -->
    <view class="mode-tabs">
      <view
        class="mode-tab {{mode === 'wechat' ? 'active' : ''}}"
        data-mode="wechat"
        bindtap="switchMode"
      >微信登录</view>
      <view
        class="mode-tab {{mode === 'password' ? 'active' : ''}}"
        data-mode="password"
        bindtap="switchMode"
      >账号登录</view>
    </view>

    <!-- 微信登录 -->
    <block wx:if="{{mode === 'wechat'}}">
      <button
        class="btn-wechat"
        bindtap="handleWechatLogin"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        {{loading ? '登录中...' : '微信一键登录'}}
      </button>
      <view class="hint">
        首次登录需绑定账号验证身份（学号 / 教师号 / 工号）
      </view>
    </block>

    <!-- 账号密码登录 -->
    <block wx:if="{{mode === 'password'}}">
      <view class="form">
        <view class="field">
          <text class="label">账号</text>
          <input
            class="input"
            placeholder="请输入学号 / 教师号 / 工号"
            placeholder-class="placeholder"
            value="{{account}}"
            bindinput="onAccountInput"
          />
        </view>
        <view class="field">
          <text class="label">密码</text>
          <input
            class="input"
            password
            placeholder="请输入密码"
            placeholder-class="placeholder"
            value="{{password}}"
            bindinput="onPasswordInput"
          />
        </view>
        <button
          class="btn-primary"
          bindtap="handlePasswordLogin"
          loading="{{loading}}"
          disabled="{{loading}}"
        >
          {{loading ? '登录中...' : '登录'}}
        </button>
      </view>
    </block>

    <view wx:if="{{errorMsg}}" class="error-msg">{{errorMsg}}</view>
  </view>

  <view class="footer">
    <text>登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>
