.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 100vh;
  padding: var(--space-6) var(--space-4);
  box-sizing: border-box;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: var(--space-8);
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-3);
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary-dark);
  margin-bottom: var(--space-2);
}

.app-slogan {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.login-card {
  width: 100%;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-4);
  box-shadow: 0 4rpx 24rpx rgba(8, 145, 178, 0.08);
}

/* Mode tabs */
.mode-tabs {
  display: flex;
  margin-bottom: var(--space-4);
  border-bottom: 1rpx solid var(--color-divider);
}

.mode-tab {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  padding: var(--space-2) 0;
  position: relative;
}

.mode-tab.active {
  color: var(--color-primary);
  font-weight: 600;
}

.mode-tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: var(--radius-full);
}

/* Form */
.form {
  width: 100%;
}

.field {
  margin-bottom: var(--space-3);
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  margin-bottom: var(--space-1);
}

.input {
  width: 100%;
  height: 88rpx;
  background-color: var(--color-surface-raised);
  border-radius: var(--radius-md);
  padding: 0 var(--space-3);
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--color-text);
}

.placeholder {
  color: var(--color-text-disabled);
}

/* Buttons */
.btn-wechat {
  width: 100%;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 500;
  padding: var(--space-3) 0;
  border: none;
}

.btn-wechat[disabled] {
  background-color: var(--color-primary);
  opacity: 0.6;
  color: #ffffff;
}

.btn-primary {
  width: 100%;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 500;
  padding: var(--space-3) 0;
  margin-top: var(--space-2);
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.btn-primary::after,
.btn-wechat::after {
  border: none;
}

.hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: var(--space-3);
}

.error-msg {
  text-align: center;
  color: var(--color-error);
  font-size: 26rpx;
  margin-top: var(--space-2);
}

.footer {
  font-size: 22rpx;
  color: var(--color-text-disabled);
  text-align: center;
}
