page {
  height: 100%;
  background-color: #ECFEFF;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.loading-wrap,
.error-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading {
  color: #64748B;
  font-size: 28rpx;
}

.error-text {
  color: #EF4444;
  font-size: 28rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.retry-btn {
  background-color: #0891B2;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
}

.task-scroll {
  flex: 1;
  padding: 24rpx;
}

.task-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.08);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.task-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #164E63;
  line-height: 1.4;
  margin-right: 16rpx;
}

.status-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  white-space: nowrap;
}

.deadline-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.deadline-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.deadline-text {
  font-size: 26rpx;
  color: #64748B;
}

.content-section {
  margin-top: 8rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #164E63;
  margin-bottom: 16rpx;
}

.task-content {
  display: block;
  font-size: 30rpx;
  color: #334155;
  line-height: 1.7;
  white-space: pre-wrap;
}

.footer {
  padding: 24rpx 32rpx 48rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #F1F5F9;
}

.checkin-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #22C55E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn.disabled {
  background-color: #E2E8F0;
  color: #94A3B8;
}

.checkin-btn:not(.disabled):active {
  transform: scale(0.98);
}

.modify-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #FFFFFF;
  color: #0891B2;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: 2rpx solid #0891B2;
  margin-bottom: 20rpx;
}

.modify-btn::after {
  border: none;
}

.modify-btn:active {
  transform: scale(0.98);
}

.review-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #F1F5F9;
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.review-icon {
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 12rpx;
}

.review-label {
  font-size: 32rpx;
  font-weight: 700;
}

.review-reason,
.review-feedback,
.review-reflection {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.reason-label,
.feedback-label,
.reflection-label {
  color: #64748B;
  margin-right: 8rpx;
}

.reason-text,
.feedback-text,
.reflection-text {
  color: #334155;
  word-break: break-all;
}

.feedback-text {
  color: #B45309;
}
