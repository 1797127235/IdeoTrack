page {
  height: 100%;
  background-color: #ECFEFF;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.loading-wrap,
.error-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading {
  color: #64748B;
  font-size: 28rpx;
}

.error-text {
  color: #EF4444;
  font-size: 28rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.retry-btn {
  background-color: #0891B2;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
}

.task-scroll {
  flex: 1;
  padding: 24rpx;
}

/* Task header card */
.task-header-card {
  background: linear-gradient(135deg, #0891B2 0%, #164E63 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #FFFFFF;
}

.task-header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 9999rpx;
}

.task-deadline {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.task-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.4;
}

.status-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  white-space: nowrap;
  background-color: rgba(255, 255, 255, 0.9) !important;
}

/* Steps card */
.steps-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.steps-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 24rpx;
}

.steps-list {
  display: flex;
  flex-direction: column;
}

.step-item {
  display: flex;
  align-items: flex-start;
}

.step-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  background-color: #F1F5F9;
  color: #64748B;
  border: 2rpx solid #E2E8F0;
}

.step-item.current .step-number {
  background-color: #0891B2;
  color: #FFFFFF;
  border-color: #0891B2;
}

.step-item.completed .step-number {
  background-color: #22C55E;
  color: #FFFFFF;
  border-color: #22C55E;
}

.step-line {
  width: 2rpx;
  flex: 1;
  min-height: 60rpx;
  background-color: #E2E8F0;
  margin: 8rpx 0;
}

.step-item.completed .step-line {
  background-color: #22C55E;
}

.step-content {
  flex: 1;
  padding-bottom: 32rpx;
}

.step-item:last-child .step-content {
  padding-bottom: 0;
}

.step-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #164E63;
  margin-bottom: 8rpx;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: #64748B;
}

/* Content card */
.content-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 20rpx;
  margin-top: 32rpx;
}

.section-title:first-child {
  margin-top: 0;
}

.task-content {
  display: block;
  font-size: 30rpx;
  color: #334155;
  line-height: 1.8;
  white-space: pre-wrap;
}

.questions-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #F1F5F9;
}

.question-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.question-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: rgba(8, 145, 178, 0.1);
  color: #0891B2;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.question-text {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
}

.link-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #F1F5F9;
}

.link-card {
  display: flex;
  align-items: center;
  background-color: #F0FDFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.link-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.link-text {
  flex: 1;
  font-size: 26rpx;
  color: #0891B2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Review card */
.review-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.review-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.review-icon {
  font-size: 32rpx;
  font-weight: 700;
}

.review-label {
  font-size: 32rpx;
  font-weight: 700;
}

.review-reason,
.review-feedback,
.review-reflection {
  margin-bottom: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.reason-label,
.feedback-label,
.reflection-label {
  color: #64748B;
  margin-right: 8rpx;
}

.reason-text,
.feedback-text,
.reflection-text {
  color: #334155;
  word-break: break-all;
}

.feedback-text {
  color: #B45309;
}

/* Footer */
.footer {
  padding: 24rpx 32rpx 48rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #F1F5F9;
}

.checkin-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn.disabled {
  background: #E2E8F0;
  color: #94A3B8;
}

.checkin-btn:not(.disabled):active {
  transform: scale(0.98);
}

.modify-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #FFFFFF;
  color: #0891B2;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: 2rpx solid #0891B2;
  margin-bottom: 20rpx;
}

.modify-btn::after {
  border: none;
}

.modify-btn:active {
  transform: scale(0.98);
}
