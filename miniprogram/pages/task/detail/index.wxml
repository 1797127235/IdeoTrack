<view class="container">
  <block wx:if="{{loading}}">
    <view class="loading-wrap">
      <view class="loading">加载中...</view>
    </view>
  </block>

  <block wx:elif="{{error}}">
    <view class="error-wrap">
      <text class="error-text">{{error}}</text>
      <button class="retry-btn" bindtap="onRetry">重试</button>
    </view>
  </block>

  <block wx:elif="{{task}}">
    <scroll-view class="task-scroll" scroll-y>
      <!-- 任务标题卡片 -->
      <view class="task-header-card">
        <view class="task-header-top">
          <view class="task-meta">
            <text class="task-tag">今日任务</text>
            <text class="task-deadline">{{deadlineText}}</text>
          </view>
          <view class="status-badge" style="background-color: {{statusColor}}20; color: {{statusColor}};">
            {{statusLabel}}
          </view>
        </view>
        <text class="task-title">{{task.title}}</text>
      </view>

      <!-- 任务内容 -->
      <view class="content-card">
        <text class="section-title">任务内容</text>
        <text class="task-content">{{task.content}}</text>

        <!-- 思考题 -->
        <view class="questions-section" wx:if="{{task.guiding_questions && task.guiding_questions.length > 0}}">
          <text class="section-title">思考题</text>
          <view class="question-item" wx:for="{{task.guiding_questions}}" wx:key="*this">
            <text class="question-dot">{{index + 1}}</text>
            <text class="question-text">{{item}}</text>
          </view>
        </view>

        <!-- 外部链接 -->
        <view class="link-section" wx:if="{{task.source_url}}">
          <text class="section-title">延伸阅读</text>
          <view class="link-card" data-url="{{task.source_url}}" bindtap="onOpenLink">
            <text class="link-icon">🔗</text>
            <text class="link-text">{{task.source_url}}</text>
          </view>
        </view>

        <!-- 视频链接 -->
        <view class="link-section" wx:if="{{task.video_url}}">
          <text class="section-title">相关视频</text>
          <view class="link-card" data-url="{{task.video_url}}" bindtap="onOpenLink">
            <text class="link-icon">▶️</text>
            <text class="link-text">{{task.video_url}}</text>
          </view>
        </view>
      </view>

      <!-- 打卡表单 -->
      <view class="checkin-form-card" wx:if="{{canCheckIn}}">
        <view class="form-title">{{requireLocation ? '定位签到' : '确认签到'}}</view>

        <!-- 定位状态 -->
        <view class="location-section" wx:if="{{requireLocation}}">
          <view wx:if="{{locationLoading}}" class="location-loading">
            <view class="spinner"></view>
            <text>正在获取位置…</text>
          </view>
          <view wx:elif="{{locationError}}" class="location-error">
            <text>{{locationError}}</text>
            <text class="location-retry" bindtap="loadLocation">重新获取</text>
          </view>
          <view wx:elif="{{address}}" class="location-info">
            <text class="location-icon">📍</text>
            <text class="location-address">{{address}}</text>
          </view>
          <view wx:else class="location-hint">
            <text>点击按钮获取当前位置</text>
            <text class="location-retry" bindtap="loadLocation">获取位置</text>
          </view>
          <view wx:if="{{outOfRange}}" class="location-warning">
            当前位置不在签到范围内，请到指定地点打卡
          </view>
        </view>

        <!-- 心得输入 -->
        <view class="reflection-section">
          <view class="reflection-label-row">
            <text class="reflection-label">学习心得</text>
            <text class="reflection-count">{{reflectionContent.length}}/500</text>
          </view>
          <textarea
            class="reflection-input"
            value="{{reflectionContent}}"
            bindinput="onReflectionInput"
            placeholder="结合任务内容，写下你的学习心得（不少于10字）"
            maxlength="500"
            auto-height
          />
        </view>
      </view>

      <!-- 复核状态 -->
      <view class="review-card" wx:if="{{reviewMeta}}">
        <view class="review-header">
          <view class="review-icon-wrap" style="background-color: {{reviewMeta.color}}20;">
            <text class="review-icon" style="color: {{reviewMeta.color}};">{{reviewMeta.icon}}</text>
          </view>
          <text class="review-label" style="color: {{reviewMeta.color}};">{{reviewMeta.label}}</text>
        </view>
        <view class="review-reason" wx:if="{{reviewReasonText}}">
          <text class="reason-label">AI 初审：</text>
          <text class="reason-text">{{reviewReasonText}}</text>
        </view>
        <view class="review-feedback" wx:if="{{task.review_feedback}}">
          <text class="feedback-label">辅导员反馈：</text>
          <text class="feedback-text">{{task.review_feedback}}</text>
        </view>
        <view class="review-reflection" wx:if="{{task.reflection_content}}">
          <text class="reflection-label">你的心得：</text>
          <text class="reflection-text">{{task.reflection_content}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="footer">
      <button
        wx:if="{{showModifyReflection}}"
        class="modify-btn"
        bindtap="onModifyReflection"
      >
        修改心得
      </button>
      <button
        class="checkin-btn {{buttonDisabled || !canSubmit ? 'disabled' : ''}}"
        disabled="{{buttonDisabled || !canSubmit}}"
        bindtap="onSubmit"
      >
        {{buttonText}}
      </button>
    </view>
  </block>
</view>
