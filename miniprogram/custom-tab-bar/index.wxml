<view class="tab-bar" wx:if="{{list.length > 0}}">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{index === selected ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon">{{item.icon}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
