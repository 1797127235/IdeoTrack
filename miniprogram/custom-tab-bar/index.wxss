.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: calc(112rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #ffffff;
  border-top: 1rpx solid var(--color-border, #e2e8f0);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  z-index: 1000;

  /* SVG stroke icons: default (#64748B) and active (#0891B2) */
  --icon-home-default: url('data:image/svg+xml;base64,');
  --icon-home-active: url('data:image/svg+xml;base64,');
  --icon-leaderboard-default: url('data:image/svg+xml;base64,');
  --icon-leaderboard-active: url('data:image/svg+xml;base64,');
  --icon-calendar-default: url('data:image/svg+xml;base64,');
  --icon-calendar-active: url('data:image/svg+xml;base64,');
  --icon-profile-default: url('data:image/svg+xml;base64,');
  --icon-profile-active: url('data:image/svg+xml;base64,');
  --icon-dashboard-default: url('data:image/svg+xml;base64,');
  --icon-dashboard-active: url('data:image/svg+xml;base64,');
  --icon-students-default: url('data:image/svg+xml;base64,');
  --icon-students-active: url('data:image/svg+xml;base64,');
  --icon-tasks-default: url('data:image/svg+xml;base64,');
  --icon-tasks-active: url('data:image/svg+xml;base64,');
  --icon-stats-default: url('data:image/svg+xml;base64,');
  --icon-stats-active: url('data:image/svg+xml;base64,');
  --icon-review-default: url('data:image/svg+xml;base64,');
  --icon-review-active: url('data:image/svg+xml;base64,');
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--color-text-secondary, #64748b);
  transition: color 0.15s ease;
}

.tab-item.active {
  color: var(--color-primary, #0891b2);
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
  line-height: 1.2;
}

/* Default icon states */
.icon-home { background-image: var(--icon-home-default); }
.icon-leaderboard { background-image: var(--icon-leaderboard-default); }
.icon-calendar { background-image: var(--icon-calendar-default); }
.icon-profile { background-image: var(--icon-profile-default); }
.icon-dashboard { background-image: var(--icon-dashboard-default); }
.icon-students { background-image: var(--icon-students-default); }
.icon-tasks { background-image: var(--icon-tasks-default); }
.icon-stats { background-image: var(--icon-stats-default); }
.icon-review { background-image: var(--icon-review-default); }

/* Active icon states */
.tab-item.active .icon-home { background-image: var(--icon-home-active); }
.tab-item.active .icon-leaderboard { background-image: var(--icon-leaderboard-active); }
.tab-item.active .icon-calendar { background-image: var(--icon-calendar-active); }
.tab-item.active .icon-profile { background-image: var(--icon-profile-active); }
.tab-item.active .icon-dashboard { background-image: var(--icon-dashboard-active); }
.tab-item.active .icon-students { background-image: var(--icon-students-active); }
.tab-item.active .icon-tasks { background-image: var(--icon-tasks-active); }
.tab-item.active .icon-stats { background-image: var(--icon-stats-active); }
.tab-item.active .icon-review { background-image: var(--icon-review-active); }
