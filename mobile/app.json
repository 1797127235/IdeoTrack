{
  "expo": {
    "name": "IdeoTrack",
    "slug": "ideo-track",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ECFEFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ideotrack.mobile"
    },
    "android": {
      "package": "com.ideotrack.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ECFEFF"
      }
    },
    "plugins": ["expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
