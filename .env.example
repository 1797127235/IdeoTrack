# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=ideo_track

# API
CLIENT_URL=*
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# WeChat Mini Program (required for wechat login)
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# WeChat subscribe message template ID for counselor one-click reminder (Epic 8.3)
WECHAT_REMINDER_TEMPLATE_ID=

# Web Admin Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_AMAP_JSAPI_KEY=
# Server-side API base URL for React Server Components (web container → api container)
API_BASE_URL=http://api:3000/api

# Face recognition service (FastAPI + InsightFace)
# 容器间用服务名；本地开发时若直接跑 python app.py，改为 http://localhost:8000
FACE_SERVICE_URL=http://face:8000

# Deployment domains (used by Caddyfile)
API_DOMAIN=api.your-domain.com
WEB_DOMAIN=admin.your-domain.com
